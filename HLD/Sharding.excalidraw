      "seed": 1401388760,
      "version": 195,
      "versionNonce": 667087832,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770217747647,
      "link": null,
      "locked": false,
      "text": "A bad shard key has low cardinality creates uneven distribution and it forces queries to hit many shards\njust to answer something simple in many cases.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A bad shard key has low cardinality creates uneven distribution and it forces queries to hit many shards\njust to answer something simple in many cases.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
