      ],
      "updated": 1770218264312,
      "link": null,
      "locked": false,
      "text": "If we have an ecommerce site, where most popular thing that users\nare doing is retrieving info about a single order both creating order\nretrieving orders, checkning status of orders, then sharding by order_id\nmakes lot of sence due to same 3 above properties.",
      "fontSize": 20,
      "fontFamily": 8,
