    {
      "id": "lbjWQRg75HyZ3075MUvJ_",
      "type": "text",
      "x": 317.5018382455738,
      "y": 4985.020713055474,
      "width": 1144,
      "height": 50,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
