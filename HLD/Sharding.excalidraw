      "text": "How to Shard (split) your data?",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How to Shard (split) your data?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "murAUEvF93JELtFSl_FKN",
      "type": "text",
      "x": 381.9228358301175,
      "y": 8295.660588910505,
      "width": 209,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1U",
      "roundness": null,
      "seed": 159384432,
      "version": 450,
      "versionNonce": 1444480680,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770219100077,
      "link": null,
      "locked": false,
      "text": "1. What to shard by\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
