    },
    {
      "id": "Lh5He27Ksw_dyUyldWsT-",
      "type": "text",
      "x": 735.681888484472,
      "y": 13683.608842735006,
      "width": 167.19976806640625,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
