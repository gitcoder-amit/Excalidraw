    {
      "id": "RkoqaxWJKKYYz01i0YEjX",
      "type": "text",
      "x": 384.0062969556432,
      "y": 3583.988317731547,
      "width": 1122,
      "height": 50,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4e",
      "roundness": null,
      "seed": 244917208,
      "version": 146,
      "versionNonce": 1839435944,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770215713459,
      "link": null,
      "locked": false,
      "text": "In Simple words the shard key is  how we group our data and the distribution strategy is how we place \nthose groups onto shards",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In Simple words the shard key is  how we group our data and the distribution strategy is how we place \nthose groups onto shards",
      "autoResize": true,
      "lineHeight": 1.25
    },
