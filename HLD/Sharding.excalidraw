    {
      "id": "qOGNsH-maek3d1x_MjWFc",
      "type": "text",
      "x": 312.58495462609744,
      "y": 4615.184373166652,
      "width": 1177,
      "height": 250,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4h",
      "roundness": null,
      "seed": 1181676456,
      "version": 819,
      "versionNonce": 1111807192,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770217638220,
      "link": null,
      "locked": false,
      "text": "High Cardinality ->  this is basically that we want a field with lots of unique values, so that we can\n    spread that data across the shards instead of piling everything on few shards, High cardinality means\nthat we can have a random or even distribution.\n\nEven Distribution -> Each shard roughly has same ammount of data.\n\nQuery Alignment -> Our shard key should match how we query our data\nExample -> If most of our queries are lets get all posts for a given user, then sharding by user_id, keeps \n    all of that user data on one shard, And it means we want to get all of a user's post. we only need to \nquery one database. We dont need to query all the different shards.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "High Cardinality ->  this is basically that we want a field with lots of unique values, so that we can\n    spread that data across the shards instead of piling everything on few shards, High cardinality means\nthat we can have a random or even distribution.\n\nEven Distribution -> Each shard roughly has same ammount of data.\n\nQuery Alignment -> Our shard key should match how we query our data\nExample -> If most of our queries are lets get all posts for a given user, then sharding by user_id, keeps \n    all of that user data on one shard, And it means we want to get all of a user's post. we only need to \nquery one database. We dont need to query all the different shards.",
      "autoResize": true,
      "lineHeight": 1.25
    },
