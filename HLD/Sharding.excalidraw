      "type": "text",
      "x": 120.0216763793548,
      "y": 6663.388132608721,
      "width": 413.552295918368,
      "height": 39.16214923469391,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
