      "text": "traffic keeps on increasing our database is now not able to handle the load, at this poing the\nissue can't be solve by bigger database",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "traffic keeps on increasing our database is now not able to handle the load, at this poing the\nissue can't be solve by bigger database",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xz8GRtvoDg3Hnr-nGEEu_",
      "type": "text",
      "x": 983.645402858421,
      "y": 870.2112995023854,
      "width": 11,
      "height": 25,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
