    {
      "id": "KTGi0-fCJKvYVrPhGyjga",
      "type": "text",
      "x": 203.5713879393009,
      "y": 5584.230202579111,
      "width": 1100,
      "height": 175,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4n",
      "roundness": null,
      "seed": 727942360,
      "version": 622,
      "versionNonce": 985992104,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "Jr4naccYKqL6V-Vu-eO-I",
          "type": "arrow"
        }
      ],
      "updated": 1770218264312,
      "link": null,
      "locked": false,
      "text": "We have a popular social media app and most common operation is users visiting another users profile\nand loading all of their posts.\nIn this case sharding by user_id is a great choice because it has \nhigh cardinality -> Every user has unique id so we have tons of  distinct values to spread across\nthe shards.\neven distribution\nquery alignement -> for one user we need to hit only one shard",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We have a popular social media app and most common operation is users visiting another users profile\nand loading all of their posts.\nIn this case sharding by user_id is a great choice because it has \nhigh cardinality -> Every user has unique id so we have tons of  distinct values to spread across\nthe shards.\neven distribution\nquery alignement -> for one user we need to hit only one shard",
      "autoResize": true,
      "lineHeight": 1.25
    },
