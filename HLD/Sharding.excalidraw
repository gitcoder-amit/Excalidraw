    {
      "id": "Jh4BbkF_WTsZbsSR5alBV",
      "type": "text",
      "x": 385.0652892218791,
      "y": 8494.334286476398,
      "width": 1254,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1S",
      "roundness": null,
      "seed": 645117840,
      "version": 987,
      "versionNonce": 1976121048,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770219665280,
      "link": null,
      "locked": false,
      "text": "Range Based -> we take the shard key and just simple split it based on ranges of shard key \n    Problem with this is it can very easily lead to unevern distribution, lets say our app in\nearly days then all the users will be in shard1 only, shard1 has real data and load and other\n2 are sitting empty,\nadditionaly may be more practically that if we are  sharding by userid and in our mid age all of our new users are\nending up over shard2 and after some time shard 3\nOne shard talking all heat of read and write, this is fine option intutively, its a nice place to start,\nbut its not what most things use in production(10:20)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Range Based -> we take the shard key and just simple split it based on ranges of shard key \n    Problem with this is it can very easily lead to unevern distribution, lets say our app in\nearly days then all the users will be in shard1 only, shard1 has real data and load and other\n2 are sitting empty,\nadditionaly may be more practically that if we are  sharding by userid and in our mid age all of our new users are\nending up over shard2 and after some time shard 3\nOne shard talking all heat of read and write, this is fine option intutively, its a nice place to start,\nbut its not what most things use in production(10:20)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ojSdIkYGBbxRPaBtBpt-k",
      "type": "text",
      "x": 390.6662180318421,
      "y": 8209.871113881834,
      "width": 613.7996215820312,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
