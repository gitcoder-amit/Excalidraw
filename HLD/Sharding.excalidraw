      ],
      "updated": 1770380620276,
      "link": null,
      "locked": false,
      "text": "BEGIN;\n\nUPDATE accounts\nSET balance = balance - 5\nWHERE name = 'Bob';\n\nUPDATE accounts\nSET balance = balance + 5\nWHERE name = 'Alice';\n\nCOMMIT;\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "BEGIN;\n\nUPDATE accounts\nSET balance = balance - 5\nWHERE name = 'Bob';\n\nUPDATE accounts\nSET balance = balance + 5\nWHERE name = 'Alice';\n\nCOMMIT;\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
