      "id": "gDjrlOezWUqZ1LRvw07fN",
      "type": "text",
      "x": 1178.1889276548636,
      "y": 6996.116507675865,
      "width": 814,
      "height": 225,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b52",
      "roundness": null,
      "seed": 580017320,
      "version": 667,
      "versionNonce": 234797736,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770219029992,
      "link": null,
      "locked": false,
      "text": "Another bad example which may be less intuitive is in the case\nwhere we shard by creation date, specaially if we are sharding\nby created date in the where most of the users quering the recent\ndata, Imaging our social media app and we have sharded by created \ndate posts. So all the post from 2023, 2024, 2025\n\nwhats going to happen here is that all of the traffic is going toward\nshard3 because most user are looking for the recent posts. So we are going\nto end up with that hot spot on shard3 so this was not evenly distributed",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Another bad example which may be less intuitive is in the case\nwhere we shard by creation date, specaially if we are sharding\nby created date in the where most of the users quering the recent\ndata, Imaging our social media app and we have sharded by created \ndate posts. So all the post from 2023, 2024, 2025\n\nwhats going to happen here is that all of the traffic is going toward\nshard3 because most user are looking for the recent posts. So we are going\nto end up with that hot spot on shard3 so this was not evenly distributed",
      "autoResize": true,
      "lineHeight": 1.25
    },
