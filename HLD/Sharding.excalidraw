    {
      "id": "h_JS-LB1R9CcTD1P7S9Gq",
      "type": "text",
      "x": 382.04143042205817,
      "y": 16277.659990850565,
      "width": 554.3997802734375,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 2,
