    {
      "type": "text",
      "version": 809,
      "versionNonce": 419930562,
      "isDeleted": false,
      "id": "AjGltnxLFp4W-MSuWVRn3",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 1568.5337071696106,
      "y": 9932.415608579606,
      "strokeColor": "#868e96",
      "backgroundColor": "#ffec99",
      "width": 351.99951171875,
      "height": 60,
      "seed": 333080464,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1770286433373,
      "link": null,
      "locked": false,
      "fontSize": 16,
      "fontFamily": 8,
      "text": "Where database does event 1234 live on? \nWell, hash(1234) = 16\nso...",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Where database does event 1234 live on? \nWell, hash(1234) = 16\nso...",
      "lineHeight": 1.25,
      "baseline": 53,
      "index": "b2G",
      "autoResize": true
    },
    {
      "id": "atb9YBU1pHYTjO86GPFYt",
      "type": "text",
      "x": 274.89540882292454,
      "y": 10781.863730343373,
      "width": 1232,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2H",
      "roundness": null,
      "seed": 560063856,
      "version": 1462,
      "versionNonce": 466019586,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770287467179,
      "link": null,
      "locked": false,
      "text": "Directory-Based Sharding -> instead of using a formula to decide where data lives, Directory sharding uses\na lookup tabe, And so for each record say each user, we store which shard they belong to in this lookup table.\nAnd so we simply on each read or write have to first come in look up table and find our which shard they belong\nto and go to the right shard. One advantage of this is flexibility. If one user becomes super popular and starts\ngenerating a ton of traffic we can move them onto their own shard easily by just updating lookup table.\n\nBut the downside is every single request now has extra latency, it needs to first lookup in lookup table and \nthen actually query the shard. so two request for every singly request. It is also going to create single\npoint of failure, this is good if we are okay with some extra latency, but in interview it is not the right \nanswer.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Directory-Based Sharding -> instead of using a formula to decide where data lives, Directory sharding uses\na lookup tabe, And so for each record say each user, we store which shard they belong to in this lookup table.\nAnd so we simply on each read or write have to first come in look up table and find our which shard they belong\nto and go to the right shard. One advantage of this is flexibility. If one user becomes super popular and starts\ngenerating a ton of traffic we can move them onto their own shard easily by just updating lookup table.\n\nBut the downside is every single request now has extra latency, it needs to first lookup in lookup table and \nthen actually query the shard. so two request for every singly request. It is also going to create single\npoint of failure, this is good if we are okay with some extra latency, but in interview it is not the right \nanswer.",
      "autoResize": true,
      "lineHeight": 1.25
    },
