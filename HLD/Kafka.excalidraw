    {
      "id": "PTl_w09njnDyzWWiKGkGD",
      "type": "text",
      "x": 889.243736682195,
      "y": 2990.2595614475094,
      "width": 2314.51123046875,
      "height": 675,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bC8",
      "roundness": null,
      "seed": 1814351130,
      "version": 1331,
      "versionNonce": 2030050592,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769005158003,
      "link": null,
      "locked": false,
      "text": "What can be the Partioning key that we would like to keep?\nLets say we are looking into some Regional service like OLA , OLA is just in the regions of India. One good way of keeping the\npatitioning key on the basis of region devision or state devision that we have in India.\n\n\nLets say some live match streaming is going on between India and Australia and lets say there is a Paikistan & England match\ngoing on for world cup, in that case whatever our match ID that we have that can be a partioning Key so it is basically depends\non what kind of solution we are building.\n\n\nFor a System like Uber, Driver location would not be only thing that we need to store in kafka, may be at any point of time some\nride request is coming that also we need to store in kafka, because on top of that we can calculate the pricing, for that also \nwe neeed to store the data and we are storing that data as well in kafka, \nSo what we can do, we can have a group of separate partition, we can have another group of partition which can store some other\ntype of data",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What can be the Partioning key that we would like to keep?\nLets say we are looking into some Regional service like OLA , OLA is just in the regions of India. One good way of keeping the\npatitioning key on the basis of region devision or state devision that we have in India.\n\n\nLets say some live match streaming is going on between India and Australia and lets say there is a Paikistan & England match\ngoing on for world cup, in that case whatever our match ID that we have that can be a partioning Key so it is basically depends\non what kind of solution we are building.\n\n\nFor a System like Uber, Driver location would not be only thing that we need to store in kafka, may be at any point of time some\nride request is coming that also we need to store in kafka, because on top of that we can calculate the pricing, for that also \nwe neeed to store the data and we are storing that data as well in kafka, \nSo what we can do, we can have a group of separate partition, we can have another group of partition which can store some other\ntype of data",
      "autoResize": true,
      "lineHeight": 1.25
    },
