        }
      ],
      "updated": 1768827717380,
      "link": null,
      "locked": false,
      "text": "Producer -> is a system who is responsible for putting\n                the data into out queues\n                Now the same definition of Producer\n                 is work for kafka as well , In Kafka whatever\n                 data is going to be created that is going to\n                  be created by the producer.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Producer -> is a system who is responsible for putting\n                the data into out queues\n                Now the same definition of Producer\n                 is work for kafka as well , In Kafka whatever\n                 data is going to be created that is going to\n                  be created by the producer.",
      "autoResize": true,
      "lineHeight": 1.25
    },
