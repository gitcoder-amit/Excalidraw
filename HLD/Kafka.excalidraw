    {
      "id": "BaHgiqV6rpm_3b8efzDF8",
      "type": "text",
      "x": 929.2799915650075,
      "y": 4532.931436447509,
      "width": 2346.73095703125,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCM",
      "roundness": null,
      "seed": 1655474464,
      "version": 628,
      "versionNonce": 1957100832,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769005741568,
      "link": null,
      "locked": false,
      "text": "This is where concept of Kafka topic comes into the picture, we can say for 1 type of data or 1 set of partions we have one topic.\nHence the topic is eventually going to store all of the data about one event. So one type of event goes to 1 topic. So inside that\ntopic there can be multiple partitions so based on our partition logic one of the partition will take that data(event). So for diff diff\ntype of events we have diff diff type of Kafka Topics.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This is where concept of Kafka topic comes into the picture, we can say for 1 type of data or 1 set of partions we have one topic.\nHence the topic is eventually going to store all of the data about one event. So one type of event goes to 1 topic. So inside that\ntopic there can be multiple partitions so based on our partition logic one of the partition will take that data(event). So for diff diff\ntype of events we have diff diff type of Kafka Topics.",
      "autoResize": true,
      "lineHeight": 1.25
    },
