    {
      "id": "rpvfN_UhvOFZ6mDNJqY_s",
      "type": "text",
      "x": 925.204674182195,
      "y": -61.08418855249056,
      "width": 2089.943359375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fff5f5",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBT",
      "roundness": null,
      "seed": 398358618,
      "version": 525,
      "versionNonce": 1642572890,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768913074394,
      "link": null,
      "locked": false,
      "text": "this is where Kafka outshine\neverywhere. -> kafka will keep the data, now our driver data is not just need to be updated in the database. Our \ndriver location can be required for multiple reasons, updating location or getting live location or analyzing the trip\nlike what went wrong with the trip or what went right in the trip. So now there can be multiple reasons that whatever\nyour data is that we are technically collectly that can be read by multiple consumers.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "this is where Kafka outshine\neverywhere. -> kafka will keep the data, now our driver data is not just need to be updated in the database. Our \ndriver location can be required for multiple reasons, updating location or getting live location or analyzing the trip\nlike what went wrong with the trip or what went right in the trip. So now there can be multiple reasons that whatever\nyour data is that we are technically collectly that can be read by multiple consumers.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ZULMKZdgddnPH1sT5bEdM",
      "type": "rectangle",
      "x": 1064.626549182195,
      "y": 618.1228426975094,
      "width": 199.34375,
