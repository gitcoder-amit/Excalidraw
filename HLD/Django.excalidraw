    {
      "id": "cBFSp-oH-Ufzge9F2M_AO",
      "type": "text",
      "x": -1741.3636958921434,
      "y": 2638.177218662855,
      "width": 277.1998291015625,
      "height": 90,
      "angle": 0,
      "strokeColor": "#e03131",
