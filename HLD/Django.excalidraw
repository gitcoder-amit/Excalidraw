      "seed": 1918255171,
      "version": 38,
      "versionNonce": 183377439,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1770404286338,
      "link": null,
      "locked": false,
      "text": "To Confirm the\nbooking.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
