    {
      "id": "GpNKaDoaK9CMORJxkmSDK",
      "type": "text",
      "x": -1091.3805890054834,
      "y": 1037.5133081643505,
      "width": 2039.39892578125,
      "height": 720,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1z",
      "roundness": null,
      "seed": 1840268653,
      "version": 1329,
      "versionNonce": 190408113,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1770404286338,
      "link": null,
      "locked": false,
      "text": "-> the purpose fo core entities is to start to get an understanding of what data is persisted in \nour system and then exchanged by the APIs. We are going to use these in order to build our APIs as \nwell as of course High level design.\n\nFirst entity -> Event -> Admin can add these events note adding event is out of scope we just focuses\n    just on user flow for our system.Events themselved need to be hosted somewhere so they are usually\nhosted at venue like a stadium. and then there is somebody who is performing. So there is a Performer\nSo we probably will have table for \nEvent\nVenue\nPerformer\nTicket -> this will going to have all the tickets for an event. so that we can determine whethere these\n            are available or not. who has purchased that stuff like that.\nWe can mention the keys if we know related to Entity, but the suggestion is just stick to the entities \nand clear interviewer I am not going to detail the key fields and columns here because the reality is\nI quite dont know them yet ",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-> the purpose fo core entities is to start to get an understanding of what data is persisted in \nour system and then exchanged by the APIs. We are going to use these in order to build our APIs as \nwell as of course High level design.\n\nFirst entity -> Event -> Admin can add these events note adding event is out of scope we just focuses\n    just on user flow for our system.Events themselved need to be hosted somewhere so they are usually\nhosted at venue like a stadium. and then there is somebody who is performing. So there is a Performer\nSo we probably will have table for \nEvent\nVenue\nPerformer\nTicket -> this will going to have all the tickets for an event. so that we can determine whethere these\n            are available or not. who has purchased that stuff like that.\nWe can mention the keys if we know related to Entity, but the suggestion is just stick to the entities \nand clear interviewer I am not going to detail the key fields and columns here because the reality is\nI quite dont know them yet ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dG-594TjJMDlHk9koyleM",
      "type": "text",
      "x": -742.0467745190767,
      "y": 2129.8835884783507,
      "width": 1583.999267578125,
      "height": 450,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b20",
      "roundness": null,
      "seed": 2027978755,
      "version": 926,
      "versionNonce": 2107492831,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1770404286338,
      "link": null,
      "locked": false,
      "text": "-> we are goint to click on ticket and it being reserved we have 10 minutes\n   actually to book it if we dont book it, that ticket goes back to available.\nand thats the same pattern that we have here.\nSo In an interview some candidates because they have experience with these sorts\nof things they have thought about that they know that its two phase and thats\nusually awesome to see but its not a requirement, If I see that a user writes a\nsingle endpoint for booking a ticket then I will point out actually this is \ngoing to be a two phase process and then they will ammend them accordingly so \nwhat will end up doing here is we will have some posts may be call it booking\nand the first endpoint is going to be just reserve",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-> we are goint to click on ticket and it being reserved we have 10 minutes\n   actually to book it if we dont book it, that ticket goes back to available.\nand thats the same pattern that we have here.\nSo In an interview some candidates because they have experience with these sorts\nof things they have thought about that they know that its two phase and thats\nusually awesome to see but its not a requirement, If I see that a user writes a\nsingle endpoint for booking a ticket then I will point out actually this is \ngoing to be a two phase process and then they will ammend them accordingly so \nwhat will end up doing here is we will have some posts may be call it booking\nand the first endpoint is going to be just reserve",
      "autoResize": true,
      "lineHeight": 1.25
    },
