    {
      "id": "7axtxSovbYJB53339S_0i",
      "type": "text",
      "x": -1760.4853242330973,
      "y": 3062.7513877791534,
      "width": 2446.334228515625,
      "height": 89.67968750000011,
      "angle": 0,
      "strokeColor": "#e03131",
