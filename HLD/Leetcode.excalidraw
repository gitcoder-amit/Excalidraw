      "seed": 1596934047,
      "version": 681,
      "versionNonce": 2082646833,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1767367979039,
      "link": null,
      "locked": false,
      "text": "User make a submission, submission goes to Load Balancer, redirected to App server\nApp Server will immediately make an entry to the DB the moment App Server has made an \nentry to the database this App Server 1 will immediately respond back to the user that\nhey we have recorded your submission and we are evaluating your submission once your \nsubmission is evaluated you will be notified and the User is free, it means we are not \nblocking our User on evaluation we are just blocking our User on DB entry creation\n\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User make a submission, submission goes to Load Balancer, redirected to App server\nApp Server will immediately make an entry to the DB the moment App Server has made an \nentry to the database this App Server 1 will immediately respond back to the user that\nhey we have recorded your submission and we are evaluating your submission once your \nsubmission is evaluated you will be notified and the User is free, it means we are not \nblocking our User on evaluation we are just blocking our User on DB entry creation\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
