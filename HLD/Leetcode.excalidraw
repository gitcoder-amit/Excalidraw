      "index": "b4E",
      "roundness": null,
      "seed": 1264623212,
      "version": 70,
      "versionNonce": 1108434772,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1767711668137,
      "link": null,
      "locked": false,
      "text": "Here we will write job processor\n(code) for submission",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Here we will write job processor\n(code) for submission",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "yrQ-PbTJ2KLiUJ-7rkLng",
      "type": "text",
      "x": 368.1336038394385,
      "y": 14257.033231658246,
      "width": 554.4718017578125,
      "height": 135,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4F",
      "roundness": null,
      "seed": 63509100,
      "version": 157,
      "versionNonce": 1259652308,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1767711727670,
      "link": null,
      "locked": false,
      "text": "IN App server we will write\ncode, that will be job processor\nfor evaluator.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "IN App server we will write\ncode, that will be job processor\nfor evaluator.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ynNwIYI-O-kccwYNbbeha",
      "type": "text",
      "x": 350.8158955061049,
      "y": 15797.645210824903,
      "width": 2742.51513671875,
      "height": 270,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4G",
      "roundness": null,
      "seed": 257990612,
      "version": 726,
      "versionNonce": 2123294060,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1767712101422,
      "link": null,
      "locked": false,
      "text": "Using queues we will be able to scale our system enough, if we are expecting a lot of user bombarding during contest submission then we will horizontally\nscale our queues, similarily we can scale our evaluator machines as well\n\nDocker allow us to restrict the amount of memory our container is actually having if the code taking more memory than the memory allocated to the docker\ncontainer our docker container will give response out of memory so we will give MLE.\nwe can write the logic to record the time when code is loaded and if the code running time is more than the time setup for the problem then it will be TLE.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Using queues we will be able to scale our system enough, if we are expecting a lot of user bombarding during contest submission then we will horizontally\nscale our queues, similarily we can scale our evaluator machines as well\n\nDocker allow us to restrict the amount of memory our container is actually having if the code taking more memory than the memory allocated to the docker\ncontainer our docker container will give response out of memory so we will give MLE.\nwe can write the logic to record the time when code is loaded and if the code running time is more than the time setup for the problem then it will be TLE.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xBydiEh7UQl6efNnxjj6V",
      "type": "text",
      "x": 380.6661559227714,
      "y": 16270.093127491571,
      "width": 2783.23095703125,
      "height": 135,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4H",
      "roundness": null,
      "seed": 676023532,
      "version": 516,
      "versionNonce": 1312610260,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "2P-lc58eN_dj_SwS7ZoxU",
          "type": "arrow"
        },
        {
          "id": "eXnxcAVP75ztboemaPm4Z",
          "type": "arrow"
        },
        {
          "id": "HGPFCOOdm0gg0CG81IL0v",
          "type": "arrow"
        }
      ],
      "updated": 1767712480749,
      "link": null,
      "locked": false,
      "text": "What about Testcases -> Most of the time test cases are static files. we store test cases in form of Text file. these text files are actually stored on \nAWS S3 inside this our input and output test cases are setup. our docker container will communicate with this S3 instance and download the test cases from\nthere to the evaluation and matching the output with the s3 bucket and evaluated output 46:15",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What about Testcases -> Most of the time test cases are static files. we store test cases in form of Text file. these text files are actually stored on \nAWS S3 inside this our input and output test cases are setup. our docker container will communicate with this S3 instance and download the test cases from\nthere to the evaluation and matching the output with the s3 bucket and evaluated output 46:15",
      "autoResize": true,
      "lineHeight": 1.25
    },
