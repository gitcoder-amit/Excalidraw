    {
      "id": "2opD-7w-3G9zQKV3iGGM5",
      "type": "text",
      "x": 940.9271559087902,
      "y": 7814.141717949818,
      "width": 1578.3116455078125,
      "height": 360,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
