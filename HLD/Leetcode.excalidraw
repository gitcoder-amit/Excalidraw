    {
      "id": "Ex1iK2KNMX2h0G-Swb7nA",
      "type": "text",
      "x": 3035.4513121727714,
      "y": 14173.556669158246,
      "width": 550.2957763671875,
      "height": 90,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
