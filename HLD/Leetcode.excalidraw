    {
      "id": "7MlAXlU7-sz59pZyeX1iZ",
      "type": "text",
      "x": 2027.253570789973,
      "y": 541.3689411531351,
      "width": 812.0516357421875,
      "height": 495,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ah",
      "roundness": null,
      "seed": 1832215976,
      "version": 366,
      "versionNonce": 1178184452,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1767451228019,
      "link": null,
      "locked": false,
      "text": "Due to we have single App server to process\nthe request and provide the response\nour system can face Single Point of failure\n\nSo we need to scale our system\nVertically or Horizontally\n\nVertical -> It is limited in nature\n\nSO we will go with Horizontally scaling our App\nServers",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Due to we have single App server to process\nthe request and provide the response\nour system can face Single Point of failure\n\nSo we need to scale our system\nVertically or Horizontally\n\nVertical -> It is limited in nature\n\nSO we will go with Horizontally scaling our App\nServers",
      "autoResize": true,
      "lineHeight": 1.25
    },
