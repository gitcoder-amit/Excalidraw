    {
      "id": "xGuJEVAwI9ofK6HI1xzy1",
      "type": "text",
      "x": 904.9893907653108,
      "y": -213.71452770645215,
      "width": 1822.6436767578125,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
