      "seed": 951700802,
      "version": 359,
      "versionNonce": 1090707614,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1768225114571,
      "link": null,
      "locked": false,
      "text": "What Socket Manager service is going to do? It will be always having \na websocket connection prepared with client and it will be separately \nhorizontally scaled\nIf this socket service if we want more client connections then we can\nhorizontally scaled if connection dropping then we can drop the no of \nscaled machines",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What Socket Manager service is going to do? It will be always having \na websocket connection prepared with client and it will be separately \nhorizontally scaled\nIf this socket service if we want more client connections then we can\nhorizontally scaled if connection dropping then we can drop the no of \nscaled machines",
      "autoResize": true,
      "lineHeight": 1.25
    },
