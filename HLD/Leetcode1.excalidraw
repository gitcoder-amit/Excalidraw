    {
      "id": "lnMo0G2zLR28bRAVCpBjY",
      "type": "text",
      "x": 2397.888501608728,
      "y": -12712.285941150658,
      "width": 1237.319580078125,
      "height": 270,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ced4da",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
