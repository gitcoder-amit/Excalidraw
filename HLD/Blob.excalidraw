    {
      "id": "g7YFH1Y99nLGjw4TC3Nue",
      "type": "text",
      "x": 2338.476226684599,
      "y": 6639.576846630557,
      "width": 294.6550332562312,
      "height": 55.80587751064985,
      "angle": 0,
      "strokeColor": "#e03131",
