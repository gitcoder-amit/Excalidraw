    {
      "id": "k__zzy6UpbG7JiD-hXA06",
      "type": "text",
      "x": 532.1712604336194,
      "y": 4127.441821133523,
      "width": 962.5,
      "height": 156.25645702981961,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
