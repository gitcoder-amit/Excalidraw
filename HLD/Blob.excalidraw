      "boundElements": [],
      "updated": 1771307885704,
      "link": null,
      "locked": false,
      "text": "Memory (RAM) is roughly 10,000× faster than disk (SSD) on average.",
      "fontSize": 44.64470200851988,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Memory (RAM) is roughly 10,000× faster than disk (SSD) on average.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "F0X1sBqDZP4uEpKup80R8",
      "type": "text",
      "x": 606.0153789367018,
      "y": -17120.855876077687,
      "width": 1558.8228399919867,
      "height": 111.6117550212997,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aE",
      "roundness": null,
      "seed": 1156266598,
      "version": 559,
      "versionNonce": 1168454141,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1771307885704,
      "link": null,
      "locked": false,
      "text": "A cache is just a temporary storage that keeps recently used\ndata handy so you can get it much faster next time.",
      "fontSize": 44.64470200851988,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A cache is just a temporary storage that keeps recently used data handy so you can get it much faster next time.",
      "autoResize": false,
      "lineHeight": 1.25
    },
