    {
      "id": "u4u0ZqixfQLBO91TxrtjG",
      "type": "text",
      "x": 444.952275812734,
      "y": -972.188890490801,
      "width": 2332.439453125,
      "height": 558.0587751064985,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0d",
      "roundness": null,
      "seed": 967989798,
      "version": 1396,
      "versionNonce": 572024371,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1771307885705,
      "link": null,
      "locked": false,
      "text": "3. Write-behind(Write Back) -> Similar to Write through but instead of updating the database\n    synchronously the cache write to the database asynchronously in the background So the \n    application only write to the cache just like we did in write through but then cache fluses\n    those updated to DB usually in batches later on asynchronously. So this make write much\n    faster than write through, we solve that problem but it introduces new risk and thats that\n    if cache were crashed or failed before this flush, then we will have data loss.\n    We can use this only when high throughput is more important than immediate consistency or\n    close to immediate consistency.\n\nExample -> Analytics, Metric pipeline where some occasional data loss might be acceptable.",
      "fontSize": 44.64470200851988,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3. Write-behind(Write Back) -> Similar to Write through but instead of updating the database\n    synchronously the cache write to the database asynchronously in the background So the \n    application only write to the cache just like we did in write through but then cache fluses\n    those updated to DB usually in batches later on asynchronously. So this make write much\n    faster than write through, we solve that problem but it introduces new risk and thats that\n    if cache were crashed or failed before this flush, then we will have data loss.\n    We can use this only when high throughput is more important than immediate consistency or\n    close to immediate consistency.\n\nExample -> Analytics, Metric pipeline where some occasional data loss might be acceptable.",
      "autoResize": true,
      "lineHeight": 1.25
    },
