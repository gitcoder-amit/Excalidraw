      "text": "Cache Eviction Policies -> ",
      "fontSize": 62.50258281192785,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cache Eviction Policies -> ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "14XBjM4plJESqHDgbBdq4",
      "type": "text",
      "x": 538.367420043218,
      "y": 3190.9237412887614,
      "width": 2309.911533826974,
      "height": 669.6705301277984,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1K",
      "roundness": null,
      "seed": 1525242746,
      "version": 735,
      "versionNonce": 1026784189,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1771307885705,
      "link": null,
      "locked": false,
      "text": "Least Recently Used (LRU) – Evict items that haven’t been used recently. Most common and\nbalanced default.\n\nLeast Frequently Used (LFU) – Evict items that are used least often, even if accessed\nrecently. Good for highly skewed access patterns.\n\nFirst-In-First-Out (FIFO) – Evict the oldest item first. Simple, but rarely the right choice.\n\nTime-To-Live (TTL) – Each item expires after a set time (e.g., 5 minutes). Great for data that\ncan go stale, like API responses.\n\n",
      "fontSize": 44.644702008519886,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Least Recently Used (LRU) – Evict items that haven’t been used recently. Most common and balanced default.\n\nLeast Frequently Used (LFU) – Evict items that are used least often, even if accessed recently. Good for highly skewed access patterns.\n\nFirst-In-First-Out (FIFO) – Evict the oldest item first. Simple, but rarely the right choice.\n\nTime-To-Live (TTL) – Each item expires after a set time (e.g., 5 minutes). Great for data that can go stale, like API responses.\n\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
