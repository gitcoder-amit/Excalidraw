    {
      "id": "zr6IwLTjBUnwp8ChNK_dl",
      "type": "text",
      "x": 445.6630880231751,
      "y": -4424.410982105763,
      "width": 2307.88720703125,
      "height": 446.4470200851987,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0D",
      "roundness": null,
      "seed": 601628070,
      "version": 1388,
      "versionNonce": 82416915,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1771307885705,
      "link": null,
      "locked": false,
      "text": "1. Cache-Aside -> here what happens is that the application checks the cache first, if the\n    data is there it returns it, thats Cache hit, If not it goes and fetch it from the \ndatabase and then stores it in cache and returns it to the user. So It is great because it \nkeeps cache lean, we only cache data, when we actually need it, We are only caching the things\nthat users actually requested. If user not requested anything it will never be in cache.\n    But the downside is that a cache miss is going to add the latency since the request has to\ngo and hit the database, request the data the more expensive operation, store it in cache and \nreturn back to user.",
      "fontSize": 44.64470200851987,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Cache-Aside -> here what happens is that the application checks the cache first, if the\n    data is there it returns it, thats Cache hit, If not it goes and fetch it from the \ndatabase and then stores it in cache and returns it to the user. So It is great because it \nkeeps cache lean, we only cache data, when we actually need it, We are only caching the things\nthat users actually requested. If user not requested anything it will never be in cache.\n    But the downside is that a cache miss is going to add the latency since the request has to\ngo and hit the database, request the data the more expensive operation, store it in cache and \nreturn back to user.",
      "autoResize": true,
      "lineHeight": 1.25
    },
