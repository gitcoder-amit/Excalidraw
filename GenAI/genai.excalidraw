      "groupIds": [],
      "frameId": null,
      "index": "bWx",
      "roundness": null,
      "seed": 166622451,
      "version": 515,
      "versionNonce": 2119410877,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777019667811,
      "link": null,
      "locked": false,
      "text": "LLMs basic principle is to predict, it will not calculate this.  the speciality of these LLM\nmodels is that their prediction is very accurate. WE have trained these models in this manner\nthat they are very accurate. LLM model can predict or pretrained data. It cann't make prediction about the\ndata about which it does not have knowledge.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "LLMs basic principle is to predict, it will not calculate this.  the speciality of these LLM\nmodels is that their prediction is very accurate. WE have trained these models in this manner\nthat they are very accurate. LLM model can predict or pretrained data. It cann't make prediction about the\ndata about which it does not have knowledge.",
      "autoResize": true,
      "lineHeight": 1.25
    },
