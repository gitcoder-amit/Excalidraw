      "updated": 1777012524813,
      "link": null,
      "locked": false,
      "text": "MusicSystem\nUser\nSong\nArtist\nAlbum\nPlaylist\nPlayer\nSubscription\nSearchService (Strategy)\nRecommendationService (optional advanced)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "MusicSystem\nUser\nSong\nArtist\nAlbum\nPlaylist\nPlayer\nSubscription\nSearchService (Strategy)\nRecommendationService (optional advanced)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Kg_rkWNyoVQ_dwX0xbQ4y",
      "type": "text",
      "x": 1022.4092489213419,
      "y": 41415.35255830291,
      "width": 825,
      "height": 2925,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVi",
      "roundness": null,
      "seed": 1263103747,
      "version": 75,
      "versionNonce": 705588413,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777012524813,
      "link": null,
      "locked": false,
      "text": "class Song:\n    def __init__(self, song_id, title, duration, artist):\n        self.song_id = song_id\n        self.title = title\n        self.duration = duration\n        self.artist = artist\n\n\nclass Artist:\n    def __init__(self, artist_id, name):\n        self.artist_id = artist_id\n        self.name = name\n\n\nclass Album:\n    def __init__(self, album_id, name):\n        self.album_id = album_id\n        self.name = name\n        self.songs = []\n\n    def add_song(self, song):\n        self.songs.append(song)\n\n\nclass User:\n    def __init__(self, user_id, name):\n        self.user_id = user_id\n        self.name = name\n        self.playlists = []\n        self.history = []\n\n    def create_playlist(self, playlist_name):\n        playlist = Playlist(playlist_name)\n        self.playlists.append(playlist)\n        return playlist\n\nclass Playlist:\n    def __init__(self, name):\n        self.name = name\n        self.songs = []\n\n    def add_song(self, song):\n        self.songs.append(song)\n\n    def remove_song(self, song):\n        self.songs.remove(song)\n\n\nclass Player:\n    def __init__(self):\n        self.current_song = None\n        self.is_playing = False\n\n    def play(self, song):\n        self.current_song = song\n        self.is_playing = True\n        print(f\"Playing: {song.title}\")\n\n    def pause(self):\n        if self.is_playing:\n            self.is_playing = False\n            print(\"Paused\")\n\n    def resume(self):\n        if not self.is_playing and self.current_song:\n            self.is_playing = True\n            print(\"Resumed\")\n\n    def stop(self):\n        self.current_song = None\n        self.is_playing = False\n        print(\"Stopped\")\n\n\nclass SearchStrategy:\n    def search(self, songs, query):\n        raise NotImplementedError\n\n\nclass SearchByTitle(SearchStrategy):\n    def search(self, songs, query):\n        return [s for s in songs if query.lower() in s.title.lower()]\n\n\nclass SearchByArtist(SearchStrategy):\n    def search(self, songs, query):\n        return [s for s in songs if query.lower() in s.artist.name.lower()]\n\n\n\nclass MusicSystem:\n    def __init__(self):\n        self.songs = []\n        self.users = []\n        self.player = Player()\n\n    def add_song(self, song):\n        self.songs.append(song)\n\n    def register_user(self, user):\n        self.users.append(user)\n\n    def search(self, strategy, query):\n        return strategy.search(self.songs, query)\n\n    def play_song(self, user, song):\n        self.player.play(song)\n        user.history.append(song)\n\n\nclass Subscription:  -> similar to payment optinal\n    def __init__(self, user, is_premium=False):\n        self.user = user\n        self.is_premium = is_premium\n\n    def upgrade(self):\n        self.is_premium = True",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class Song:\n    def __init__(self, song_id, title, duration, artist):\n        self.song_id = song_id\n        self.title = title\n        self.duration = duration\n        self.artist = artist\n\n\nclass Artist:\n    def __init__(self, artist_id, name):\n        self.artist_id = artist_id\n        self.name = name\n\n\nclass Album:\n    def __init__(self, album_id, name):\n        self.album_id = album_id\n        self.name = name\n        self.songs = []\n\n    def add_song(self, song):\n        self.songs.append(song)\n\n\nclass User:\n    def __init__(self, user_id, name):\n        self.user_id = user_id\n        self.name = name\n        self.playlists = []\n        self.history = []\n\n    def create_playlist(self, playlist_name):\n        playlist = Playlist(playlist_name)\n        self.playlists.append(playlist)\n        return playlist\n\nclass Playlist:\n    def __init__(self, name):\n        self.name = name\n        self.songs = []\n\n    def add_song(self, song):\n        self.songs.append(song)\n\n    def remove_song(self, song):\n        self.songs.remove(song)\n\n\nclass Player:\n    def __init__(self):\n        self.current_song = None\n        self.is_playing = False\n\n    def play(self, song):\n        self.current_song = song\n        self.is_playing = True\n        print(f\"Playing: {song.title}\")\n\n    def pause(self):\n        if self.is_playing:\n            self.is_playing = False\n            print(\"Paused\")\n\n    def resume(self):\n        if not self.is_playing and self.current_song:\n            self.is_playing = True\n            print(\"Resumed\")\n\n    def stop(self):\n        self.current_song = None\n        self.is_playing = False\n        print(\"Stopped\")\n\n\nclass SearchStrategy:\n    def search(self, songs, query):\n        raise NotImplementedError\n\n\nclass SearchByTitle(SearchStrategy):\n    def search(self, songs, query):\n        return [s for s in songs if query.lower() in s.title.lower()]\n\n\nclass SearchByArtist(SearchStrategy):\n    def search(self, songs, query):\n        return [s for s in songs if query.lower() in s.artist.name.lower()]\n\n\n\nclass MusicSystem:\n    def __init__(self):\n        self.songs = []\n        self.users = []\n        self.player = Player()\n\n    def add_song(self, song):\n        self.songs.append(song)\n\n    def register_user(self, user):\n        self.users.append(user)\n\n    def search(self, strategy, query):\n        return strategy.search(self.songs, query)\n\n    def play_song(self, user, song):\n        self.player.play(song)\n        user.history.append(song)\n\n\nclass Subscription:  -> similar to payment optinal\n    def __init__(self, user, is_premium=False):\n        self.user = user\n        self.is_premium = is_premium\n\n    def upgrade(self):\n        self.is_premium = True",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "QXb2iuewD74RNQo0ceHXw",
      "type": "text",
      "x": 1032.627998921342,
      "y": 44461.12990205291,
      "width": 583,
      "height": 1200,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVj",
      "roundness": null,
      "seed": 410997613,
      "version": 16,
      "versionNonce": 367626643,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777012524813,
      "link": null,
      "locked": false,
      "text": "🚀 Demo\n\n\n# Create system\nmusic_system = MusicSystem()\n\n# Artist\nartist = Artist(1, \"Arijit Singh\")\n\n# Songs\nsong1 = Song(1, \"Tum Hi Ho\", 240, artist)\nsong2 = Song(2, \"Channa Mereya\", 300, artist)\n\nmusic_system.add_song(song1)\nmusic_system.add_song(song2)\n\n# User\nuser = User(1, \"Amit\")\nmusic_system.register_user(user)\n\n# Search\nresults = music_system.search(SearchByTitle(), \"Tum\")\nsong = results[0]\n\n# Play\nmusic_system.play_song(user, song)\n\n# Playlist\nplaylist = user.create_playlist(\"Favorites\")\nplaylist.add_song(song)\n\n# Pause / Resume\nmusic_system.player.pause()\nmusic_system.player.resume()\n\n\n\n\n\n4. Real-world Enhancements (if interviewer pushes)\n\nYou can say:\n\nCache popular songs (Redis)\nUse CDN for streaming\nUse queue (Kafka) for play events\nStore play history for recommendations\nRate limiting for free users",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "🚀 Demo\n\n\n# Create system\nmusic_system = MusicSystem()\n\n# Artist\nartist = Artist(1, \"Arijit Singh\")\n\n# Songs\nsong1 = Song(1, \"Tum Hi Ho\", 240, artist)\nsong2 = Song(2, \"Channa Mereya\", 300, artist)\n\nmusic_system.add_song(song1)\nmusic_system.add_song(song2)\n\n# User\nuser = User(1, \"Amit\")\nmusic_system.register_user(user)\n\n# Search\nresults = music_system.search(SearchByTitle(), \"Tum\")\nsong = results[0]\n\n# Play\nmusic_system.play_song(user, song)\n\n# Playlist\nplaylist = user.create_playlist(\"Favorites\")\nplaylist.add_song(song)\n\n# Pause / Resume\nmusic_system.player.pause()\nmusic_system.player.resume()\n\n\n\n\n\n4. Real-world Enhancements (if interviewer pushes)\n\nYou can say:\n\nCache popular songs (Redis)\nUse CDN for streaming\nUse queue (Kafka) for play events\nStore play history for recommendations\nRate limiting for free users",
      "autoResize": true,
      "lineHeight": 1.25
    },
