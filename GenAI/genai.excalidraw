    {
      "id": "YBBBB1Nml_-zmuOLHm7cP",
      "type": "text",
      "x": 968.0227860710254,
      "y": 45343.84846108648,
      "width": 1166,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
