    {
      "id": "smZMnZnpkWnT0VZPdn2o_",
      "type": "text",
      "x": 948.6670614213419,
      "y": 41794.08302705291,
      "width": 1045,
      "height": 125,
      "angle": 0,
      "strokeColor": "#2f9e44",
