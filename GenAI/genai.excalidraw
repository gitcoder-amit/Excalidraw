    {
      "id": "zXVEwlQPipW-ulX_SJRfH",
      "type": "text",
      "x": 1071.604561421342,
      "y": 42301.34083955291,
      "width": 1133,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bW2",
      "roundness": null,
      "seed": 1295657885,
      "version": 594,
      "versionNonce": 2031840979,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777015530563,
      "link": null,
      "locked": false,
      "text": "If we have ChatGPT and we have trained it on top of something, then it can give any answer behind\nit, Suppose we have trained it on Stock Market. Now if we will ask any question related to stock market\nit can give that answer. Like we as a human if we have read 500 books related to stock market then\nwe can give any answer of stock market. We can make our answer, In the same way chatGPT can also\nanswer related question on which we have trained it.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If we have ChatGPT and we have trained it on top of something, then it can give any answer behind\nit, Suppose we have trained it on Stock Market. Now if we will ask any question related to stock market\nit can give that answer. Like we as a human if we have read 500 books related to stock market then\nwe can give any answer of stock market. We can make our answer, In the same way chatGPT can also\nanswer related question on which we have trained it.",
      "autoResize": true,
      "lineHeight": 1.25
    },
