    {
      "id": "ZatIiyPN1QmBRAy_l7N5A",
      "type": "text",
      "x": 1520.4591427514686,
      "y": 78842.65266046129,
      "width": 77,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bz5",
      "roundness": null,
      "seed": 786299261,
      "version": 9,
      "versionNonce": 1801383037,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777703239085,
      "link": null,
      "locked": false,
      "text": "Context",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Context",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GF3HiEjbUBwiE5hmKlnh5",
      "type": "text",
      "x": 1291.4591427514686,
      "y": 79261.65266046129,
      "width": 990,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bz6",
      "roundness": null,
      "seed": 1248178867,
      "version": 200,
      "versionNonce": 749737939,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777703336315,
      "link": null,
      "locked": false,
      "text": "Some companies train LLM model on this data rather giving data as context\n\nBut fine tune process is expensive, Hence we will pass our document as context to our LLM.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Some companies train LLM model on this data rather giving data as context\n\nBut fine tune process is expensive, Hence we will pass our document as context to our LLM.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xKYvQUxkWkj908bc59j_A",
      "type": "text",
      "x": 1287.7794552514686,
      "y": 79421.43000421129,
      "width": 836,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bz7",
      "roundness": null,
      "seed": 253001491,
      "version": 81,
      "versionNonce": 1987731731,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777703393300,
      "link": null,
      "locked": false,
      "text": "What is the problem if we will pass our document or data as context to LLM->",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What is the problem if we will pass our document or data as context to LLM->",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "93XHtV0lBkz9MkX5Vf6xY",
      "type": "text",
      "x": 1321.9161740014686,
      "y": 79464.98469171129,
      "width": 1122,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bz9",
      "roundness": null,
      "seed": 229380157,
      "version": 682,
      "versionNonce": 949187027,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777703679807,
      "link": null,
      "locked": false,
      "text": "Documents are not fixed, they are changing on daily basis. We are giving this as a context, then \nexpense will be tokens,  tokens will be spent. LLM charges us on the basis of tokens. In this document\nthere will be multiple things that are of no use for this current question, lets say we are asking\nabout what is the revenue, so giving whole document means lot of token, expense more, instead of that\nwe will pass only data as context that has info about the revenue, then our token will be saved.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Documents are not fixed, they are changing on daily basis. We are giving this as a context, then \nexpense will be tokens,  tokens will be spent. LLM charges us on the basis of tokens. In this document\nthere will be multiple things that are of no use for this current question, lets say we are asking\nabout what is the revenue, so giving whole document means lot of token, expense more, instead of that\nwe will pass only data as context that has info about the revenue, then our token will be saved.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "NpUKDFtYGZa7JymlFtmub",
      "type": "text",
      "x": 1273.0411740014686,
      "y": 79660.20734796129,
      "width": 649,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bzA",
      "roundness": null,
      "seed": 2135078301,
      "version": 64,
      "versionNonce": 1598377373,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777703767278,
      "link": null,
      "locked": false,
      "text": "How we can fetch releavant information from the document ->",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How we can fetch releavant information from the document ->",
