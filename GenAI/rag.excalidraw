      "isDeleted": false,
      "boundElements": null,
      "updated": 1777702869968,
      "link": null,
      "locked": false,
      "text": "How we can improve this?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How we can improve this?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-ngaOOyQo686NshuO4yPZ",
      "type": "text",
      "x": 1326.6349240014686,
      "y": 78508.38312921129,
      "width": 1012,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "byr",
      "roundness": null,
      "seed": 882828733,
      "version": 139,
      "versionNonce": 991431699,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777702916423,
      "link": null,
      "locked": false,
      "text": "We will give whole whatsapp chat of my girlfriend to the context. now it has much idea about\nour girlfriend.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We will give whole whatsapp chat of my girlfriend to the context. now it has much idea about\nour girlfriend.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ltf4SlsSxohQLQUBylOjW",
      "type": "text",
      "x": 1297.9200802514686,
      "y": 78610.02766046129,
      "width": 1045,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "byt",
      "roundness": null,
      "seed": 1527548179,
      "version": 245,
      "versionNonce": 1565832957,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777703065180,
      "link": null,
      "locked": false,
      "text": "We can do some more things like instead of giving our chat as context , we will train this LLM\nmodel on top of this whatsapp data this is called fine tuning so that we dont need to give this\ncontext everytime.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We can do some more things like instead of giving our chat as context , we will train this LLM\nmodel on top of this whatsapp data this is called fine tuning so that we dont need to give this\ncontext everytime.",
      "autoResize": true,
      "lineHeight": 1.25
    },
