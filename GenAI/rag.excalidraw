    {
      "id": "QTfJjLIQMp0eBI4o6mvn_",
      "type": "text",
      "x": 1302.6036740014686,
      "y": 78030.62141046129,
      "width": 1067,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "byp",
      "roundness": null,
      "seed": 1086217011,
      "version": 891,
      "versionNonce": 750500445,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777702842870,
      "link": null,
      "locked": false,
      "text": "we can give context to our LLM, like you need to behave my girlfriend, and you need to give\nanswers accordingly\n\nQ How are you? -> I am fine\nQ Apko khane me kya pasand h -> It can't tell exactly but still it will answer she like Poha.\n        it is not able to answer correctly since we haven't passed this detail in our context\nQ Apko khan ghumna pasand h ? -> it will say Delhi\n\nthis is called Hallusination like if they dont know about something, still they will answer\neither it will be right or wrong. Due to LLM models are trained in way that they need to answer\nthey can't say I dont know.\n\nExample -> in our exam, we dont know about question but still we write answer so that he can give\n    some mark this is hallusination.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "we can give context to our LLM, like you need to behave my girlfriend, and you need to give\nanswers accordingly\n\nQ How are you? -> I am fine\nQ Apko khane me kya pasand h -> It can't tell exactly but still it will answer she like Poha.\n        it is not able to answer correctly since we haven't passed this detail in our context\nQ Apko khan ghumna pasand h ? -> it will say Delhi\n\nthis is called Hallusination like if they dont know about something, still they will answer\neither it will be right or wrong. Due to LLM models are trained in way that they need to answer\nthey can't say I dont know.\n\nExample -> in our exam, we dont know about question but still we write answer so that he can give\n    some mark this is hallusination.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "FyrQOIFTdRZXikTaJ1ZIi",
      "type": "text",
      "x": 1295.5333615014686,
      "y": 78480.92219171129,
      "width": 264,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
