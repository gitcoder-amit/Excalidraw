      "isDeleted": false,
      "boundElements": [],
      "updated": 1777282310681,
      "link": null,
      "locked": false,
      "text": "when we purchase subscription of Claude or Gemini or ChatGPT, at that time it is giving access of \nLLM as well as tools.\n\nif we are purchasing API key of model in that time it will give only LLM.\ndue to that subscriptions are costly in comparison to API keys. Because writing the tools itself is\na big task.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "when we purchase subscription of Claude or Gemini or ChatGPT, at that time it is giving access of \nLLM as well as tools.\n\nif we are purchasing API key of model in that time it will give only LLM.\ndue to that subscriptions are costly in comparison to API keys. Because writing the tools itself is\na big task.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "aO3Wb9wosqYNBK4rcpZWT",
      "type": "text",
      "x": 1392.4533132634704,
      "y": 71027.72093735481,
      "width": 1056,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
