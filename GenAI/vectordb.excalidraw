    {
      "id": "XXyUXNy0QFnZ9BP1RJBa_",
      "type": "text",
      "x": 1444.4657588690206,
      "y": 71551.12538149438,
      "width": 968,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bsB",
      "roundness": null,
      "seed": 34694570,
      "version": 145,
      "versionNonce": 888106090,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777294882423,
      "link": null,
      "locked": false,
      "text": "If someone will purchase BCAA , we will go to BCAA row and sort that in Descending order\nand we will recommend start 3 4 products.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If someone will purchase BCAA , we will go to BCAA row and sort that in Descending order\nand we will recommend start 3 4 products.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GkCQS8FpY8D09yXAxF_X7",
      "type": "text",
      "x": 1445.1412214990992,
      "y": 71746.09747885824,
      "width": 1133,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bsC",
      "roundness": null,
      "seed": 956042410,
      "version": 599,
      "versionNonce": 1638109930,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777295314556,
      "link": null,
      "locked": false,
      "text": "1 Size of matrix N*N if any new product comes then we need to add one more column and row \n    that is not scalable. but first problem is sovled that is beer and Diper problem.\n\n2 Selecting the array and then sort. it will be time consuming.\n\n3 Initially recommendation system will not work as weight of every edge is 0, Cold start problem\n4 It only captures co-occurance, not content(On whey vs my protein brand, whey is famous and my protein\nis just added so it will not give recommendation for my protein)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1 Size of matrix N*N if any new product comes then we need to add one more column and row \n    that is not scalable. but first problem is sovled that is beer and Diper problem.\n\n2 Selecting the array and then sort. it will be time consuming.\n\n3 Initially recommendation system will not work as weight of every edge is 0, Cold start problem\n4 It only captures co-occurance, not content(On whey vs my protein brand, whey is famous and my protein\nis just added so it will not give recommendation for my protein)",
      "autoResize": true,
      "lineHeight": 1.25
    },
