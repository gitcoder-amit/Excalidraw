    {
      "id": "LVTuDPhWPOs3aflyh0JFt",
      "type": "text",
      "x": 1343.0562194219199,
      "y": 75849.11245650948,
      "width": 825,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "btE",
      "roundness": null,
      "seed": 1862287182,
      "version": 4,
      "versionNonce": 1953599822,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777689465250,
      "link": null,
      "locked": false,
      "text": "SQL and NoSQL databases are designed to find exact matches based on known \nvalues, while vector databases are designed to find similar items based on \nconceptual meaning.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SQL and NoSQL databases are designed to find exact matches based on known \nvalues, while vector databases are designed to find similar items based on \nconceptual meaning.",
      "autoResize": true,
      "lineHeight": 1.25
    },
