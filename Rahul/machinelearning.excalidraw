    },
    {
      "id": "4aBzS0L0IufqinVZM0pkO",
      "type": "text",
      "x": 917.6282537163404,
      "y": 47578.60849104651,
      "width": 1199,
      "height": 225,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#eaddd7",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZt",
      "roundness": null,
      "seed": 1042793433,
      "version": 835,
      "versionNonce": 2055322736,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777309307012,
      "link": null,
      "locked": false,
      "text": "New image will be passed from all filters, all layers of filter, then all this will produce\nour final single or pare of results. In this way when we have multiple layer of filtering, then this part is \ncalled as Deep Learning.\nWhat we are doing in Deep learning is that, at every layer, we are applying ML like filter or algorithm,\nSo deep learning is nothing but stacking of multiple ML algorithms. So Deep learning is subset of Machine \nleaning. and the network that made in Deep learning is known as Neural network.\n\nFor any particular data  point, we will have multiple of those data points to make sure our model understands\nthe characterstics of data point nicely",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "New image will be passed from all filters, all layers of filter, then all this will produce\nour final single or pare of results. In this way when we have multiple layer of filtering, then this part is \ncalled as Deep Learning.\nWhat we are doing in Deep learning is that, at every layer, we are applying ML like filter or algorithm,\nSo deep learning is nothing but stacking of multiple ML algorithms. So Deep learning is subset of Machine \nleaning. and the network that made in Deep learning is known as Neural network.\n\nFor any particular data  point, we will have multiple of those data points to make sure our model understands\nthe characterstics of data point nicely",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "tpN9PIDNcmqeko9GzxrUI",
