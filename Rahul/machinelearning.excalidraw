    },
    {
      "id": "CAveko4-TAHykT2FFiihl",
      "type": "text",
      "x": 920.8090942668963,
      "y": 50328.486484988905,
      "width": 1122,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "baF",
      "roundness": null,
      "seed": 1406683549,
      "version": 872,
      "versionNonce": 663559443,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777835462612,
      "link": null,
      "locked": false,
      "text": "Here we are talking about inside model, there can be two type of functions, One F(x) understand the\nwhole pattern for example face of Rahul, It will try to understand whole face of Rahul that what is\nthe pattern, so that from next time onwards it can detect it. So it will memorize the face of Rahul.\nOr it will memorize how human face look like and it will detect the human face., that is memorization.\nGeneralize is more used when we categorize our data, Category into Product A or Product B. One thing\nis whether it is Rahul or not. and the categorize into cluster. so this is generalize like where our\ndata belong to.\n1 Instance Based -> Memorization\n2 Model Based -> Generalization",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Here we are talking about inside model, there can be two type of functions, One F(x) understand the\nwhole pattern for example face of Rahul, It will try to understand whole face of Rahul that what is\nthe pattern, so that from next time onwards it can detect it. So it will memorize the face of Rahul.\nOr it will memorize how human face look like and it will detect the human face., that is memorization.\nGeneralize is more used when we categorize our data, Category into Product A or Product B. One thing\nis whether it is Rahul or not. and the categorize into cluster. so this is generalize like where our\ndata belong to.\n1 Instance Based -> Memorization\n2 Model Based -> Generalization",
      "autoResize": true,
      "lineHeight": 1.25
    },
