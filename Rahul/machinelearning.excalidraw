    {
      "id": "4aBzS0L0IufqinVZM0pkO",
      "type": "text",
      "x": 917.6282537163404,
      "y": 47578.60849104651,
      "width": 1199,
      "height": 200,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#eaddd7",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZt",
      "roundness": null,
      "seed": 1042793433,
      "version": 587,
      "versionNonce": 1246308407,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777229300402,
      "link": null,
      "locked": false,
      "text": "New image will be passed from all filters, all layers of filter, then all this will produce\nour final single or pare of results. In this way when we have multiple layer of filtering, then this part is \ncalled as Deep Learning.\nWhat we are doing in Deep learning is that, at every layer, we are applying ML like filter or algorithm,\nSo deep learning is nothing but stacking of multiple ML algorithms. So Deep learning is subset of Machine \nleaning.\n\n25:00",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "New image will be passed from all filters, all layers of filter, then all this will produce\nour final single or pare of results. In this way when we have multiple layer of filtering, then this part is \ncalled as Deep Learning.\nWhat we are doing in Deep learning is that, at every layer, we are applying ML like filter or algorithm,\nSo deep learning is nothing but stacking of multiple ML algorithms. So Deep learning is subset of Machine \nleaning.\n\n25:00",
      "autoResize": true,
      "lineHeight": 1.25
    },
