    {
      "id": "94-0vX-J70yaAbuVIPEum",
      "type": "text",
      "x": 950.0041795498939,
      "y": 49464.05359140687,
      "width": 792,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
