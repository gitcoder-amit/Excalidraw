      "isDeleted": false,
      "boundElements": [],
      "updated": 1777568967069,
      "link": null,
      "locked": false,
      "text": "lets say we have to train a machine learning model, I will give all the inputs that we have,\nI will read the training data, testing data, I will make the entire perfect model in one go.\nAnd once I have the perfect model, I deploy it to production or any sytem and will start using\nit, that is called as a offline model.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "lets say we have to train a machine learning model, I will give all the inputs that we have,\nI will read the training data, testing data, I will make the entire perfect model in one go.\nAnd once I have the perfect model, I deploy it to production or any sytem and will start using\nit, that is called as a offline model.",
      "autoResize": true,
      "lineHeight": 1.25
    },
