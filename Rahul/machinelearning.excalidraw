    {
      "id": "xlGtavD_Psun7YhEbSKvd",
      "type": "text",
      "x": 1149.9435110692812,
      "y": 43912.17987585025,
      "width": 1067,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bY8",
      "roundness": null,
      "seed": 1146743152,
      "version": 787,
      "versionNonce": 1484049776,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777054350160,
      "link": null,
      "locked": false,
      "text": "AI is trying to mimic human behaviour, like we see, we do tasks, we speak, we  think, we run a \ncode , we test code, we delete code, we push the code into git.\nIf somehow we are able to give this feature to a machine, if we are able to make machine in such \na way that it is able to think or reason that is one thing, If it is able to see or speak which\ncomes under Natural language processing or image processing these kind of things, we distinguise\nbetween cat and dog, when we see and distinguise between cat and dog, that is again a feature of\nhuman interlligence, when we give it to a machine that is called as Artificial Intelligence.\n\nRun code\ngit push\ntest code\ndelete code\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AI is trying to mimic human behaviour, like we see, we do tasks, we speak, we  think, we run a \ncode , we test code, we delete code, we push the code into git.\nIf somehow we are able to give this feature to a machine, if we are able to make machine in such \na way that it is able to think or reason that is one thing, If it is able to see or speak which\ncomes under Natural language processing or image processing these kind of things, we distinguise\nbetween cat and dog, when we see and distinguise between cat and dog, that is again a feature of\nhuman interlligence, when we give it to a machine that is called as Artificial Intelligence.\n\nRun code\ngit push\ntest code\ndelete code\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
