      "text": "from google import genai\n\nclient = genai.Client(api_key=\"AIzaSyCiaVzwz9Kg_LHDl9JuhRE5MKOFtMDlnis\")\nchat = client.chats.create(model=\"gemini-2.5-flash-lite\")\n\nresponse = chat.send_message(\"I have 2 dogs in my house.\")\nprint(response.text)\n\nresponse = chat.send_message(\"How many paws are in my house?\")\nprint(response.text)\n\nfor message in chat.get_history():\n    print(f'role - {message.role}',end=\": \")\n    print(message.parts[0].text)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "from google import genai\n\nclient = genai.Client(api_key=\"AIzaSyCiaVzwz9Kg_LHDl9JuhRE5MKOFtMDlnis\")\nchat = client.chats.create(model=\"gemini-2.5-flash-lite\")\n\nresponse = chat.send_message(\"I have 2 dogs in my house.\")\nprint(response.text)\n\nresponse = chat.send_message(\"How many paws are in my house?\")\nprint(response.text)\n\nfor message in chat.get_history():\n    print(f'role - {message.role}',end=\": \")\n    print(message.parts[0].text)",
      "autoResize": true,
      "lineHeight": 1.25
    },
