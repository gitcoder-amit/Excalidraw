    },
    {
      "id": "Xn7nuYs2t99ivJ56K9NIp",
      "type": "text",
      "x": 911.8452201649528,
      "y": 47871.906997040445,
      "width": 1199,
      "height": 275,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZw",
      "roundness": null,
      "seed": 2091175056,
      "version": 929,
      "versionNonce": 130680976,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777315109217,
      "link": null,
      "locked": false,
      "text": "Deep Learning when initially was introduced, majorly was dealing with images, To classify images or something\nlike this because for regular text data regular Machine learning was more than enough, Deep learning\nmostly was used either in audio files or image files something like this.\n\n\nDevelopment happpened in mathematics not in computer science, earlier we were storing data in \ntabular format, but for data like [1, 2, 3] we have stored data in 3D format, but as the data\ngrows we need nd vector(N d transformers) format as well. When we have n D transformer and we \nhave to move across them mathematician give us logic that help us to move, and when we have\nsomething that can help us to navigate, what can be next, whats built on top of it is something\ncalled as LLM.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Deep Learning when initially was introduced, majorly was dealing with images, To classify images or something\nlike this because for regular text data regular Machine learning was more than enough, Deep learning\nmostly was used either in audio files or image files something like this.\n\n\nDevelopment happpened in mathematics not in computer science, earlier we were storing data in \ntabular format, but for data like [1, 2, 3] we have stored data in 3D format, but as the data\ngrows we need nd vector(N d transformers) format as well. When we have n D transformer and we \nhave to move across them mathematician give us logic that help us to move, and when we have\nsomething that can help us to navigate, what can be next, whats built on top of it is something\ncalled as LLM.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "y5xIgY4nlJetrfWedYqOV",
