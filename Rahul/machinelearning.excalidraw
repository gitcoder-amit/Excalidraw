      "seed": 1987130256,
      "version": 481,
      "versionNonce": 1296668528,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777056509182,
      "link": null,
      "locked": false,
      "text": "Machine Learning is entirely nothing but we are trying to write a mathematical function, Always\nit is going to be a mathematical function, that mathematical function will either try to classify\nor predict something. it is trying to predict or classify based on our input what is going to\nbe the output.\nwe write some mathematical function, function take the input, it predict something for us that is\nML.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Machine Learning is entirely nothing but we are trying to write a mathematical function, Always\nit is going to be a mathematical function, that mathematical function will either try to classify\nor predict something. it is trying to predict or classify based on our input what is going to\nbe the output.\nwe write some mathematical function, function take the input, it predict something for us that is\nML.",
      "autoResize": true,
      "lineHeight": 1.25
    },
