    {
      "id": "gJiACf9EXbwBD8QR_TgIY",
      "type": "text",
      "x": 926.158814378105,
      "y": 54818.14778332592,
      "width": 1188,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bco",
      "roundness": null,
      "seed": 1451480627,
      "version": 503,
      "versionNonce": 1565448829,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777866012830,
      "link": null,
      "locked": false,
      "text": "Model 2, due to it is classifying my data better. obviously there are some make in female region and some\nfemale in male region, these are outliers, but still we have clear distinguise line between two of them.\nso this is something that we get via EDA. Not before that. In EDA if we are able to able to understand these\npatterns or lines, thats it life is simple after that.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Model 2, due to it is classifying my data better. obviously there are some make in female region and some\nfemale in male region, these are outliers, but still we have clear distinguise line between two of them.\nso this is something that we get via EDA. Not before that. In EDA if we are able to able to understand these\npatterns or lines, thats it life is simple after that.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "eBSkxTKzw-sK0urR2lZJH",
      "type": "text",
      "x": 826.029908128105,
      "y": 55012.44856457592,
      "width": 11,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bcp",
