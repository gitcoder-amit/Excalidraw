      "originalText": "Classification models are more like whether it is a cat image or dog image. that is classification \nmodel.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "htQtiCIt3ckGgNYvqg6XC",
      "type": "text",
      "x": 804.537720628105,
      "y": 53091.46809582592,
      "width": 264,
      "height": 25,
      "angle": 0,
