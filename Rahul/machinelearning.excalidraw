      "seed": 756340339,
      "version": 460,
      "versionNonce": 1068299859,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777862596814,
      "link": null,
      "locked": false,
      "text": "In google photos we tell about, one or two or few photos that okay Rahul looks like this, then it\nwill take a lot of Rahul photos and classify that it is Rahul, Some of them it will ask whether it\nis Rahul or not then if varied kind of input if we agree that yes this is Rahul or this is not me,\nthen based on that we have more labels over here, once it has labels all sorted",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In google photos we tell about, one or two or few photos that okay Rahul looks like this, then it\nwill take a lot of Rahul photos and classify that it is Rahul, Some of them it will ask whether it\nis Rahul or not then if varied kind of input if we agree that yes this is Rahul or this is not me,\nthen based on that we have more labels over here, once it has labels all sorted",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "0y3Lu-qtOqnYpmg1WMwqp",
