      "isDeleted": true,
      "boundElements": [],
      "updated": 1777053178243,
      "link": null,
      "locked": false,
      "text": "How Chatgpt is giving this answer -> \n  ChatGPT will take input HI How are you and try to predict next word, like I\n  now Hi How are you, I will be passed as input, then it will predict next like am\n  now Hi How are you, I am will be passed as input next it will predict Now Hi How are you, I am fine\nnow It will give only I am fine. So it basically works on what will be next word.\n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How Chatgpt is giving this answer -> \n  ChatGPT will take input HI How are you and try to predict next word, like I\n  now Hi How are you, I will be passed as input, then it will predict next like am\n  now Hi How are you, I am will be passed as input next it will predict Now Hi How are you, I am fine\nnow It will give only I am fine. So it basically works on what will be next word.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
