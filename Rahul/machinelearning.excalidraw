      "seed": 2065175613,
      "version": 16,
      "versionNonce": 1945034813,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777570540909,
      "link": null,
      "locked": false,
      "text": "What we are trying to say is how we are going to deploy our model like is it going to be\nwhole model in one go or our model will be semi model right now and over the period of time\nwe are going to make it better, more accurate, so that is one way.\nSo in the first way, it is more like we have a perfect model or whatever our need is or\nwhatever our usecase is based on that usecase we design one model and we are going to use it\nfor its entire lifetime, so that is one way which is also called as offline model or batch\nmodel.\n\nAnother one that we have here is online model",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What we are trying to say is how we are going to deploy our model like is it going to be\nwhole model in one go or our model will be semi model right now and over the period of time\nwe are going to make it better, more accurate, so that is one way.\nSo in the first way, it is more like we have a perfect model or whatever our need is or\nwhatever our usecase is based on that usecase we design one model and we are going to use it\nfor its entire lifetime, so that is one way which is also called as offline model or batch\nmodel.\n\nAnother one that we have here is online model",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dm6mwaaUZNi-MWJJaY4h1",
      "type": "text",
      "x": 876.9770630168963,
      "y": 50289.006016238905,
      "width": 187,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
