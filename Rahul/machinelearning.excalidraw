    {
      "id": "qIZ6Sj94OBmKTMwmWzi2q",
      "type": "text",
      "x": 1323.9778247947704,
      "y": 45797.489312124475,
      "width": 286,
      "height": 425,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#eaddd7",
      "fillStyle": "solid",
      "strokeWidth": 1,
