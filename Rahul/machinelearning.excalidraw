    {
      "id": "CI1WBr_Y03Ac7j5U_VdDW",
      "type": "text",
      "x": 1198.3159069026146,
      "y": 44542.418846438326,
      "width": 990,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bYF",
      "roundness": null,
      "seed": 159601040,
      "version": 759,
      "versionNonce": 587870096,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777055250354,
      "link": null,
      "locked": false,
      "text": "TO be honest ML can do two things only, It will take data from us then it will either do\n1 Classify or\n2 Predict\n    these two things only ML can do.\n\nPredict whihc share will go up and which will go down in the share market\nClassify who are rich,who are poor, who is gone to buy the product, who is going to not \nbuy the product these are the basic use cases.\n\nwe can think that how much change ML can bring in the world, if we have this kind of data,\nthat is why ML holds power.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TO be honest ML can do two things only, It will take data from us then it will either do\n1 Classify or\n2 Predict\n    these two things only ML can do.\n\nPredict whihc share will go up and which will go down in the share market\nClassify who are rich,who are poor, who is gone to buy the product, who is going to not \nbuy the product these are the basic use cases.\n\nwe can think that how much change ML can bring in the world, if we have this kind of data,\nthat is why ML holds power.",
      "autoResize": true,
      "lineHeight": 1.25
    },
