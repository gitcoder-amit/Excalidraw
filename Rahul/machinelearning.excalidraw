    {
      "id": "Rv2A5_Yhesloms82x_Rm_",
      "type": "text",
      "x": 995.416626878105,
      "y": 51642.97981457592,
      "width": 1166,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bah",
      "roundness": null,
      "seed": 1159427123,
      "version": 854,
      "versionNonce": 278736979,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777862381765,
      "link": null,
      "locked": false,
      "text": "We have some data, table is there, output is there, but output only exists for some datapoints. not\nfor rest of the datapoint. so in this case when we have output for some datapoints and for rest of them\nour model tries to generate the output. and most of the time we have a feedback loop when we are using\nsemisupervised model. Atleat initially it is needed, lateron we can reduce the feedback loop. Why feedback\nloop is needed, due to it is genrating output based on some outputs, so it has to make sure output is\ncorrect or not. It will be constantly asking us, it is correct or not. later on when we have more data\npoint then we can remove this. we can change it to a different algorithm or something like this.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We have some data, table is there, output is there, but output only exists for some datapoints. not\nfor rest of the datapoint. so in this case when we have output for some datapoints and for rest of them\nour model tries to generate the output. and most of the time we have a feedback loop when we are using\nsemisupervised model. Atleat initially it is needed, lateron we can reduce the feedback loop. Why feedback\nloop is needed, due to it is genrating output based on some outputs, so it has to make sure output is\ncorrect or not. It will be constantly asking us, it is correct or not. later on when we have more data\npoint then we can remove this. we can change it to a different algorithm or something like this.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "H9JqCGpVbxtXQm9GVjnqX",
