    {
      "id": "eM26ahuJeadJcE1uYKBZe",
      "type": "text",
      "x": 1368.9954412163404,
      "y": 43659.09286604651,
      "width": 143,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
