    },
    {
      "id": "JNl2nwEJlKJRR5yx2hhsx",
      "type": "text",
      "x": 829.545533128105,
      "y": 55018.24543957592,
      "width": 1155,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bcq",
      "roundness": null,
      "seed": 1691262355,
      "version": 193,
      "versionNonce": 81597469,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777866107332,
      "link": null,
      "locked": false,
      "text": "We have dimentionality reduction, that is one thing, the second thing that unsupervised learning can give\nus and which is very important is clustering.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We have dimentionality reduction, that is one thing, the second thing that unsupervised learning can give\nus and which is very important is clustering.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ykO-bIzF2zGV_5J5Kc9Uk",
      "type": "text",
      "x": 834.822876878105,
      "y": 55092.40559582592,
      "width": 154,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bcr",
      "roundness": null,
      "seed": 858943709,
      "version": 19,
      "versionNonce": 691652605,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777866126230,
      "link": null,
      "locked": false,
      "text": "Clustering -> ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Clustering -> ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "SoEv70QzDFiOq0aayzi4R",
      "type": "text",
      "x": 875.420533128105,
      "y": 55118.86262707592,
      "width": 1045,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bcs",
      "roundness": null,
      "seed": 161923059,
      "version": 513,
      "versionNonce": 555268602,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777866785509,
      "link": null,
      "locked": false,
      "text": "Means it will devide our data into clusters. whethere this belong to cluster 1 or cluster 2.\nDeviding the whole data into clusters. So that lets say when x values is increasing, sometimes\ny is decreasing othertime y is increasing, so when y is increasing lets say x < 50, when x > 50\ny is decreasing. so it will cluster on the basis of that and then we get pattern between x and\ny. that pattern is something that we need.\n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Means it will devide our data into clusters. whethere this belong to cluster 1 or cluster 2.\nDeviding the whole data into clusters. So that lets say when x values is increasing, sometimes\ny is decreasing othertime y is increasing, so when y is increasing lets say x < 50, when x > 50\ny is decreasing. so it will cluster on the basis of that and then we get pattern between x and\ny. that pattern is something that we need.\n\n",
