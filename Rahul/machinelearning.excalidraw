    {
      "id": "xlGtavD_Psun7YhEbSKvd",
      "type": "text",
      "x": 1149.9435110692812,
      "y": 43912.17987585025,
      "width": 1067,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
