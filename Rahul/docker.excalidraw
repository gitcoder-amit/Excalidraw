    {
      "id": "a35o7erBR3NZcj6pXb9VY",
      "type": "text",
      "x": 1739.670967671342,
      "y": 76556.81740205291,
      "width": 572,
      "height": 275,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
