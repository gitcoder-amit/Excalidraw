    {
      "id": "shTl9v1LcATISlPhERaZW",
      "type": "text",
      "x": 1463.889717671342,
      "y": 74800.67287080291,
      "width": 880,
      "height": 200,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkl",
      "roundness": null,
      "seed": 1269131381,
      "version": 417,
      "versionNonce": 54905659,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773925885077,
      "link": null,
      "locked": false,
      "text": "This VM/Container running a specific server lets say webserver.\nwebserver usually runs on port 80(http) https(443), lets say it is running\non port 80 of container not Base system.\n\n\nlets say base also itself running a server on port 80\n\nNow if request comes on port 80, obviously it will go to base system web server.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This VM/Container running a specific server lets say webserver.\nwebserver usually runs on port 80(http) https(443), lets say it is running\non port 80 of container not Base system.\n\n\nlets say base also itself running a server on port 80\n\nNow if request comes on port 80, obviously it will go to base system web server.",
      "autoResize": true,
      "lineHeight": 1.25
    },
