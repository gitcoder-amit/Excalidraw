      "versionNonce": 1082032981,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773928456935,
      "link": null,
      "locked": false,
      "text": "Suppose we want to share App S/W, these S/W are \nthere in HDD lets say in /rahul folder, so will\nmount this in our container, now we have link\nto access this S/W, but this mount point we can\nshare this to other containers also.\nMOunting means we are not copying, I am sharing from\nmy base within these container. So container\nwould not be heavy, images would not be heavy\ndeployment will be fast at the same time just one\ncan be share with all of containers. this is called\nVolume mounting.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Suppose we want to share App S/W, these S/W are \nthere in HDD lets say in /rahul folder, so will\nmount this in our container, now we have link\nto access this S/W, but this mount point we can\nshare this to other containers also.\nMOunting means we are not copying, I am sharing from\nmy base within these container. So container\nwould not be heavy, images would not be heavy\ndeployment will be fast at the same time just one\ncan be share with all of containers. this is called\nVolume mounting.",
      "autoResize": true,
      "lineHeight": 1.25
    },
