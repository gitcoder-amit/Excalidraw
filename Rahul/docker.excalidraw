      "originalText": "docker save -o amit.tar my-apache-image/id\ndocker load -i amit.tar\ndocker commit <container_id> my-apache-image\ndocker export <container_id> -o container.tar\ndocker import container.tar my-imported-image",
      "autoResize": true,
      "lineHeight": 1.25
