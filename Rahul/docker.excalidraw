    },
    {
      "id": "7bAtB7J5g2d9O525wHJPf",
      "type": "text",
      "x": 1483.3076864213417,
      "y": 83728.11427705291,
      "width": 429,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bm6",
      "roundness": null,
      "seed": 1979797805,
      "version": 91,
