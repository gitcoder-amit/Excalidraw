    {
      "id": "gAmyC-vlRiuAb0t218Ytx",
      "type": "text",
      "x": 1242.9287801713417,
      "y": 80623.39943330291,
      "width": 1111,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
