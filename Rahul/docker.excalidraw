      "seed": 1270613795,
      "version": 609,
      "versionNonce": 1999097315,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774017114295,
      "link": null,
      "locked": false,
      "text": "Till now we were doing all things with Docker commands.\nNow came a new way we will write all these commands inside a file, and we will call that file\nas dockerfile. This is also being run by CLI, commands are also being run by CLI. And if it is\ndone in CLI, We can write Python Script or Shell Script or any kind of script.\nWhy do we need to learn, understand and write a different kind of file for it, rather than doing\nbasic scripting.",
      "fontSize": 19.9,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Till now we were doing all things with Docker commands.\nNow came a new way we will write all these commands inside a file, and we will call that file\nas dockerfile. This is also being run by CLI, commands are also being run by CLI. And if it is\ndone in CLI, We can write Python Script or Shell Script or any kind of script.\nWhy do we need to learn, understand and write a different kind of file for it, rather than doing\nbasic scripting.",
      "autoResize": true,
      "lineHeight": 1.25
    },
