    {
      "id": "vYOSrmhnfrBAFnrqDiOyn",
      "type": "text",
      "x": 1153.344795796342,
      "y": 42435.80177705291,
      "width": 1034,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
