      "boundElements": [],
      "updated": 1772380849476,
      "link": null,
      "locked": false,
      "text": "Q IF we have created two LVMs and assigned to 2 diff users, then one user come and want more space\nthen how we will handle becuase if we will extend our LVM them if will shift whole next block?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Q IF we have created two LVMs and assigned to 2 diff users, then one user come and want more space\nthen how we will handle becuase if we will extend our LVM them if will shift whole next block?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "SopNHbycIrmzFmSmgsGs5",
      "type": "text",
      "x": 1061.237373921342,
      "y": 35544.23341767791,
      "width": 1045,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVS",
