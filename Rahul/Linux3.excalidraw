      "isDeleted": false,
      "boundElements": [],
      "updated": 1772380849476,
      "link": null,
      "locked": false,
      "text": "No, Due to our HDD is not like Array, it is like Linked List, so we no need to shift the blocks",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "No, Due to our HDD is not like Array, it is like Linked List, so we no need to shift the blocks",
      "autoResize": true,
      "lineHeight": 1.25
