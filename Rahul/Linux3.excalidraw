    {
      "id": "WBQ-gfBwdkOCPHHnwS3Jw",
      "type": "text",
      "x": 1105.870186421342,
      "y": 37372.42091767791,
      "width": 1023,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bWZ",
      "roundness": null,
      "seed": 2072925381,
      "version": 822,
      "versionNonce": 1470046917,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772383176240,
      "link": null,
      "locked": false,
      "text": "Source Address would be mostly our Private IP because we are hitting outside the system, \nwe are not interacting within the system, within in the system it will be 127.0.0.1 both\nsource and destination.\nbut for outside system our source address would be private IP if we have that otherwise\npublic IP. whatever IP is assigned to our system by DHCP.\n\nAt the destination address also, it is suppose to be IP, packet structure is like that it is\nexpecting a IP address. What we have here is google.com which is called our domain name\nwe don't have Ip address, So for that domain name to be converted to a IP address, it happens\nvia a process called as DNS resolution.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Source Address would be mostly our Private IP because we are hitting outside the system, \nwe are not interacting within the system, within in the system it will be 127.0.0.1 both\nsource and destination.\nbut for outside system our source address would be private IP if we have that otherwise\npublic IP. whatever IP is assigned to our system by DHCP.\n\nAt the destination address also, it is suppose to be IP, packet structure is like that it is\nexpecting a IP address. What we have here is google.com which is called our domain name\nwe don't have Ip address, So for that domain name to be converted to a IP address, it happens\nvia a process called as DNS resolution.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mzEvu-Vdt7pncgkcrUNlY",
