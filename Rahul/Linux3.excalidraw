    {
      "id": "fJ7Ok_FvxvKx5aoXoqI68",
      "type": "text",
      "x": 1211.889717671342,
      "y": 39610.58498017791,
      "width": 1089,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bXF",
      "roundness": null,
      "seed": 1855622187,
      "version": 707,
      "versionNonce": 110640229,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772386505059,
      "link": null,
      "locked": false,
      "text": "Now our DNS will go to corresponding ANS and ANS will give one of the IP of google.com, Now DNS\nhas the IP of google.com, Now DNS along the way will return IP to our router, Now our Router will\nnot immediately respond back to system, Router will first cache it, So that next time it can only\ngo through the Router only no need to hit DNS. Now it will pass to our client or system. Now system\nwill also not directly use it, Client will cache it first. SO the next time dont have to hit router\nalso and then start the process whihc looks like, here we talk about 1 and 2 step only",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Now our DNS will go to corresponding ANS and ANS will give one of the IP of google.com, Now DNS\nhas the IP of google.com, Now DNS along the way will return IP to our router, Now our Router will\nnot immediately respond back to system, Router will first cache it, So that next time it can only\ngo through the Router only no need to hit DNS. Now it will pass to our client or system. Now system\nwill also not directly use it, Client will cache it first. SO the next time dont have to hit router\nalso and then start the process whihc looks like, here we talk about 1 and 2 step only",
      "autoResize": true,
      "lineHeight": 1.25
    },
