      "updated": 1772033958451,
      "link": null,
      "locked": false,
      "text": "Week1 -> basics of syntax, like if else, loop\nweek2 -> do basic questions fact, fib, palindrome, LCM, GCD, Calculator, * patterns\nMove to DSA Array, Linked List, Tree, BST, Recursion, Backtracking, Graph",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Week1 -> basics of syntax, like if else, loop\nweek2 -> do basic questions fact, fib, palindrome, LCM, GCD, Calculator, * patterns\nMove to DSA Array, Linked List, Tree, BST, Recursion, Backtracking, Graph",
      "autoResize": true,
      "lineHeight": 1.25
    },
