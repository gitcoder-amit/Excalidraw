    {
      "id": "Lab0Py60eYvyKb7KCa0aV",
      "type": "text",
      "x": 1617.2227252914288,
      "y": 14793.944282134049,
      "width": 847,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
