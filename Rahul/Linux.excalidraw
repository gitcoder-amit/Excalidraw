    {
      "id": "zE7Z-34hLg3CqH-NGgVEw",
      "type": "text",
      "x": 1682.5975167740678,
      "y": 10423.754884885671,
      "width": 121,
      "height": 50,
      "angle": 0,
      "strokeColor": "#e03131",
