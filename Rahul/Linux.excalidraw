    {
      "id": "nFnN9qX7ldDUIkgWm_4yW",
      "type": "text",
      "x": 951.6553426713419,
      "y": 27456.799823927915,
      "width": 979,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
