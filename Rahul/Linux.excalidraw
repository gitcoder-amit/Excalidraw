    },
    {
      "id": "vzz4fjXcpPrzYzd2y88pa",
      "type": "text",
      "x": 1734.8037479756904,
      "y": 12163.45159421282,
      "width": 187,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bKp",
      "roundness": null,
      "seed": 1793865007,
      "version": 123,
      "versionNonce": 369117217,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770751859494,
      "link": null,
      "locked": false,
      "text": "Created Fedora OS",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Created Fedora OS",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5COIGR3fFfG32BAQEiLfE",
      "type": "text",
      "x": 992.2887200961618,
      "y": 12471.973653634574,
      "width": 1364,
      "height": 1125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bKr",
      "roundness": null,
      "seed": 232542145,
      "version": 2838,
      "versionNonce": 405023471,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770754741363,
      "link": null,
      "locked": false,
      "text": "There is a rule of Open source community, the rule is anything that we derive from open source, like Debian\nderive Debian OS using Kernel, we can't charge money for it, we suppose to keep it open and free, it means Debian and \nFedora OS free and Open source other companies can come and use it. but there is a minor loop hole over here, if we \nare charging at the very same time we suppose to crate a free version of it, if we have a free version then we can \ncharge for it. and the free version of RedHat OS is CentOS.\n\n\nIf RedHat has free version then why people will pay for it?\nPeople pay for licensing if anything goes wrong, due to that system goes down, we can connect with RedHat team for\nsupport and they will come and make it up immediately for that they are charging actually, they are not charging\nfor OS indirectly.\n\nWindows have their own kernel but most of the OS are built on top of solo kernel.\n\n\nthere are lot of versions availalble for Debian, Ubuntu due to people need their own customization,\nAndroid uses Linux OS.\n\n\nQ We already have Linux and it is very secure the why we need India specific OS?\nfirst of all security is a myth just like privacy and democracy, security is no where. we will be working on some\nthings where in we see that it will take less than 1 minute 30 sec to break Linux OS. to entet into it without \npassword\n\nWhy every country needs their own OS?\nlets sat in a time like war, our supports being cut off how are we going to manage. So every country needs their\nown OS, India need their own Google, Microsoft this should be taken by India.\n\n\nLInux is Open Source but everyone can't use due to its hard.=\n\nexe file -> format that windows run\ndmg file -> macos file\n\nEmulator -> software that will run Android application in our PC. or a playstation game on my PC. How are they doing?\nthey just write the software that can understand that particular extension or file that we can run over here\n\n\n\n\nInstall Oracle Virtual box version 22 then on top of it install latest Ubuntu make sure it is LTS(long term support) version\nwhihc is release in every 4 years.\n\n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "There is a rule of Open source community, the rule is anything that we derive from open source, like Debian\nderive Debian OS using Kernel, we can't charge money for it, we suppose to keep it open and free, it means Debian and \nFedora OS free and Open source other companies can come and use it. but there is a minor loop hole over here, if we \nare charging at the very same time we suppose to crate a free version of it, if we have a free version then we can \ncharge for it. and the free version of RedHat OS is CentOS.\n\n\nIf RedHat has free version then why people will pay for it?\nPeople pay for licensing if anything goes wrong, due to that system goes down, we can connect with RedHat team for\nsupport and they will come and make it up immediately for that they are charging actually, they are not charging\nfor OS indirectly.\n\nWindows have their own kernel but most of the OS are built on top of solo kernel.\n\n\nthere are lot of versions availalble for Debian, Ubuntu due to people need their own customization,\nAndroid uses Linux OS.\n\n\nQ We already have Linux and it is very secure the why we need India specific OS?\nfirst of all security is a myth just like privacy and democracy, security is no where. we will be working on some\nthings where in we see that it will take less than 1 minute 30 sec to break Linux OS. to entet into it without \npassword\n\nWhy every country needs their own OS?\nlets sat in a time like war, our supports being cut off how are we going to manage. So every country needs their\nown OS, India need their own Google, Microsoft this should be taken by India.\n\n\nLInux is Open Source but everyone can't use due to its hard.=\n\nexe file -> format that windows run\ndmg file -> macos file\n\nEmulator -> software that will run Android application in our PC. or a playstation game on my PC. How are they doing?\nthey just write the software that can understand that particular extension or file that we can run over here\n\n\n\n\nInstall Oracle Virtual box version 22 then on top of it install latest Ubuntu make sure it is LTS(long term support) version\nwhihc is release in every 4 years.\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
