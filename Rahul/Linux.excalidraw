      "seed": 1554243465,
      "version": 427,
      "versionNonce": 1568017993,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772042989304,
      "link": null,
      "locked": false,
      "text": "Become a root user\n\n\ndate -> today date in our system UTC format\nls -> lists what all there in current directory, current location.\npwd -> will give present working directory\nls -> nothing inside /root\n\nIn any system of the world, like Linux or MAC or Android or Windows, there are no folders\nor directories.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Become a root user\n\n\ndate -> today date in our system UTC format\nls -> lists what all there in current directory, current location.\npwd -> will give present working directory\nls -> nothing inside /root\n\nIn any system of the world, like Linux or MAC or Android or Windows, there are no folders\nor directories.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "blkh59NoLrruYXjLMiBHm",
      "type": "text",
      "x": 953.3115926713419,
      "y": 27758.424823927915,
