      "link": null,
      "locked": false,
      "text": "In Linux there is nothing or not just in linux, In system there is no such thing called as directory, But\nwhy we do see something like a directory ? when we see it in GUI then why we see different Icon ?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In Linux there is nothing or not just in linux, In system there is no such thing called as directory, But\nwhy we do see something like a directory ? when we see it in GUI then why we see different Icon ?",
      "autoResize": true,
      "lineHeight": 1.25
    },
