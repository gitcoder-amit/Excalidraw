      "isDeleted": false,
      "boundElements": [],
      "updated": 1772028035016,
      "link": null,
      "locked": false,
      "text": "How PL are made, what decisions are made, what choices are made, this subject is called\nas Principle of Programming Language. this is the root of compiler, a programming language\nand the root of all data structures.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
