    {
      "id": "88Qdn8bS8ydY_sXD1x8jv",
      "type": "text",
      "x": 1069.514717671342,
      "y": 26107.897480177915,
      "width": 913,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
