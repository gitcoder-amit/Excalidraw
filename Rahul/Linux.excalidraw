    {
      "id": "dbzkr-ew-KZC4fyLGJl85",
      "type": "text",
      "x": 1764.8916526974153,
      "y": 19445.32179267136,
      "width": 451,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
