    },
    {
      "id": "EeX22TisgnbNiXZEaPTo9",
      "type": "text",
      "x": 1328.8768842574393,
      "y": 20170.010147253113,
      "width": 935,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOA",
      "roundness": null,
      "seed": 763496135,
      "version": 802,
      "versionNonce": 1269605959,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771353354624,
      "link": null,
      "locked": false,
      "text": "If everything on a single machine -> there will be lot of issues like security risk\nfrontent deserves to be attacke we have not much taken care but due to that our DB\nand backend is compromised, hence putting everything in a single system is not a\ngood way\n\nSo we will try to separate them into 3 different machines VMs.\n\nWithout having the VM facility we have to buy 3 different hardwares for it And rather\nthan buyihng 3 different software, In a single software if we can create 3 isolated\nenvironment, it can give me same feel of 3 different hardwares but at the cost of \nhaving a single hardware. hence this is the use of our VMs.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If everything on a single machine -> there will be lot of issues like security risk\nfrontent deserves to be attacke we have not much taken care but due to that our DB\nand backend is compromised, hence putting everything in a single system is not a\ngood way\n\nSo we will try to separate them into 3 different machines VMs.\n\nWithout having the VM facility we have to buy 3 different hardwares for it And rather\nthan buyihng 3 different software, In a single software if we can create 3 isolated\nenvironment, it can give me same feel of 3 different hardwares but at the cost of \nhaving a single hardware. hence this is the use of our VMs.",
      "autoResize": true,
      "lineHeight": 1.25
    },
