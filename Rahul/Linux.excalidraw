    {
      "id": "shFahBLks86qpalVrRHR2",
      "type": "text",
      "x": 1866.3864526900643,
      "y": 16308.416131887341,
      "width": 737,
      "height": 425,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bMI",
      "roundness": null,
      "seed": 1830462062,
      "version": 833,
      "versionNonce": 1510636978,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771264832697,
      "link": null,
      "locked": false,
      "text": "4 GB from here processor will read, as the processor\\\nwill read this data, I will load next 4 GB of data which\nis required and keep on replacing back from RAM to HDD.\n\nthis 4 GB is also too much to be processed at a time, so \nwithin this 4GB also we have a small part called as cache memory.\n\nso load few kb of data processor first check into cache if not then\nin rem part of RAM if not in RAM it is going to be checked in HDD\n\nwhen we try to check in HDD what happens is in entire haradisk\nthere is again a small part of storage that kind of create a \nbuffer sort of storage. this buffer is part of HDD that has\nhight probability of being loaded to RAM. this part is called\nvirtualRAM\n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4 GB from here processor will read, as the processor\\\nwill read this data, I will load next 4 GB of data which\nis required and keep on replacing back from RAM to HDD.\n\nthis 4 GB is also too much to be processed at a time, so \nwithin this 4GB also we have a small part called as cache memory.\n\nso load few kb of data processor first check into cache if not then\nin rem part of RAM if not in RAM it is going to be checked in HDD\n\nwhen we try to check in HDD what happens is in entire haradisk\nthere is again a small part of storage that kind of create a \nbuffer sort of storage. this buffer is part of HDD that has\nhight probability of being loaded to RAM. this part is called\nvirtualRAM\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
