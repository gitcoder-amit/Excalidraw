    {
      "id": "6s6EwsWkRoOwRgq_8dcsy",
      "type": "text",
      "x": 942.0401347068848,
      "y": 18315.44415612802,
      "width": 477.3998107910156,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
