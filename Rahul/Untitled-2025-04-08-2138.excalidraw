      "versionNonce": 1896070334,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054918,
      "link": null,
      "locked": false,
      "text": "Q How will you troubleshoot(t/s) if you are not able to reach google.com? this type of question called OEQ \nOpen Ended Questions",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Q How will you troubleshoot(t/s) if you are not able to reach google.com? this type of question called OEQ \nOpen Ended Questions",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
