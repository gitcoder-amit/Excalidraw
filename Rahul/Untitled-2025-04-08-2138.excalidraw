    {
      "id": "iGLg3i28ixgj5HlzVDnCL",
      "type": "text",
      "x": 1538.1850246544911,
      "y": 42555.91934631584,
      "width": 836,
      "height": 300,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
