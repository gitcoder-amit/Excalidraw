    {
      "id": "01-YV_qF37pVZbIQJhlYf",
      "type": "text",
      "x": 1049.448311421342,
      "y": 53642.29982392791,
      "width": 1089,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bUk",
      "roundness": null,
      "seed": 1308180139,
      "version": 461,
      "versionNonce": 1353616482,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054919,
      "link": null,
      "locked": false,
      "text": "Above is complex analogy, In a simple Analogy, System connects to a router, Router becomes our\nDHCP server, Router gives us a IP address, Once we have the IP address, we can connect to rest\nof the world. \n\nDHCP assigns a IP to system that is dynamic in nature if we will trying to reconnect it may change.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Above is complex analogy, In a simple Analogy, System connects to a router, Router becomes our\nDHCP server, Router gives us a IP address, Once we have the IP address, we can connect to rest\nof the world. \n\nDHCP assigns a IP to system that is dynamic in nature if we will trying to reconnect it may change.",
      "autoResize": true,
      "lineHeight": 1.25
    },
