    {
      "id": "pcEc-95nxFy-y-M8Lgloe",
      "type": "text",
      "x": 881.9076809044911,
      "y": 39984.47403381584,
      "width": 990,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
