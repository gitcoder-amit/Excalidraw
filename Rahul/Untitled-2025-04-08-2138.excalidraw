    {
      "id": "B7xTA3XqruIKyOoKfmlfV",
      "type": "text",
      "x": 1003.4561239213419,
      "y": 46403.64748017791,
      "width": 286,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bSw",
      "roundness": null,
      "seed": 116485079,
      "version": 45,
      "versionNonce": 1792579170,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054918,
      "link": null,
      "locked": false,
      "text": "Create Partition P1 and P2",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Create Partition P1 and P2",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "lX_swSQmSRiYbfamtYt5p",
      "type": "text",
      "x": 1096.268623921342,
      "y": 46447.72560517791,
      "width": 1045,
      "height": 525,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bSx",
      "roundness": null,
      "seed": 1064264825,
      "version": 105,
      "versionNonce": 1030486206,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054918,
      "link": null,
      "locked": false,
      "text": "fdisk /dev/sda\nn -> new partition\np -> to create a primary partition , e for create a extended partition -> here we have chosen p\npartition  number just enter it will take defaul 1\nfirst sector -> just hit enter it will take default sector\nLast sector -> we can give either sector number or size for example if we want to create\n            100 MB partition then we can give +200m and hit enter\nnow partition is created of 200 MB size\n\nn -> new partition\np -> to create a primary partition , e for create a extended partition -> here we have chosen p\npartition  number just enter it will take defaul 2\nfirst sector -> just hit enter it will take default sector\nLast sector -> we can give either sector number or size for example if we want to create\n            100 MB partition then we can give +200m and hit enter\nnow partition is created of 200 MB size\n\npartprobe\n\n\nNow Partion /dev/sda1 and /dev/sda2 is created",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "fdisk /dev/sda\nn -> new partition\np -> to create a primary partition , e for create a extended partition -> here we have chosen p\npartition  number just enter it will take defaul 1\nfirst sector -> just hit enter it will take default sector\nLast sector -> we can give either sector number or size for example if we want to create\n            100 MB partition then we can give +200m and hit enter\nnow partition is created of 200 MB size\n\nn -> new partition\np -> to create a primary partition , e for create a extended partition -> here we have chosen p\npartition  number just enter it will take defaul 2\nfirst sector -> just hit enter it will take default sector\nLast sector -> we can give either sector number or size for example if we want to create\n            100 MB partition then we can give +200m and hit enter\nnow partition is created of 200 MB size\n\npartprobe\n\n\nNow Partion /dev/sda1 and /dev/sda2 is created",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "jQElg68pmjOI--dMy2Zmu",
      "type": "text",
      "x": 1011.5576864213419,
      "y": 47027.51076142791,
      "width": 374,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bSy",
      "roundness": null,
      "seed": 2051333177,
      "version": 51,
      "versionNonce": 435911202,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054918,
      "link": null,
      "locked": false,
      "text": "Convert P1 to PV1 and P2 to PV2 ->\n     ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Convert P1 to PV1 and P2 to PV2 ->\n     ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "RYMFo7WaBcum5XYzNZ7Y4",
      "type": "text",
      "x": 1098.284248921342,
      "y": 47087.44435517791,
      "width": 704,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bT0",
      "roundness": null,
      "seed": 261110775,
      "version": 196,
      "versionNonce": 824848638,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054918,
      "link": null,
      "locked": false,
      "text": "pvcreate /dev/sda1 -> this will create /dev/sda1 physical volume\npvcreate /dev/sda2\npvdisplay -> to check whethere both the pvs are created or not\n\nNow pv1 and pv2 are created",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "pvcreate /dev/sda1 -> this will create /dev/sda1 physical volume\npvcreate /dev/sda2\npvdisplay -> to check whethere both the pvs are created or not\n\nNow pv1 and pv2 are created",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4cZD-7nWlMpQ1j0wlM_1T",
      "type": "text",
