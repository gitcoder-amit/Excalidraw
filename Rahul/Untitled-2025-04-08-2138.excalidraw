    {
      "id": "gust39tS_vvDHAe0eTW7Q",
      "type": "text",
      "x": 1234.4467434044911,
      "y": 41355.59512756584,
      "width": 1133,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
