      "seed": 468778850,
      "version": 13,
      "versionNonce": 308390654,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772814440654,
      "link": null,
      "locked": false,
      "text": "Lets say I am at some other place connected to some other router, can we directly reach to\nother system if it is not having a public ip?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Lets say I am at some other place connected to some other router, can we directly reach to\nother system if it is not having a public ip?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "7YCKToYBuNurbUkbpG_4m",
      "type": "text",
      "x": 929.2201809044911,
      "y": 40049.77090881584,
      "width": 968,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bWF",
      "roundness": null,
      "seed": 1738096546,
      "version": 146,
      "versionNonce": 1271518562,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772814680610,
      "link": null,
      "locked": false,
      "text": "No due to, that is why these type of IP are called as private ip. because these can only\nbe used within a private network.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "No due to, that is why these type of IP are called as private ip. because these can only\nbe used within a private network.",
      "autoResize": true,
      "lineHeight": 1.25
    },
