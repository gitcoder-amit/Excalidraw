    {
      "id": "p1U6TaWJU6Jk6XaA-VdMH",
      "type": "text",
      "x": 1128.1850246544911,
      "y": 41130.21231506584,
      "width": 1243,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
