    {
      "id": "CWpN1wqoX3lJYF6IBtZwh",
      "type": "text",
      "x": 1023.6826864213419,
      "y": 33438.62794892791,
      "width": 1155,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
