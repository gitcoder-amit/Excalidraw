      "isDeleted": false,
      "boundElements": [],
      "updated": 1773158896360,
      "link": null,
      "locked": false,
      "text": "Application Layer -> it is our Browser, Or any application that is going to use internet. Here our\n                    whole packet either completely opened or packet is beiing pack krna start hota h, and the data\n                    is being read. Either the data is being sent to the packet to start it wrapping up or it is \n                    being completely completely open and it is being read. that is the part happening at Application\n                    layer means we are able to see the data.\n\nPresentation Layer -> \nSession Layer\nTransporation Layer\nNetwork Layer\nData Link Layer\nPhysical Layer",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Application Layer -> it is our Browser, Or any application that is going to use internet. Here our\n                    whole packet either completely opened or packet is beiing pack krna start hota h, and the data\n                    is being read. Either the data is being sent to the packet to start it wrapping up or it is \n                    being completely completely open and it is being read. that is the part happening at Application\n                    layer means we are able to see the data.\n\nPresentation Layer -> \nSession Layer\nTransporation Layer\nNetwork Layer\nData Link Layer\nPhysical Layer",
      "autoResize": true,
      "lineHeight": 1.25
    },
