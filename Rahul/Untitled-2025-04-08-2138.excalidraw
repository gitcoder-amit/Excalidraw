    },
    {
      "id": "LzqAGH1CpED_eKGqD7Vv2",
      "type": "text",
      "x": 908.1475301713419,
      "y": 34804.40138642791,
      "width": 1056,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bPs",
      "roundness": null,
      "seed": 34874204,
      "version": 903,
      "versionNonce": 443066466,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054918,
      "link": null,
      "locked": false,
      "text": "We have not checked till now how much our RAM is free, for a particular process we might see\nwith top command but if we want to check for total RAM then we have a command free\n\nfree -> here we can see what RAM is free and what is \nfree -h -> making sizes human readable.\n\nshared memory -> memory shared between 2 or more processes\nswap memory -> Our RAM has a part called cache, this cache generally swaps with other part of\n    RAM or this swaps with HDD so all this also need certain amount of memory that memory is\n    called as swap memory.\n\nQ -> we see cache and buffer here which are occupied, And there are cases in which we need to\nfree buffer and cache So how we will free our buffer memory and cache memory, which is displayed\noccupied by free command",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We have not checked till now how much our RAM is free, for a particular process we might see\nwith top command but if we want to check for total RAM then we have a command free\n\nfree -> here we can see what RAM is free and what is \nfree -h -> making sizes human readable.\n\nshared memory -> memory shared between 2 or more processes\nswap memory -> Our RAM has a part called cache, this cache generally swaps with other part of\n    RAM or this swaps with HDD so all this also need certain amount of memory that memory is\n    called as swap memory.\n\nQ -> we see cache and buffer here which are occupied, And there are cases in which we need to\nfree buffer and cache So how we will free our buffer memory and cache memory, which is displayed\noccupied by free command",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "gwLscrEqI07fBbl0cvhc3",
      "type": "text",
      "x": 846.9951864213419,
      "y": 35221.81544892791,
      "width": 176,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
