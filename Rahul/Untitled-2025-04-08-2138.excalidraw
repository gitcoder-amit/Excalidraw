      "seed": 467499774,
      "version": 616,
      "versionNonce": 13093474,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772818932011,
      "link": null,
      "locked": false,
      "text": "Till here we are done with half of the networking because through network our data packet can move from\none system to other system, but packet need to reach to exact appliction not only to system.\nOnce a packet comes to our IP, after that how will it know that which software requires it? May our media player\nis playing something via internet or playing a game using internet over there, at the same time I'm using browser\nand using internet over there, So How will it know which software to go to? There can be n number of softwares?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Till here we are done with half of the networking because through network our data packet can move from\none system to other system, but packet need to reach to exact appliction not only to system.\nOnce a packet comes to our IP, after that how will it know that which software requires it? May our media player\nis playing something via internet or playing a game using internet over there, at the same time I'm using browser\nand using internet over there, So How will it know which software to go to? There can be n number of softwares?",
      "autoResize": true,
      "lineHeight": 1.25
    },
