    {
      "id": "ptmWCMNRucEIT-_aiSWeQ",
      "type": "text",
      "x": 1820.8584676713422,
      "y": 45197.37404267791,
      "width": 539,
      "height": 350,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bSa",
      "roundness": null,
      "seed": 2144525929,
      "version": 769,
      "versionNonce": 343927010,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054918,
      "link": null,
      "locked": false,
      "text": "Just like wheat and sugar,as we can't \nmix wheat and sugar directly we need to\nprocess them, Same way two disk in their\noriginal partition form can't be joined\nor merged combined together. To combine \nthem we need to process them in some\nform that can be joined together, WE need to\nconvert them in a particular form whihc is\ncalled as PV(Physical Volume), now we know\ntwo physical volumns can be joined together\nvirtually whihc means, and then we will \ncombine both physical volume and we will make\nVolume Group, Like we will create a virtual layer\non top of those two PV.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Just like wheat and sugar,as we can't \nmix wheat and sugar directly we need to\nprocess them, Same way two disk in their\noriginal partition form can't be joined\nor merged combined together. To combine \nthem we need to process them in some\nform that can be joined together, WE need to\nconvert them in a particular form whihc is\ncalled as PV(Physical Volume), now we know\ntwo physical volumns can be joined together\nvirtually whihc means, and then we will \ncombine both physical volume and we will make\nVolume Group, Like we will create a virtual layer\non top of those two PV.",
      "autoResize": true,
      "lineHeight": 1.25
    },
