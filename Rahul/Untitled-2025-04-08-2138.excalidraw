    {
      "id": "PZgX9_N6856ZWOtLtoJ9f",
      "type": "text",
      "x": 882.509776548147,
      "y": 39660.45315743805,
      "width": 935,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bWB",
      "roundness": null,
      "seed": 1600301154,
      "version": 1116,
      "versionNonce": 335312190,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772814391726,
      "link": null,
      "locked": false,
      "text": "jis IP ko hm internet access allow kr dete h, that is called Public IP. Jis IP me hm\ndeny kr dete h that is our Private IP. in terms of  when we are assignin IP to our \nsystem, just in that term but ther is one more concept of Public and Private IP when\nwe talk about global networks or bigger networks.\n\nWhen we talk about bigger networks, Public IP is a IP which is registered with DNS,\nLets say we have to create linux socials website, we have to go and register with\nsome DNS that this is the IP address that I will be using and if anyone tries to come\nto linuxsocials.com, please redirect them to this particular IP address.\nwhereas A private IP is a IP, where there are few systems connected to my router or\nmy mobile hotspot, Now this router give all of them a IP using their DHCP.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "jis IP ko hm internet access allow kr dete h, that is called Public IP. Jis IP me hm\ndeny kr dete h that is our Private IP. in terms of  when we are assignin IP to our \nsystem, just in that term but ther is one more concept of Public and Private IP when\nwe talk about global networks or bigger networks.\n\nWhen we talk about bigger networks, Public IP is a IP which is registered with DNS,\nLets say we have to create linux socials website, we have to go and register with\nsome DNS that this is the IP address that I will be using and if anyone tries to come\nto linuxsocials.com, please redirect them to this particular IP address.\nwhereas A private IP is a IP, where there are few systems connected to my router or\nmy mobile hotspot, Now this router give all of them a IP using their DHCP.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "h0y5HX_6SosESQbfcwMJS",
