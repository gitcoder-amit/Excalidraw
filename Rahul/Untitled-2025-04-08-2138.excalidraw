    {
      "id": "dikAeIn8QLIPYY_ko_UjG",
      "type": "text",
      "x": 910.4990926713419,
      "y": 35558.80763642791,
      "width": 1078,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bQ4",
      "roundness": null,
      "seed": 1543682396,
      "version": 523,
      "versionNonce": 687568610,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054918,
      "link": null,
      "locked": false,
      "text": "As we know HDD has something called as sector numbers, So even if we are creating partition, we \nsuppose to know which sector number to which sector number my partition D is or C or B or A is\nfor this a space in HDD is already alocated that space is known as partition table. this partition\ntable will have the info regarding how much partition and metadata related to those partitions.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "As we know HDD has something called as sector numbers, So even if we are creating partition, we \nsuppose to know which sector number to which sector number my partition D is or C or B or A is\nfor this a space in HDD is already alocated that space is known as partition table. this partition\ntable will have the info regarding how much partition and metadata related to those partitions.",
      "autoResize": true,
      "lineHeight": 1.25
    },
