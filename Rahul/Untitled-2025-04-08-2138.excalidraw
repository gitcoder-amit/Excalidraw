      "seed": 1576329058,
      "version": 23,
      "versionNonce": 770039202,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772804572237,
      "link": null,
      "locked": false,
      "text": "IPv4 & IPv6 ->",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
