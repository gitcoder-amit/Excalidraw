    {
      "id": "6rFeEJYbcjERb8E9iNRqL",
      "type": "text",
      "x": 1015.0459676713419,
      "y": 38596.54201142791,
      "width": 341,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bR2",
      "roundness": null,
      "seed": 1601868380,
      "version": 44,
      "versionNonce": 1986204990,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054918,
      "link": null,
      "locked": false,
      "text": "What is the way of using a HDD?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What is the way of using a HDD?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "u_x53HmicvMpnv6r_im0V",
      "type": "text",
      "x": 1085.967842671342,
      "y": 38635.88576142791,
      "width": 1067,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bR3",
      "roundness": null,
      "seed": 1512410332,
      "version": 1480,
      "versionNonce": 1693607330,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054918,
      "link": null,
      "locked": false,
      "text": "the way of using a HDD is, we first attach our HDD then we partition it, where is the partiontion\nentry made -> partition table, after that we will read the partition and will try to format it.\nOnce we format the partition we do create file system table , Now this file system table we will\nlink it with mount point(any directory or location of my OS) we will link it over there. Once we\nhave mount point we can store that data inside that.\n\nWriting data takes lot of time, we write 1 TB of data or we create 1 GB of file it takes lot of \ntime But we can delete 1 GB even 1 TB of file that deletion takes only a second or less than a \nsecond why?\n\n    this is happening bcz they just have to remove your entry from file system table. If it is \ninside a folder, inside a folder we already know, no matter how big the file is we just have a\npointer stored inside one folder and if we remove this pointer we can't read the file bcz we dont\nhave way to reach the file. this data is still in HDD but delete for us, thats why deletion of\ndata is fast as compared to writing or creating new data. Because data creation is systematic\narrangement of each and every sector.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "the way of using a HDD is, we first attach our HDD then we partition it, where is the partiontion\nentry made -> partition table, after that we will read the partition and will try to format it.\nOnce we format the partition we do create file system table , Now this file system table we will\nlink it with mount point(any directory or location of my OS) we will link it over there. Once we\nhave mount point we can store that data inside that.\n\nWriting data takes lot of time, we write 1 TB of data or we create 1 GB of file it takes lot of \ntime But we can delete 1 GB even 1 TB of file that deletion takes only a second or less than a \nsecond why?\n\n    this is happening bcz they just have to remove your entry from file system table. If it is \ninside a folder, inside a folder we already know, no matter how big the file is we just have a\npointer stored inside one folder and if we remove this pointer we can't read the file bcz we dont\nhave way to reach the file. this data is still in HDD but delete for us, thats why deletion of\ndata is fast as compared to writing or creating new data. Because data creation is systematic\narrangement of each and every sector.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9kLgNuegpRtadXH60pZov",
      "type": "text",
      "x": 1008.4600301713419,
      "y": 39074.86232392791,
      "width": 583,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bR4",
      "roundness": null,
      "seed": 1792245988,
      "version": 66,
      "versionNonce": 1711914366,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1772802054918,
      "link": null,
      "locked": false,
      "text": "Q Files are always there is HDD after deletion also ?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Q Files are always there is HDD after deletion also ?",
      "autoResize": true,
      "lineHeight": 1.25
    },
