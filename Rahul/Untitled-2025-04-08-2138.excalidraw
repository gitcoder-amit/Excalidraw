    {
      "id": "tKkqP3CLYW_Mu84bT0OAF",
      "type": "text",
      "x": 1234.7201809044911,
      "y": 41640.68106506584,
      "width": 1276,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1971c2",
