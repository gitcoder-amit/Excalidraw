      "text": "HardDisk(HDD) ->",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "HardDisk(HDD) ->",
      "autoResize": true,
