    {
      "id": "kK8q3j5G3DLiOLW3qVFxa",
      "type": "text",
      "x": 864.9479121072225,
      "y": 38782.824413118164,
      "width": 154,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
