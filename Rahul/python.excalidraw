    {
      "id": "Rdo4xRmIfW2c5QTKRXaW7",
      "type": "text",
      "x": 1161.2555339973253,
      "y": -12825.184327927022,
      "width": 1023,
      "height": 950,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b9I",
