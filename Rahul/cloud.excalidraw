      "seed": 483022812,
      "version": 194,
      "versionNonce": 699770980,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775965657064,
      "link": null,
      "locked": false,
      "text": "No failure, we have read replica, once we have that replica anyday if our write DB is down, we can\npick one of these replica and we can make that our write DB.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "No failure, we have read replica, once we have that replica anyday if our write DB is down, we can\npick one of these replica and we can make that our write DB.",
      "autoResize": true,
      "lineHeight": 1.25
    },
