      "isDeleted": false,
      "boundElements": [],
      "updated": 1773250235339,
      "link": null,
      "locked": false,
      "text": "Now we have cloud inside that, we have VPC and we are inside that, Now we will work whatever\nwe want inside this private cloud, ",
      "fontSize": 20,
