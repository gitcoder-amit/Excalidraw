    {
      "id": "TJJA8RsaemVAleRdnTG75",
      "type": "text",
      "x": 1111.8866075417504,
      "y": 60195.81396621892,
      "width": 1155,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bez",
      "roundness": null,
      "seed": 1855703712,
      "version": 1260,
      "versionNonce": 1859164000,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773833561074,
      "link": null,
      "locked": false,
      "text": "Task -> \nCreate EC2,  this EC2 is going to display the IP of system, how it will display IP, it will fetch IP \ndynamycally during run time, Our webpase runtime directly fetch IP dynamically we can write symple \npython code for this, Now this will be displayed on our index.html\nwhihc meand we have to setup Apache server\n2 thing from the above instance we will create a AMI\n3 From here we will create APplication Software, Add one instance manually, after that setup autoscaling\n    and after setting autoscaling, we need to make sure that it scales to 2 instances and then rather\nthan hitting 2 instance direclty we willl hit the link or the URL of our LB. when we create LB, LB itself\ngive one URL and we will hit that URL and then LB will redirect to 1st instance it will take sometime\nno need to set stickyness then after sometime 1 or 2 minute it will go to other instance then 1 st.\nTry to observer the pattern, and how we will know that which instance is hitting, the IP of that instance\nwill be displayed on our browser due to our code.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Task -> \nCreate EC2,  this EC2 is going to display the IP of system, how it will display IP, it will fetch IP \ndynamycally during run time, Our webpase runtime directly fetch IP dynamically we can write symple \npython code for this, Now this will be displayed on our index.html\nwhihc meand we have to setup Apache server\n2 thing from the above instance we will create a AMI\n3 From here we will create APplication Software, Add one instance manually, after that setup autoscaling\n    and after setting autoscaling, we need to make sure that it scales to 2 instances and then rather\nthan hitting 2 instance direclty we willl hit the link or the URL of our LB. when we create LB, LB itself\ngive one URL and we will hit that URL and then LB will redirect to 1st instance it will take sometime\nno need to set stickyness then after sometime 1 or 2 minute it will go to other instance then 1 st.\nTry to observer the pattern, and how we will know that which instance is hitting, the IP of that instance\nwill be displayed on our browser due to our code.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "I1e99u5YHKTtozYLel13C",
      "type": "text",
      "x": 1104.0439301122817,
      "y": 60664.12543572728,
      "width": 264,
      "height": 50,
      "angle": 0,
