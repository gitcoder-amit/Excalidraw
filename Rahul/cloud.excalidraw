    {
      "id": "kMC3-JLhGWYFsajOYjAv5",
      "type": "text",
      "x": 1163.5088582963417,
      "y": 36040.38185517791,
      "width": 1001,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
