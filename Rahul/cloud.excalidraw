    {
      "id": "aPFpS3Cg3T9kPi6Xm6Wbp",
      "type": "text",
      "x": 1219.567452046342,
      "y": 56847.12208955291,
      "width": 1089,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
