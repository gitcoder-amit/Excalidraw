      "index": "bkv",
      "roundness": null,
      "seed": 689835868,
      "version": 314,
      "versionNonce": 1472035420,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775969856110,
      "link": null,
      "locked": false,
      "text": "Next challenge is we are adding all ML feature in separate machine, somehow integrate this code, with main \npipeline without disturbing our backend service.\nRight now work on main service we will work on ML related stuff later.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Next challenge is we are adding all ML feature in separate machine, somehow integrate this code, with main \npipeline without disturbing our backend service.\nRight now work on main service we will work on ML related stuff later.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "vkAJQ7GgWVB49FL0rktAk",
      "type": "text",
      "x": 1674.1373533787087,
      "y": 76553.83464970658,
      "width": 1188,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkw",
      "roundness": null,
      "seed": 1777308508,
      "version": 671,
      "versionNonce": 306747108,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775970387739,
      "link": null,
      "locked": false,
      "text": "overview ->\nfrontent HTML action  we will give LB link here-> give route to BE LB,\n        Backend has lets say Python code that will call our RDS that will connect to Databaase\n        In RDS we can setup two type of call, lets say I am displaying a list of fruit(Apple, Mango, Banana)\n    Now if I want to add Strawberry over there, how we will do this by makiing a write query, and we need to\nmake such a way when we are fetching fruit it will fetch from Read replica and when it will make write\nthen it will write in write DB.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "overview ->\nfrontent HTML action  we will give LB link here-> give route to BE LB,\n        Backend has lets say Python code that will call our RDS that will connect to Databaase\n        In RDS we can setup two type of call, lets say I am displaying a list of fruit(Apple, Mango, Banana)\n    Now if I want to add Strawberry over there, how we will do this by makiing a write query, and we need to\nmake such a way when we are fetching fruit it will fetch from Read replica and when it will make write\nthen it will write in write DB.",
      "autoResize": true,
      "lineHeight": 1.25
    },
