    {
      "id": "EaU3VK3YtmADEefnvEfIR",
      "type": "text",
      "x": 1182.4593840828586,
      "y": 57523.793454208775,
      "width": 1276,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
