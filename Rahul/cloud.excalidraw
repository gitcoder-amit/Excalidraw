    {
      "id": "6C45fcjtWFM3vL9ZHOyVG",
      "type": "text",
      "x": 1677.571545107343,
      "y": 76432.31741071829,
      "width": 1177,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
