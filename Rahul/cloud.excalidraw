    },
    {
      "id": "ZgjVRwU4uNDa7TmxAz9xL",
      "type": "text",
      "x": 1677.2240376109935,
      "y": 74098.93948740355,
      "width": 1122,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkZ",
      "roundness": null,
      "seed": 1736705628,
      "version": 715,
      "versionNonce": 988602596,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775966401929,
      "link": null,
      "locked": false,
      "text": "External disk EBS. EBS attached to write DB. But usually it is not needed, Lets say we are configuring\nlike this that data should be replicated in after every 10 minutes, Like I am assuming this if we lost\n10 minute data it is okat for me. that is why I have configured like this. So we know our priorities \nand according to that only we set it up.\n\nIn this case there is 10 minute stale data in our read replicas, there is no stale data due to we have\nconfigured in it will replicated in 10 or 15 minutes which means we are assuming for 10-15 minutes\nthere is no stale data. I can show it to users.\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "External disk EBS. EBS attached to write DB. But usually it is not needed, Lets say we are configuring\nlike this that data should be replicated in after every 10 minutes, Like I am assuming this if we lost\n10 minute data it is okat for me. that is why I have configured like this. So we know our priorities \nand according to that only we set it up.\n\nIn this case there is 10 minute stale data in our read replicas, there is no stale data due to we have\nconfigured in it will replicated in 10 or 15 minutes which means we are assuming for 10-15 minutes\nthere is no stale data. I can show it to users.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "sCKQIUbzsqbzRODlIUxoP",
      "type": "text",
