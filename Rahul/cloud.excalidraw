    {
      "id": "iM9b0liW4boSGz35UIBKz",
      "type": "text",
      "x": 1219.008858296342,
      "y": 56501.79396455291,
      "width": 1166,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "beS",
      "roundness": null,
      "seed": 787439456,
      "version": 1039,
      "versionNonce": 358360928,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773829783471,
      "link": null,
      "locked": false,
      "text": "If the LB needs to route the request the LB obviously need to keep on checking which server(LB knows\neach server IP) is healthy and which server is not, which means LB will send request to each server(it is \nnot by user it is by LB) periodically(LIke every 10 minute or 5 minute acc to requirement)\n and it sends two kind of request\n1 To the System\n2 To the Application -> which is running on server, so at the time of LB configuration, we are\n    actually telling the LB, that you have to route the request on this instance and in this\n    particular PORT number. Hence LB will check on instance and Port Number like that Particular\n    Port number is running or not, what kind of response it is giving, is it giving 200 or\n    any other.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If the LB needs to route the request the LB obviously need to keep on checking which server(LB knows\neach server IP) is healthy and which server is not, which means LB will send request to each server(it is \nnot by user it is by LB) periodically(LIke every 10 minute or 5 minute acc to requirement)\n and it sends two kind of request\n1 To the System\n2 To the Application -> which is running on server, so at the time of LB configuration, we are\n    actually telling the LB, that you have to route the request on this instance and in this\n    particular PORT number. Hence LB will check on instance and Port Number like that Particular\n    Port number is running or not, what kind of response it is giving, is it giving 200 or\n    any other.",
      "autoResize": true,
      "lineHeight": 1.25
    },
