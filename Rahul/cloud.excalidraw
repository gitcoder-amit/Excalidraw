      "isDeleted": false,
      "boundElements": [],
      "updated": 1773642972823,
      "link": null,
      "locked": false,
      "text": "this is something that allow us to increase the network bandwidth of our system, incoming and \noutgoing network bandwidth of our system.",
      "fontSize": 20,
