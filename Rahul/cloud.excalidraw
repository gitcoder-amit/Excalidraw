    {
      "id": "aWsrkpOi6tJBYEuwzni3N",
      "type": "text",
      "x": 1082.024483296342,
      "y": 54957.31740205291,
      "width": 1056,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "be2",
      "roundness": null,
      "seed": 2080681632,
      "version": 267,
      "versionNonce": 308602528,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773828168240,
      "link": null,
      "locked": false,
      "text": "Lets say we have a website in which there are lot of users in night but less users in day time\ndue to lot of users in night we have a powerful system and we are not utilizing this at day time\nso this is a cost problem also with Vertical Scaling.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Lets say we have a website in which there are lot of users in night but less users in day time\ndue to lot of users in night we have a powerful system and we are not utilizing this at day time\nso this is a cost problem also with Vertical Scaling.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Cp8uIstVDW4Ofxl-xQPab",
      "type": "text",
      "x": 1037.184639546342,
      "y": 55130.77443330291,
      "width": 638,
      "height": 25,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "be3",
      "roundness": null,
      "seed": 1679015584,
      "version": 69,
