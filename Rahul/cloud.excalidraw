    {
      "id": "P-VU8zs_dBf9d8xKEqJOb",
      "type": "text",
      "x": 1267.4872917560829,
      "y": 66270.5485744116,
      "width": 781,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
