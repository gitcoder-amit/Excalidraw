    },
    {
      "id": "xh_huYJ0vbpGBsnpO4MsB",
      "type": "text",
      "x": 1274.301827046342,
      "y": 40782.96193330291,
      "width": 1012,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bbL",
      "roundness": null,
      "seed": 275007394,
      "version": 297,
      "versionNonce": 101504842,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773641419343,
      "link": null,
      "locked": false,
      "text": "Cloud software is some other system, and we are using it with the network in another system.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cloud software is some other system, and we are using it with the network in another system.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "yRyk642qiXXu_gEKvCyjD",
      "type": "text",
      "x": 1277.665108296342,
      "y": 40813.37990205291,
      "width": 1023,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bbM",
      "roundness": null,
      "seed": 1814100350,
      "version": 359,
      "versionNonce": 566713866,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773641419343,
      "link": null,
      "locked": false,
      "text": "Example -> Online Game, Google Sheets, Google Docs, these are install somewhere else, we are \n    using it over a browser.\n    Compiler even though they are Software, we still can't use this as a SAAS.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Example -> Online Game, Google Sheets, Google Docs, these are install somewhere else, we are \n    using it over a browser.\n    Compiler even though they are Software, we still can't use this as a SAAS.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-cs_0EUe7If5nMarDWZpk",
      "type": "text",
      "x": 1220.653389546342,
      "y": 40917.23927705291,
      "width": 341,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bbO",
      "roundness": null,
      "seed": 499125538,
      "version": 100,
      "versionNonce": 868315146,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773641406599,
      "link": null,
      "locked": false,
      "text": "PAAS(Plateform as a Service) ->",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PAAS(Plateform as a Service) ->",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-e7j9jdx5bj-prIJhch-Y",
      "type": "text",
      "x": 1266.946358296342,
      "y": 40973.12990205291,
      "width": 1100,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bbQ",
      "roundness": null,
      "seed": 1041833918,
      "version": 968,
      "versionNonce": 1463363798,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773641674759,
      "link": null,
      "locked": false,
      "text": "we are not saying compiler as SAAS due to we are not getting just once software usually, with this\ncompilere we get a whole environment being setup.\n\nIf someone is providing ML compiler online like a normal website, then it would not give like a \npython compiler, he will setup whole enviroment, he will setup ML libraries, Deep learning libraries\nevery thing packaged and give it to us\n\nIF we are setting up group of softwares and making a whole environment together and providing them\naccess to it, Where they can develop something then it is called as PAAS.\n\nExample -> we will see majorly in cloud service only\n            AWS lambda or serverless\n    Any cloud which provides serverless feature, that serverless is a part of PASS.\n    Salesforce",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "we are not saying compiler as SAAS due to we are not getting just once software usually, with this\ncompilere we get a whole environment being setup.\n\nIf someone is providing ML compiler online like a normal website, then it would not give like a \npython compiler, he will setup whole enviroment, he will setup ML libraries, Deep learning libraries\nevery thing packaged and give it to us\n\nIF we are setting up group of softwares and making a whole environment together and providing them\naccess to it, Where they can develop something then it is called as PAAS.\n\nExample -> we will see majorly in cloud service only\n            AWS lambda or serverless\n    Any cloud which provides serverless feature, that serverless is a part of PASS.\n    Salesforce",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "A7H4Bj2VnJLFHztb66AJo",
      "type": "text",
      "x": 1212.149483296342,
      "y": 41360.30958955291,
      "width": 341,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bbR",
      "roundness": null,
      "seed": 264973758,
      "version": 89,
      "versionNonce": 727553430,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773641810416,
      "link": null,
      "locked": false,
