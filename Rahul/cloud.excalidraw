      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bbT",
      "roundness": null,
      "seed": 112070154,
      "version": 165,
      "versionNonce": 1327843082,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773641563813,
      "link": null,
      "locked": false,
      "text": "Cloud itself provide many services to use like many software monitoring softwares, Logging software or\nvarious other softwares.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cloud itself provide many services to use like many software monitoring softwares, Logging software or\nvarious other softwares.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oZQ-SkSPgfOdV6tlDcaU8",
      "type": "text",
      "x": 1251.911202046342,
      "y": 41414.82521455291,
      "width": 1001,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
