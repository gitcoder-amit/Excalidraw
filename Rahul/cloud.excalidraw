    },
    {
      "id": "20ml_ssAgZR8t_BXhaZo5",
      "type": "text",
      "x": 1248.422920796342,
      "y": 41477.37208955291,
      "width": 198,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
