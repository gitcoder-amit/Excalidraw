      "isDeleted": false,
      "boundElements": [],
      "updated": 1773840860626,
      "link": null,
      "locked": false,
      "text": "Do we need Server for static Application?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Do we need Server for static Application?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "DWFe3HXCz9PgIev3leRE8",
      "type": "text",
      "x": 1227.3678737954867,
      "y": 63318.8678203387,
      "width": 1045,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
