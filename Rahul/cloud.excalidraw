      "index": "bef",
      "roundness": null,
      "seed": 2063746720,
      "version": 781,
      "versionNonce": 702680928,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773830941584,
      "link": null,
      "locked": false,
      "text": "If a user comes, for a while(untill token is valid) make it busy with same instance like if he is going to any other\npage or going to product page from index page or refreshing the page, so instance should be same.\nIt should be there due to if refresh will change machine new session will be created. It also\nreduce the load on LB.\n\nExample -> If we have loged into Netflix if after 2 -3 hours we are coming again then it will show\n    us the home page due to stickyness, if we are coming after 1 day then it will show us user\nselection page or Login Page due to stickyness ends.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If a user comes, for a while(untill token is valid) make it busy with same instance like if he is going to any other\npage or going to product page from index page or refreshing the page, so instance should be same.\nIt should be there due to if refresh will change machine new session will be created. It also\nreduce the load on LB.\n\nExample -> If we have loged into Netflix if after 2 -3 hours we are coming again then it will show\n    us the home page due to stickyness, if we are coming after 1 day then it will show us user\nselection page or Login Page due to stickyness ends.",
      "autoResize": true,
      "lineHeight": 1.25
    },
