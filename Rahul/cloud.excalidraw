    {
      "id": "A2oEhV-5d1kncIAAsrOAY",
      "type": "text",
      "x": 1185.033901785069,
      "y": 62475.70541665528,
      "width": 407,
      "height": 50,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bfp",
      "roundness": null,
      "seed": 952618848,
      "version": 74,
      "versionNonce": 413827936,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773840501613,
      "link": null,
      "locked": false,
      "text": "Lets say we have 1 GB of media files \nin our frontend.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Lets say we have 1 GB of media files \nin our frontend.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "6gOARIH8ULO-6iD-enhkP",
      "type": "text",
      "x": 1160.4460482224108,
      "y": 63100.43865571526,
      "width": 990,
      "height": 100,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bfq",
      "roundness": null,
      "seed": 1647099744,
      "version": 469,
      "versionNonce": 144880288,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773840711282,
      "link": null,
      "locked": false,
      "text": "Sometime we dont even need instances for our static application, we will directly put in\nS3 and give that URL to people, As S3 is managed service by Amazon hence we dont even need\nLB in this case it is there responsibility to handle load on that S3 url. EC2 is not a\nmanaged service that is why we are putting LB in front of them to manage the load.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Sometime we dont even need instances for our static application, we will directly put in\nS3 and give that URL to people, As S3 is managed service by Amazon hence we dont even need\nLB in this case it is there responsibility to handle load on that S3 url. EC2 is not a\nmanaged service that is why we are putting LB in front of them to manage the load.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "gh9k13IUQvuAtTSocLU46",
      "type": "text",
      "x": 1070.5692789018217,
      "y": 63676.27880665646,
      "width": 330,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
