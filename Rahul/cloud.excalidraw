    {
      "id": "eBm1qvjX73r273xhz_ZL3",
      "type": "text",
      "x": 1075.387764546342,
      "y": 55284.94240205291,
      "width": 1078,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "be5",
      "roundness": null,
      "seed": 1542792032,
      "version": 289,
      "versionNonce": 1934716576,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773828346208,
      "link": null,
      "locked": false,
      "text": "in horizontal scaling we have a system that will redirect users to multiple servers, if we have \nincreasing users then we can add more servers if the users are decreasing then we can decrease the\nserver such that our cost will be effective",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "in horizontal scaling we have a system that will redirect users to multiple servers, if we have \nincreasing users then we can add more servers if the users are decreasing then we can decrease the\nserver such that our cost will be effective",
      "autoResize": true,
      "lineHeight": 1.25
    },
