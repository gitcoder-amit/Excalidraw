      "type": "text",
      "x": 1155.235420796342,
      "y": 43414.16851125666,
      "width": 1034,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
