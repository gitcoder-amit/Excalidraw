      "versionNonce": 526241440,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773832142480,
      "link": null,
      "locked": false,
      "text": "As name suggest it works on Application layer protocol\nWhat are the Application Layer Protocol ->\n    http, https, ftp, sftp, smtp basically browser deals this protocols.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "As name suggest it works on Application layer protocol\nWhat are the Application Layer Protocol ->\n    http, https, ftp, sftp, smtp basically browser deals this protocols.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_8wHO0icu26Zr1AsBAGQa",
      "type": "text",
      "x": 1126.370831623202,
      "y": 59038.64614529428,
      "width": 154,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
