    {
      "id": "qWagX0sTgEZSoYH9a_eH7",
      "type": "text",
      "x": 1028.532295796342,
      "y": 35147.69240205291,
      "width": 1144,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ba5",
      "roundness": null,
      "seed": 426419709,
      "version": 1334,
      "versionNonce": 2121893171,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773245661376,
      "link": null,
      "locked": false,
      "text": "if we have one software, we need hardware to run this software, one way is we will purchase\nthat hardware, So we need to create a data center for that, we need people to manage this\ndata center\n\nSecond way is someone create their services to use, now we know we can connect to system over network \neasily, and we can use system.\n\nHere where in I can come as a client, I can start using that system or group of those systems, then that\nis cloud.\n\nBy Cloud, Developers can sit anywhere and access the resource anywhere doesn't matter in the world.\nthat is why it is not just storage, there are lot of things that we can use. which are called as diff\nservices of cloud. and whoever is giving this cloud, that kind of company called as Cloud Provider.\nExample -> AWS, GCP, Azure, Nutanix, Netapp, Oracle, IBM\n\nSO cloud is we can resource over network, we can get Hardware, Software or It resource over network.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "if we have one software, we need hardware to run this software, one way is we will purchase\nthat hardware, So we need to create a data center for that, we need people to manage this\ndata center\n\nSecond way is someone create their services to use, now we know we can connect to system over network \neasily, and we can use system.\n\nHere where in I can come as a client, I can start using that system or group of those systems, then that\nis cloud.\n\nBy Cloud, Developers can sit anywhere and access the resource anywhere doesn't matter in the world.\nthat is why it is not just storage, there are lot of things that we can use. which are called as diff\nservices of cloud. and whoever is giving this cloud, that kind of company called as Cloud Provider.\nExample -> AWS, GCP, Azure, Nutanix, Netapp, Oracle, IBM\n\nSO cloud is we can resource over network, we can get Hardware, Software or It resource over network.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "eo8Yx0jQx1MTuyzliauXG",
      "type": "text",
      "x": 1021.5596395463419,
      "y": 35572.30568330291,
      "width": 803,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
