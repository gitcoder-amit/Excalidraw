      "boundElements": [],
      "updated": 1773247964169,
      "link": null,
      "locked": false,
      "text": "Entire PUblic cloud is not available to use, like A hotel we can't go in everywhere we will\nbuy a room and we can go there.\n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Entire PUblic cloud is not available to use, like A hotel we can't go in everywhere we will\nbuy a room and we can go there.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "D5lNv9S9dLcnKhZoePyvY",
      "type": "text",
      "x": 1275.4346395463417,
      "y": 36998.93263642791,
      "width": 1012,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
