      "isDeleted": false,
      "boundElements": [],
      "updated": 1773249952024,
      "link": null,
      "locked": false,
      "text": "Flat -> Whole Data Center\nRooms -> Resources\nto communicate with resource we have put Router there that router is our VPC.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flat -> Whole Data Center\nRooms -> Resources\nto communicate with resource we have put Router there that router is our VPC.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
