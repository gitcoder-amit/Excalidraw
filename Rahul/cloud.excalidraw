      "isDeleted": false,
      "boundElements": [],
      "updated": 1773828205794,
      "link": null,
      "locked": false,
      "text": "Solution to this is something called as Horizontal Scaling",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Solution to this is something called as Horizontal Scaling",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "XiSm96XNbbcXQvH9bSsi8",
