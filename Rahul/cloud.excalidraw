      "index": "bft",
      "roundness": null,
      "seed": 1094712160,
      "version": 216,
      "versionNonce": 241743520,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773840919270,
      "link": null,
      "locked": false,
      "text": "No we just need  a mechanism by whihc user can directly run on their browser without installing\nanything in the system. so we just need S3 url to access the media files.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "No we just need  a mechanism by whihc user can directly run on their browser without installing\nanything in the system. so we just need S3 url to access the media files.",
      "autoResize": true,
      "lineHeight": 1.25
    },
