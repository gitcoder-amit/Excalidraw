    {
      "id": "02hfb_HfKPywlvhZF8zBq",
      "type": "text",
      "x": 952.0947957963419,
      "y": 53742.12599580291,
      "width": 220,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
