    {
      "id": "3_QtftXFcyxnMyOW_Pq57",
      "type": "text",
      "x": 1588.4828880136783,
      "y": 73573.3405316595,
      "width": 1122,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkP",
      "roundness": null,
      "seed": 785037412,
      "version": 900,
      "versionNonce": 1340759268,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775965526846,
      "link": null,
      "locked": false,
      "text": "If  we will zoom on Write DB, Its not like we have single DB only, we might have multiple write\nDB, but each of them will have different data. For example users have name starts with A in one\ndatabase, for B in different database and so on, or their is any other way to distribute data like\nuser from one region they will have one DB, users from another region they will have different DB.\nOr One Zone have one DB, another zone have another DB like this. So if we are classifying like this\nbut all in all if we group them and see like howmany write databases are for users whose name are \nstarting with A there is only one write DB. So for a particular user in a particular application there\nis going to be just one write database.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If  we will zoom on Write DB, Its not like we have single DB only, we might have multiple write\nDB, but each of them will have different data. For example users have name starts with A in one\ndatabase, for B in different database and so on, or their is any other way to distribute data like\nuser from one region they will have one DB, users from another region they will have different DB.\nOr One Zone have one DB, another zone have another DB like this. So if we are classifying like this\nbut all in all if we group them and see like howmany write databases are for users whose name are \nstarting with A there is only one write DB. So for a particular user in a particular application there\nis going to be just one write database.",
      "autoResize": true,
      "lineHeight": 1.25
    },
