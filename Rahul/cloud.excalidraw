      "seed": 966371350,
      "version": 629,
      "versionNonce": 1906230358,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773642114638,
      "link": null,
      "locked": false,
      "text": "Storage is of different types, the prime types that we have to focus on is object and block",
