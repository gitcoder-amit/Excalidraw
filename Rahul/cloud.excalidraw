      "seed": 1102824138,
      "version": 21,
      "versionNonce": 888631434,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773642125583,
      "link": null,
      "locked": false,
      "text": "Object Storage -> ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Object Storage -> ",
      "autoResize": true,
