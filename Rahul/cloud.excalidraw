    {
      "id": "H2lor4Zj_lj-A6PZw2LVU",
      "type": "text",
      "x": 1145.18854713715,
      "y": 62186.72355727826,
      "width": 1155,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bfC",
      "roundness": null,
      "seed": 1847994016,
      "version": 789,
      "versionNonce": 226712224,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773840080153,
      "link": null,
      "locked": false,
      "text": "EBS is usually added to store our logs, code can be deployes in all instances, code is not that big\nit is of few Mbs or few KBs, But logs are generated repeatedly over a time again and again, if we\nare using it for a longer period of time then it can full the storage also so what we do, we try to ]\ncollect logs in different system so that some day if attack or anything happen with our system and system\ngoes down then we need check the logs, we can detach the EBS from the system and attach it with test\nserver, in test server we can start reading the logs. and we can check what if any issues comes in\nour application side.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "EBS is usually added to store our logs, code can be deployes in all instances, code is not that big\nit is of few Mbs or few KBs, But logs are generated repeatedly over a time again and again, if we\nare using it for a longer period of time then it can full the storage also so what we do, we try to ]\ncollect logs in different system so that some day if attack or anything happen with our system and system\ngoes down then we need check the logs, we can detach the EBS from the system and attach it with test\nserver, in test server we can start reading the logs. and we can check what if any issues comes in\nour application side.",
      "autoResize": true,
      "lineHeight": 1.25
    },
