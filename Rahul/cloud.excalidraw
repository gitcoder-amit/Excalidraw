    {
      "id": "IbwcnI2-DJzU1IZX8KLnz",
      "type": "text",
      "x": 1944.6412349965613,
      "y": 70070.17469748443,
      "width": 198,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
