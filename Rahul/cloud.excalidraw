      "updated": 1775965581993,
      "link": null,
      "locked": false,
      "text": "Doubt -> IF we have only one write DB for a set of user, that will be a Single point of failure for\n    those set of user.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Doubt -> IF we have only one write DB for a set of user, that will be a Single point of failure for\n    those set of user.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "NVgSd-PifQ6s8pUE9eBw_",
      "type": "text",
      "x": 1653.9083287676558,
      "y": 73860.80690928713,
      "width": 1078,
