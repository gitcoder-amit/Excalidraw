    {
      "id": "MTdHxyTxnHFH63LFHvsOC",
      "type": "text",
      "x": 1210.669014546342,
      "y": 56189.36037080291,
      "width": 1122,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "beQ",
      "roundness": null,
      "seed": 1398938272,
      "version": 4,
      "versionNonce": 1487915680,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773829172386,
      "link": null,
      "locked": false,
      "text": "Round Robin Algo (1 by 1 to everyone)\n    weighted Round Robin Load balancing ( if one system is highly powerful like 4x then it will take 4\n            request then 5th will go to other accoring to weight that server will take\n            that number or request and so on)\n    IP hash algorithm(IP%no of servers) send the request to that server\n    Least Connection -> when we need to decide based on availability of open connection on a server\n    Least Response time -> when the client is looking for least response time, so our LB knows\n            which server takes howmuch time.\n    ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Round Robin Algo (1 by 1 to everyone)\n    weighted Round Robin Load balancing ( if one system is highly powerful like 4x then it will take 4\n            request then 5th will go to other accoring to weight that server will take\n            that number or request and so on)\n    IP hash algorithm(IP%no of servers) send the request to that server\n    Least Connection -> when we need to decide based on availability of open connection on a server\n    Least Response time -> when the client is looking for least response time, so our LB knows\n            which server takes howmuch time.\n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "5QkoXlwp6jS_qxqdANNfD",
      "type": "text",
      "x": 1149.540108296342,
      "y": 56462.37208955291,
      "width": 396,
      "height": 25,
      "angle": 0,
