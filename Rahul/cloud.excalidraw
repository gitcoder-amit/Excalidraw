      "versionNonce": 2109472157,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773249432651,
      "link": null,
      "locked": false,
      "text": "VPC on Hardware Level ->",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "VPC on Hardware Level ->",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "pWIVS2iDc7ATrMKK4zIRm",
      "type": "text",
      "x": 1350.1260457963417,
      "y": 37545.00685517791,
      "width": 1364,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "baT",
      "roundness": null,
      "seed": 1025779187,
      "version": 356,
      "versionNonce": 1835061437,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773249694355,
      "link": null,
      "locked": false,
      "text": "whenever we create VM or resouce, resource will have own IP & ID, this IP belongs to a particular subnet, subnet belongs\nto a vpc.\n\nsubnet at a hardware level belongs to our router, we creare subnet in router. So VPC is basically a router which is assigned\nto us.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "whenever we create VM or resouce, resource will have own IP & ID, this IP belongs to a particular subnet, subnet belongs\nto a vpc.\n\nsubnet at a hardware level belongs to our router, we creare subnet in router. So VPC is basically a router which is assigned\nto us.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "pMTDTi0k8rChH1XPSpEzo",
      "type": "text",
      "x": 1355.8057332963417,
      "y": 37723.00294892791,
      "width": 847,
      "height": 75,
      "angle": 0,
