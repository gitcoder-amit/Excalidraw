    {
      "id": "vYNHI-AI9g7Fer_oVNKM4",
      "type": "text",
      "x": 1297.254952046342,
      "y": 48372.87208955291,
      "width": 176,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
