    },
    {
      "id": "N7DHK0H0rbkfR0zf4QcJ2",
      "type": "text",
      "x": 1191.887764546342,
      "y": 43725.40333955291,
      "width": 506,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
