    {
      "id": "molikcYWmcVV7YA0WfElU",
      "type": "text",
      "x": 1169.9608881068089,
      "y": 58166.69978085496,
      "width": 1155,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
