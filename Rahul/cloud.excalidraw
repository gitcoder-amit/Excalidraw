      "text": "SAAS(Software as a service) ->",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SAAS(Software as a service) ->",
      "autoResize": true,
