    {
      "id": "WY4-z_AoSeMsaAgcOyff5",
      "type": "text",
      "x": 1538.8710825053656,
      "y": 73073.71669012685,
      "width": 1155,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkE",
      "roundness": null,
      "seed": 128023388,
      "version": 365,
      "versionNonce": 587804644,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775964591852,
      "link": null,
      "locked": false,
      "text": "Doubt -> If we are trying to book a seat in Book My show , we need to select the seat, when we select the\nseat and we dont book it yet, Person B wont able to select those seat, It will be displayed occupied, so \nwe can understand they are maintaining using flags, but how they are showing instantaniously?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Doubt -> If we are trying to book a seat in Book My show , we need to select the seat, when we select the\nseat and we dont book it yet, Person B wont able to select those seat, It will be displayed occupied, so \nwe can understand they are maintaining using flags, but how they are showing instantaniously?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wqqkkmiEf3fSevnuz1STh",
      "type": "text",
      "x": 1615.8746553730268,
      "y": 73150.19496248639,
      "width": 1089,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkF",
      "roundness": null,
      "seed": 1986103012,
      "version": 203,
      "versionNonce": 539290844,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775964661346,
      "link": null,
      "locked": false,
      "text": "That is in-memory database, something like Redis in between, we discussed above as SQL DB. Book My \nshow will have a redis in between.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "That is in-memory database, something like Redis in between, we discussed above as SQL DB. Book My \nshow will have a redis in between.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "aiOTodTf3577QOKeuL60n",
      "type": "text",
      "x": 1547.243969005656,
      "y": 73239.83145492723,
      "width": 242,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkG",
      "roundness": null,
      "seed": 133981660,
      "version": 35,
      "versionNonce": 2052649820,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775964775743,
      "link": null,
      "locked": false,
      "text": "Locking is also used ?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Locking is also used ?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "7zs4Dl3PTzhc6Eot4OCHt",
      "type": "text",
      "x": 1615.457646377407,
      "y": 73267.91823727927,
      "width": 1056,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkH",
      "roundness": null,
      "seed": 885050460,
      "version": 358,
      "versionNonce": 1156523492,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775964940482,
      "link": null,
      "locked": false,
      "text": "Every user who comes over here one after another, So for their particular session like when\ntheir queries are running, when their things are being handled, when their seat is being booked \nor product is being sold. At that time DB is locked we can't make another transaction, thats\nobviously there for sure.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Every user who comes over here one after another, So for their particular session like when\ntheir queries are running, when their things are being handled, when their seat is being booked \nor product is being sold. At that time DB is locked we can't make another transaction, thats\nobviously there for sure.",
      "autoResize": true,
      "lineHeight": 1.25
    },
