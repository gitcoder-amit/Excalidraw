    {
      "id": "W-NXsfgY8piX2jizW9SkE",
      "type": "text",
      "x": 1902.3565145463417,
      "y": 38969.14357392791,
      "width": 693,
      "height": 200,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bal",
      "roundness": null,
      "seed": 1978218963,
      "version": 471,
      "versionNonce": 1125198370,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773334836329,
      "link": null,
      "locked": false,
      "text": "I will give this system a public IP and we will call\nAmit and tell this is my cloud, YOu can come over here\nand login and for this you can pay me. Now this is cloud \nservice\n\nwe have already worked on LVM & Mounting, instead of mounting\non our system, IF we will mount on some other system then it is\nbecome drive. OVer the network we are providing storage.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "I will give this system a public IP and we will call\nAmit and tell this is my cloud, YOu can come over here\nand login and for this you can pay me. Now this is cloud \nservice\n\nwe have already worked on LVM & Mounting, instead of mounting\non our system, IF we will mount on some other system then it is\nbecome drive. OVer the network we are providing storage.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "HHV6ze9fmowmeOja_tfyh",
      "type": "text",
      "x": 1570.8682332963417,
      "y": 38926.59669892791,
      "width": 44,
      "height": 25,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bam",
      "roundness": null,
      "seed": 307581555,
      "version": 6,
      "versionNonce": 1043308595,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773250790896,
      "link": null,
      "locked": false,
      "text": "Amit",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Amit",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4AIOcZk_NlCnlRSHcDSPZ",
      "type": "text",
      "x": 1355.7471395463417,
      "y": 39236.13966767791,
      "width": 1012,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ban",
      "roundness": null,
      "seed": 1097121213,
      "version": 367,
      "versionNonce": 559166973,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773251135826,
      "link": null,
      "locked": false,
      "text": "Hence cloud was already there in form of FOSS(Free and Open soure software), we just make it\nmore secure, more managable, once they are secure we start charging for that. Now we are not\ncharging for FOSS, we are charging because we are managing them.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Hence cloud was already there in form of FOSS(Free and Open soure software), we just make it\nmore secure, more managable, once they are secure we start charging for that. Now we are not\ncharging for FOSS, we are charging because we are managing them.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "jDVTWNXpzOsFKgngFxsPM",
      "type": "text",
      "x": 1355.3643270463417,
      "y": 39400.70607392791,
      "width": 1232,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bao",
      "roundness": null,
      "seed": 603101885,
      "version": 337,
      "versionNonce": 644920733,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773251376581,
      "link": null,
      "locked": false,
      "text": "task -> in AWS account create two VPCs VPC1, VPC2. Inside one VPC create a EC2 instance basically a VM instance,\nIn VPC2 again create a EC2, we need to communicate to these when both of them have a private IP. If they have\nPublic IP then they can communicate Easily.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "task -> in AWS account create two VPCs VPC1, VPC2. Inside one VPC create a EC2 instance basically a VM instance,\nIn VPC2 again create a EC2, we need to communicate to these when both of them have a private IP. If they have\nPublic IP then they can communicate Easily.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qEXJFOIlz6dYgCl75ovw0",
      "type": "text",
      "x": 1401.6182332963417,
      "y": 39489.78029267791,
      "width": 1166,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "baq",
      "roundness": null,
      "seed": 577483357,
      "version": 204,
      "versionNonce": 249072829,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773251471979,
      "link": null,
      "locked": false,
      "text": "we will establish a tunnel between these 2 EC2, VPC tunneling, and we need to make sure that EC2 instances\nare able to communicate even after having private IP.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "we will establish a tunnel between these 2 EC2, VPC tunneling, and we need to make sure that EC2 instances\nare able to communicate even after having private IP.",
      "autoResize": true,
      "lineHeight": 1.25
    },
