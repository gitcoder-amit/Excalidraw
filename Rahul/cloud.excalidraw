      "type": "text",
      "x": 1165.9021651528196,
      "y": 58889.270224584354,
      "width": 792,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
