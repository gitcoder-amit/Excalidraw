      "isDeleted": true,
      "boundElements": [],
      "updated": 1777685646399,
      "link": null,
      "locked": false,
      "text": "docker ps -> 0 containers\ndocker run -it ubuntu:latest\nhostname -i -> this will show container ip like 172.17.0.2\n\n",
