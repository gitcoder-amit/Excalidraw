    },
    {
      "id": "cj19vOa-3N8DlmyChfnGB",
      "type": "text",
      "x": 1481.842842671342,
      "y": 87583.31349580291,
      "width": 1001,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
