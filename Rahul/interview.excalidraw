      "updated": 1777685646399,
      "link": null,
      "locked": false,
      "text": "FROM node:18\nWORKDIR /usr/src/app\nCOPY package*.json ./\nRUN npm install\nCOPY ..\nRUN npm run build -> this will build node application using packages, source code, node and all\nEXPOSE 3000\nCMD [\"npm\",\"start\"]",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FROM node:18\nWORKDIR /usr/src/app\nCOPY package*.json ./\nRUN npm install\nCOPY ..\nRUN npm run build -> this will build node application using packages, source code, node and all\nEXPOSE 3000\nCMD [\"npm\",\"start\"]",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
