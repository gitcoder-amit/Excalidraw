    },
    {
      "id": "WCV4g41QNN66MvyGoOwiI",
      "type": "text",
      "x": 1078.801827046342,
      "y": 66001.98537080291,
      "width": 1023,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
