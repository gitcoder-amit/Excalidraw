    {
      "id": "9ga_sqK5Vp893nzHxOeR3",
      "type": "text",
      "x": 1516.545967671342,
      "y": 87793.01662080291,
      "width": 1100,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
