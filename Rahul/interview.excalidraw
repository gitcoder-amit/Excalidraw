      "link": null,
      "locked": false,
      "text": "So this is bridge kind of networking that Docker help us to setup.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "So this is bridge kind of networking that Docker help us to setup.",
