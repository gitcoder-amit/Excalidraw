      "isDeleted": true,
      "boundElements": [],
      "updated": 1777685646399,
      "link": null,
      "locked": false,
      "text": "Images are files that are use to create these process.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Images are files that are use to create these process.",
      "autoResize": true,
