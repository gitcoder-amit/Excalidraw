      "seed": 1625848691,
      "version": 479,
      "versionNonce": 166492242,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777685646399,
      "link": null,
      "locked": false,
      "text": "If we have to send a file to a diff system, what we usually do we tar them, we save them as tar files\nor zip files, to understand easily they are nothing but zip files. diff way of zip is also called as\ntar. if we have to create tar of a image, image is already a file\n\ndocker save -> save will take image input and generate the output as a tar file, this tar file can\nlater be send to other system or other people.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If we have to send a file to a diff system, what we usually do we tar them, we save them as tar files\nor zip files, to understand easily they are nothing but zip files. diff way of zip is also called as\ntar. if we have to create tar of a image, image is already a file\n\ndocker save -> save will take image input and generate the output as a tar file, this tar file can\nlater be send to other system or other people.",
      "autoResize": true,
      "lineHeight": 1.25
    },
