    },
    {
      "id": "qV8KrJIOgRIeo0uvrKCaJ",
      "type": "text",
      "x": 967.1006551713419,
      "y": 73502.73927705291,
      "width": 539,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkK",
      "roundness": null,
      "seed": 1905242261,
      "version": 56,
      "versionNonce": 1354963470,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777685646398,
      "link": null,
      "locked": false,
      "text": "How to take background container to foreground ->",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How to take background container to foreground ->",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "8R4tRZ-1wIdDshNFhpFWi",
      "type": "text",
      "x": 1025.409248921342,
      "y": 73545.59865205291,
      "width": 1133,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkL",
      "roundness": null,
      "seed": 1268557051,
      "version": 1077,
      "versionNonce": 1679676882,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777685646398,
      "link": null,
      "locked": false,
      "text": "There are two ways to do this\n1. exec -> exec is not exactly the way to bring the container in foreground, but there is a trick\n        which we can use over here.\n2. attach -> attach is actually a command which is used to bring container in foreground\n\ndocker exec -it myserver bash -> bash is a command that will give us a terminal that will going to\n        run untill we will stop that. So exec is just a way using which we can go inside the container\nand run our command then again back in base shell. this only allow to execute 1 command but bash itself\nallow us to run multiple commands.\n\nctrl + p +q -> exit from the container without terminating\n\ndocker attach myserver -> this will get this container into foreground.\n\nusing exec we can run a command it will go inside and will come out, we don't even need to give -it we \njust need to give command.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "There are two ways to do this\n1. exec -> exec is not exactly the way to bring the container in foreground, but there is a trick\n        which we can use over here.\n2. attach -> attach is actually a command which is used to bring container in foreground\n\ndocker exec -it myserver bash -> bash is a command that will give us a terminal that will going to\n        run untill we will stop that. So exec is just a way using which we can go inside the container\nand run our command then again back in base shell. this only allow to execute 1 command but bash itself\nallow us to run multiple commands.\n\nctrl + p +q -> exit from the container without terminating\n\ndocker attach myserver -> this will get this container into foreground.\n\nusing exec we can run a command it will go inside and will come out, we don't even need to give -it we \njust need to give command.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "vqY4uSw-gCAFn1_-tzg0H",
      "type": "text",
      "x": 948.4365926713419,
      "y": 74015.82130830291,
      "width": 1144,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkM",
      "roundness": null,
      "seed": 1689321237,
      "version": 237,
      "versionNonce": 1437640782,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777685646398,
      "link": null,
      "locked": false,
      "text": "docker logs -f myserver -> to see the logs\ndocker inspect myserver -> it gives metadata of the container, this will tell all the modifications done\n                    to make this container from any of the base image",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "docker logs -f myserver -> to see the logs\ndocker inspect myserver -> it gives metadata of the container, this will tell all the modifications done\n                    to make this container from any of the base image",
      "autoResize": true,
      "lineHeight": 1.25
    },
