    {
      "id": "FUzStm8LFU7jMxAr3_4I-",
      "type": "text",
      "x": 1251.045967671342,
      "y": 79250.61037080291,
      "width": 528,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
