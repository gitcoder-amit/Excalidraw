    {
      "id": "tT7s-0VqOrlVs5veWo_Pt",
      "type": "text",
      "x": 1471.362373921342,
      "y": 75041.62599580291,
      "width": 341,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
