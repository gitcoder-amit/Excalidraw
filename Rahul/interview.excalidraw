      "boundElements": [],
      "updated": 1777685646399,
      "link": null,
      "locked": false,
      "text": "docker run -idt ubuntu:latest\ndocker attach container_id or we can run directly in -it\napt update\napt install apache2 -y\nservice apache2 start\n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "docker run -idt ubuntu:latest\ndocker attach container_id or we can run directly in -it\napt update\napt install apache2 -y\nservice apache2 start\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "C4L48TUVKPXlGfDGP3tXT",
      "type": "text",
