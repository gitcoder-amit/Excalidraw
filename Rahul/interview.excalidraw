      "locked": false,
      "text": "How to create container from a tar file ->",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How to create container from a tar file ->",
