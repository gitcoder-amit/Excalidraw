      "updated": 1777685646399,
      "link": null,
      "locked": false,
      "text": "FROM python:3.9-slim\nWORKDIR /app \nCOPY ./app .\nRUN pip install flask\nEXPOSE 5000\nCMD [\"python\", \"app.py\"]",
      "fontSize": 20,
