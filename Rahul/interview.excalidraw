      "index": "bp0",
      "roundness": null,
      "seed": 1147167972,
      "version": 291,
      "versionNonce": 571521742,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777685646399,
      "link": null,
      "locked": false,
      "text": "First Image as builder image or stage\n\nFROM node:18 AS builder\nWORKDIR /usr/src/app\nCOPY package*.json ./\nRUN npm install\nCOPY ..\nRUN npm run build\n\n\nSecond Image\n\nFROM nginx:alpine -> if we want to use this next then we can use AS tester\nCOPY --from=builder /app/build /usr/share/nginx/html\nEXPOSE 80\nCMD [\"nginx\", \"-g\", \"daemon off;\"]",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "First Image as builder image or stage\n\nFROM node:18 AS builder\nWORKDIR /usr/src/app\nCOPY package*.json ./\nRUN npm install\nCOPY ..\nRUN npm run build\n\n\nSecond Image\n\nFROM nginx:alpine -> if we want to use this next then we can use AS tester\nCOPY --from=builder /app/build /usr/share/nginx/html\nEXPOSE 80\nCMD [\"nginx\", \"-g\", \"daemon off;\"]",
      "autoResize": true,
      "lineHeight": 1.25
    },
