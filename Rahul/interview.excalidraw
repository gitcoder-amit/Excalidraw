      "seed": 1792096105,
      "version": 285,
      "versionNonce": 1960673042,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777685646399,
      "link": null,
      "locked": false,
      "text": "If we are getting such lightweight infra, obviously we can expand our infra, we can expand our infra\nmeans we can run our infra over multiple systems like for same application now we are going to run\nmultiple containers but they are for same application",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If we are getting such lightweight infra, obviously we can expand our infra, we can expand our infra\nmeans we can run our infra over multiple systems like for same application now we are going to run\nmultiple containers but they are for same application",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "RpuROuJAVEbOZIWzxVbo4",
      "type": "text",
      "x": 1510.8059602516034,
      "y": 87920.55481321906,
      "width": 638,
      "height": 125,
