      "seed": 1557949321,
      "version": 336,
      "versionNonce": 122976594,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777685646399,
      "link": null,
      "locked": false,
      "text": "ip addr -> it will show network cards, one is for private  and lo is for localhost, after\n    installing docker we will have one more docker0, docker0 is the name of the bridge that\n    is going to connect us with the base and give the IP address to these containers.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ip addr -> it will show network cards, one is for private  and lo is for localhost, after\n    installing docker we will have one more docker0, docker0 is the name of the bridge that\n    is going to connect us with the base and give the IP address to these containers.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "jrxBoISMC65VYAkvKiENT",
      "type": "text",
      "x": 1474.694405171342,
      "y": 87753.27443330291,
