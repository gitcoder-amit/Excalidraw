      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bln",
      "roundness": null,
      "seed": 72690349,
      "version": 151,
      "versionNonce": 886150354,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777685646399,
      "link": null,
      "locked": false,
      "text": "FROM ubuntu:latest\nRUN apt-get update\nRUN apt-get install -y apache2\nEXPOSE 80\nCMD service apache2 start",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FROM ubuntu:latest\nRUN apt-get update\nRUN apt-get install -y apache2\nEXPOSE 80\nCMD service apache2 start",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "t8Agp8e0fNeHrJa9HN0pa",
      "type": "text",
      "x": 2001.0772176713417,
      "y": 83040.51662080291,
      "width": 308,
      "height": 225,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
