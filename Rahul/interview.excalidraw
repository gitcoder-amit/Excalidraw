    {
      "id": "z5aHQy-Y507LgcTd5W7oy",
      "type": "text",
      "x": 1629.644818007995,
      "y": 96655.28104196498,
      "width": 814,
      "height": 400,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
