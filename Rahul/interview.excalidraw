    {
      "id": "3sEayrHoF4LEEmW2tyiHf",
      "type": "text",
      "x": 1495.7920614213417,
      "y": 83065.43068330291,
      "width": 330,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
