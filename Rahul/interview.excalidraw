    {
      "id": "shTl9v1LcATISlPhERaZW",
      "type": "text",
      "x": 1463.889717671342,
      "y": 74800.67287080291,
      "width": 880,
      "height": 200,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
