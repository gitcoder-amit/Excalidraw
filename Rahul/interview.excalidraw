    {
      "id": "PcKve0W1EsHSOX07LmIyB",
      "type": "text",
      "x": 1301.358467671342,
      "y": 88094.43068330291,
      "width": 143,
      "height": 50,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
