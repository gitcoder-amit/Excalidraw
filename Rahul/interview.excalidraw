    },
    {
      "id": "sjQrypPvMs10wGaL5sEEW",
      "type": "text",
      "x": 1053.102608296342,
      "y": 67306.42287080291,
      "width": 506,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
