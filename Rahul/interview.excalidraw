      "seed": 642166363,
      "version": 80,
      "versionNonce": 1200138258,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777685646398,
      "link": null,
      "locked": false,
      "text": "docker run --name myserver -dit ubuntu:latest",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "docker run --name myserver -dit ubuntu:latest",
      "autoResize": true,
