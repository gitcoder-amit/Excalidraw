      "lineHeight": 1.25
    },
    {
      "id": "EJHI5VZ7GhVjkQxtWGcld",
      "type": "text",
      "x": 1618.3545708066883,
      "y": 90350.45264890087,
      "width": 1001,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
