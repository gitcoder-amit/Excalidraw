      "isDeleted": false,
      "boundElements": [],
      "updated": 1775229322808,
      "link": null,
      "locked": false,
      "text": "What is the parent class of everything here?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What is the parent class of everything here?",
