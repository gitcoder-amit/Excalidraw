    },
    {
      "id": "lLPjLSsEDxOzVswyWBG2M",
      "type": "text",
      "x": 2073.2911422125817,
      "y": 7254.628136461251,
      "width": 1067,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFa",
      "roundness": null,
      "seed": 213945267,
      "version": 594,
      "versionNonce": 280100669,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775229584095,
      "link": null,
      "locked": false,
      "text": "Parent class is AI, AI is the word that is used for many things, AI is used for if we are doing\nautomation its AI, If we are doing Maching Learning its AI, If we are doing NLP its AI, If we are\ndoing Deep Learning, If we are working on LLMs, they all are part of AI, SO this whole domain is\nAI.\nSmalled domain is ML, we will learn later.\nML can do two things\n    Classify\n    Predict, these are only two things that ML can do.\n\nAfter this also world is rushing behind Machine Learning.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Parent class is AI, AI is the word that is used for many things, AI is used for if we are doing\nautomation its AI, If we are doing Maching Learning its AI, If we are doing NLP its AI, If we are\ndoing Deep Learning, If we are working on LLMs, they all are part of AI, SO this whole domain is\nAI.\nSmalled domain is ML, we will learn later.\nML can do two things\n    Classify\n    Predict, these are only two things that ML can do.\n\nAfter this also world is rushing behind Machine Learning.",
      "autoResize": true,
      "lineHeight": 1.25
    },
