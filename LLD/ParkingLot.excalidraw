      "seed": 392944961,
      "version": 181,
      "versionNonce": 1972030047,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770732835561,
      "link": null,
      "locked": false,
      "text": "class EntryGate:\n    def __init__(self, gate_id, parking_lot):\n        self.gate_id = gate_id\n        self.parking_lot = parking_lot\n\n    def enter_vehicle(self, vehicle):\n        spot = self.parking_lot.find_spot(vehicle)\n        if not spot:\n            raise Exception(\"Parking Full\")\n\n        spot.park_vehicle(vehicle)\n        ticket = ParkingTicket(vehicle, spot)\n        return ticket",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class EntryGate:\n    def __init__(self, gate_id, parking_lot):\n        self.gate_id = gate_id\n        self.parking_lot = parking_lot\n\n    def enter_vehicle(self, vehicle):\n        spot = self.parking_lot.find_spot(vehicle)\n        if not spot:\n            raise Exception(\"Parking Full\")\n\n        spot.park_vehicle(vehicle)\n        ticket = ParkingTicket(vehicle, spot)\n        return ticket",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "-vJ8lL7ZUFy-sxlWKJ6w4",
      "type": "text",
      "x": 1602.9780117343073,
      "y": 18711.083176771248,
      "width": 2098.799072265625,
      "height": 630,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bGu",
      "roundness": null,
      "seed": 162010849,
      "version": 256,
      "versionNonce": 728894815,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770732826161,
      "link": null,
      "locked": false,
      "text": "class ExitGate:\n    def __init__(self, gate_id, pricing_strategy):\n        self.gate_id = gate_id\n        self.pricing_strategy = pricing_strategy\n\n    def exit_vehicle(self, ticket, payment_method):\n        ticket.close_ticket()\n        ticket.spot.remove_vehicle()\n\n        invoice = Invoice(ticket, self.pricing_strategy)\n        payment = Payment(invoice, payment_method).      \n        payment.make_payment().   # if payment will not success we will hold that in gate write logic here\n\n        return invoice, payment",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class ExitGate:\n    def __init__(self, gate_id, pricing_strategy):\n        self.gate_id = gate_id\n        self.pricing_strategy = pricing_strategy\n\n    def exit_vehicle(self, ticket, payment_method):\n        ticket.close_ticket()\n        ticket.spot.remove_vehicle()\n\n        invoice = Invoice(ticket, self.pricing_strategy)\n        payment = Payment(invoice, payment_method).      \n        payment.make_payment().   # if payment will not success we will hold that in gate write logic here\n\n        return invoice, payment",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Wo2CJRFvsfkYBSasfQG8W",
      "type": "text",
      "x": 1674.6860756740325,
      "y": 20138.11168743292,
      "width": 1286.999267578125,
      "height": 1395,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bGv",
      "roundness": null,
      "seed": 1355528737,
      "version": 78,
      "versionNonce": 1726198065,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770732822909,
      "link": null,
      "locked": false,
      "text": "import uuid\n\nclass Invoice:\n    def __init__(self, ticket, pricing_strategy):\n        self.invoice_id = str(uuid.uuid4())\n        self.ticket = ticket\n        self.amount = pricing_strategy.calculate_price(ticket)\n        self.generated_at = time.time()\n\n    def get_invoice_details(self):\n        return {\n            \"invoice_id\": self.invoice_id,\n            \"ticket_id\": self.ticket.ticket_id,\n            \"vehicle_number\": self.ticket.vehicle.vehicle_number,\n            \"amount\": self.amount,\n            \"entry_time\": self.ticket.entry_time,\n            \"exit_time\": self.ticket.exit_time\n        }\n\nimport time\n\nclass PricingStrategy:\n    def calculate_price(self, ticket):\n        raise NotImplementedError\n\n\nclass HourlyPricingStrategy(PricingStrategy):\n    def calculate_price(self, ticket):\n        duration = ticket.exit_time - ticket.entry_time\n        hours = max(1, int(duration // 3600))\n        return hours * 50   # ₹50 per hour",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "import uuid\n\nclass Invoice:\n    def __init__(self, ticket, pricing_strategy):\n        self.invoice_id = str(uuid.uuid4())\n        self.ticket = ticket\n        self.amount = pricing_strategy.calculate_price(ticket)\n        self.generated_at = time.time()\n\n    def get_invoice_details(self):\n        return {\n            \"invoice_id\": self.invoice_id,\n            \"ticket_id\": self.ticket.ticket_id,\n            \"vehicle_number\": self.ticket.vehicle.vehicle_number,\n            \"amount\": self.amount,\n            \"entry_time\": self.ticket.entry_time,\n            \"exit_time\": self.ticket.exit_time\n        }\n\nimport time\n\nclass PricingStrategy:\n    def calculate_price(self, ticket):\n        raise NotImplementedError\n\n\nclass HourlyPricingStrategy(PricingStrategy):\n    def calculate_price(self, ticket):\n        duration = ticket.exit_time - ticket.entry_time\n        hours = max(1, int(duration // 3600))\n        return hours * 50   # ₹50 per hour",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "R4LAs3vqb0aZI_cMvy9QS",
      "type": "text",
      "x": 1631.1818210327033,
      "y": 16814.094275516865,
      "width": 475.19970703125,
      "height": 450,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bGy",
