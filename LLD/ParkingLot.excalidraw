      "text": "import uuid\nimport time\n\nclass Payment:\n    def __init__(self, invoice, payment_method):\n        self.payment_id = str(uuid.uuid4())\n        self.invoice = invoice\n        self.amount = invoice.amount\n        self.payment_method = payment_method\n        self.status = PaymentStatus.PENDING\n        self.paid_at = None\n\n    def make_payment(self):\n        success = self.payment_method.pay(self.amount)\n        if success:\n            self.status = PaymentStatus.SUCCESS\n            self.paid_at = time.time()\n        else:\n            self.status = PaymentStatus.FAILED\n\n        return self.status",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "import uuid\nimport time\n\nclass Payment:\n    def __init__(self, invoice, payment_method):\n        self.payment_id = str(uuid.uuid4())\n        self.invoice = invoice\n        self.amount = invoice.amount\n        self.payment_method = payment_method\n        self.status = PaymentStatus.PENDING\n        self.paid_at = None\n\n    def make_payment(self):\n        success = self.payment_method.pay(self.amount)\n        if success:\n            self.status = PaymentStatus.SUCCESS\n            self.paid_at = time.time()\n        else:\n            self.status = PaymentStatus.FAILED\n\n        return self.status",
      "autoResize": true,
      "lineHeight": 1.25
    },
