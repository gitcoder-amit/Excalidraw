      "boundElements": [],
      "updated": 1770732809845,
      "link": null,
      "locked": false,
      "text": "class PaymentStatus:\n    PENDING = \"PENDING\"\n    SUCCESS = \"SUCCESS\"\n    FAILED = \"FAILED\"",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class PaymentStatus:\n    PENDING = \"PENDING\"\n    SUCCESS = \"SUCCESS\"\n    FAILED = \"FAILED\"",
      "autoResize": true,
      "lineHeight": 1.25
