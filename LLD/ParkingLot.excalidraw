    {
      "id": "ubAgJaplnc-aUHY-Hn4N4",
      "type": "text",
      "x": 1714.7636327501068,
      "y": 11960.807533884132,
      "width": 1326.59912109375,
      "height": 585,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bGW",
      "roundness": null,
      "seed": 2012820655,
      "version": 650,
      "versionNonce": 1476753585,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770732306830,
      "link": null,
      "locked": false,
      "text": "class ParkingLot:\n    def __init__(self):\n        self.levels = []\n\n    def add_level(self, level):\n        self.levels.append(level)\n\n    def find_spot(self, vehicle):  # or we can name as park_vehicle\n        for level in self.levels:\n            spot = level.get_available_spot(vehicle)\n            if spot:\n                return spot\n        return None",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class ParkingLot:\n    def __init__(self):\n        self.levels = []\n\n    def add_level(self, level):\n        self.levels.append(level)\n\n    def find_spot(self, vehicle):  # or we can name as park_vehicle\n        for level in self.levels:\n            spot = level.get_available_spot(vehicle)\n            if spot:\n                return spot\n        return None",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4bcaQM-sINJCZseOPo10l",
      "type": "text",
      "x": 1609.8457889082824,
      "y": 12676.588908249576,
      "width": 1370.2213574597872,
      "height": 1808.2109375000011,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bGf",
      "roundness": null,
      "seed": 542322415,
      "version": 727,
      "versionNonce": 151018623,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770733116589,
      "link": null,
      "locked": false,
      "text": "class Level:\n    def __init__(self, level_number):\n        self.level_number = level_number\n        self.spots = []\n\n    def add_spot(self, spot):\n        self.spots.append(spot)\n\n    def get_available_slot(self):\n        for spot in self.spots:\n            if spot.is_free():\n                return spot\n\n        return None\n\n\nclass ParkingSpot:\n    def __init__(self, spot_id, spot_type):\n        self.spot_id = spot_id          # unique id\n        self.spot_type = spot_type      # CAR / BIKE / TRUCK\n        self.vehicle = None             # no vehicle initially\n        self.is_occupied = False\n\n    def is_free(self):\n        return not self.is_occupied\n\n    def park_vehicle(self, vehicle):\n        if self.is_occupied:\n            return False\n        self.vehicle = vehicle\n        self.is_occupied = True\n        return True\n\n    def remove_vehicle(self):\n        self.vehicle = None\n        self.is_occupied = False",
      "fontSize": 40.182465277777794,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class Level:\n    def __init__(self, level_number):\n        self.level_number = level_number\n        self.spots = []\n\n    def add_spot(self, spot):\n        self.spots.append(spot)\n\n    def get_available_slot(self):\n        for spot in self.spots:\n            if spot.is_free():\n                return spot\n\n        return None\n\n\nclass ParkingSpot:\n    def __init__(self, spot_id, spot_type):\n        self.spot_id = spot_id          # unique id\n        self.spot_type = spot_type      # CAR / BIKE / TRUCK\n        self.vehicle = None             # no vehicle initially\n        self.is_occupied = False\n\n    def is_free(self):\n        return not self.is_occupied\n\n    def park_vehicle(self, vehicle):\n        if self.is_occupied:\n            return False\n        self.vehicle = vehicle\n        self.is_occupied = True\n        return True\n\n    def remove_vehicle(self):\n        self.vehicle = None\n        self.is_occupied = False",
      "autoResize": true,
      "lineHeight": 1.25
    },
