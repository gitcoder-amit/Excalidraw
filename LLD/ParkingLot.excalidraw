    {
      "id": "9mxwSwrEy6hEEw4otIcJ_",
      "type": "text",
      "x": 1614.4552290826114,
      "y": 17579.72836567051,
      "width": 990.5435760475165,
      "height": 585,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
