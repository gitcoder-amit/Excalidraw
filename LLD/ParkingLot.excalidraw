      "link": null,
      "locked": false,
      "text": "class PaymentMethod:\n    def pay(self, amount):\n        raise NotImplementedError\n\n\nclass CashPayment(PaymentMethod):\n    def pay(self, amount):\n        print(f\"Paid ₹{amount} by cash\")\n        return True\n\n\nclass CardPayment(PaymentMethod):\n    def pay(self, amount):\n        print(f\"Paid ₹{amount} by card\")\n        return True\n\n\nclass UPIPayment(PaymentMethod):\n    def pay(self, amount):\n        print(f\"Paid ₹{amount} via UPI\")\n        return True\n\n\n👉 Strategy pattern\n👉 New payment modes = no changes to existing code",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class PaymentMethod:\n    def pay(self, amount):\n        raise NotImplementedError\n\n\nclass CashPayment(PaymentMethod):\n    def pay(self, amount):\n        print(f\"Paid ₹{amount} by cash\")\n        return True\n\n\nclass CardPayment(PaymentMethod):\n    def pay(self, amount):\n        print(f\"Paid ₹{amount} by card\")\n        return True\n\n\nclass UPIPayment(PaymentMethod):\n    def pay(self, amount):\n        print(f\"Paid ₹{amount} via UPI\")\n        return True\n\n\n👉 Strategy pattern\n👉 New payment modes = no changes to existing code",
      "autoResize": true,
      "lineHeight": 1.25
    },
