      "updated": 1770733118109,
      "link": null,
      "locked": false,
      "text": "class Vehicle:\n    def __init__(self, vehicle_number, vehicle_type):\n        self.vehicle_number = vehicle_numbe\n        self.vehicle_type = vehicle_type\n\n    def get_vehicle(self):\n        return self.vehicle",
