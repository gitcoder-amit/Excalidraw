      "updated": 1770733625062,
      "link": null,
      "locked": false,
      "text": "Demo\n\n🎯 Goal of Demo\n\nSimulate:\nVehicle enters\nTicket is generated\nVehicle exits\nInvoice is generated\nPayment is done\n\n\n\nimport time\n\nclass Demo:\n    @staticmethod\n    def run():\n        # ---- Setup ----\n        pricing_strategy = HourlyPricingStrategy()\n        parkinglot = ParkingLot()\n        entry_gate = EntryGate(gate_id=1, parking_lot)\n        exit_gate = ExitGate(gate_id=1, pricing_strategy=pricing_strategy)\n\n        # Create parking spot\n        spot = ParkingSpot(spot_id=101, spot_type=\"CAR\")\n\n        # Vehicle arrives\n        vehicle = Vehicle(vehicle_number=\"KA-01-AB-1234\", vehicle_type=\"CAR\")\n\n        print(\"\\n--- Vehicle Enters ---\")\n        ticket = entry_gate.generate_ticket(vehicle)\n        print(f\"Ticket Generated: {ticket.ticket_id}\")\n\n        # Simulate parking duration\n        time.sleep(2)  # demo purpose\n        ticket.exit_time = time.time()\n\n        print(\"\\n--- Vehicle Exits ---\")\n        payment_method = UPIPayment()\n        invoice, payment = exit_gate.exit_vehicle(ticket, payment_method)\n\n        print(\"\\n--- Invoice Details ---\")\n        print(invoice.get_invoice_details())\n\n        print(\"\\n--- Payment Status ---\")\n        print(f\"Payment Status: {payment.status}\")",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Demo\n\n🎯 Goal of Demo\n\nSimulate:\nVehicle enters\nTicket is generated\nVehicle exits\nInvoice is generated\nPayment is done\n\n\n\nimport time\n\nclass Demo:\n    @staticmethod\n    def run():\n        # ---- Setup ----\n        pricing_strategy = HourlyPricingStrategy()\n        parkinglot = ParkingLot()\n        entry_gate = EntryGate(gate_id=1, parking_lot)\n        exit_gate = ExitGate(gate_id=1, pricing_strategy=pricing_strategy)\n\n        # Create parking spot\n        spot = ParkingSpot(spot_id=101, spot_type=\"CAR\")\n\n        # Vehicle arrives\n        vehicle = Vehicle(vehicle_number=\"KA-01-AB-1234\", vehicle_type=\"CAR\")\n\n        print(\"\\n--- Vehicle Enters ---\")\n        ticket = entry_gate.generate_ticket(vehicle)\n        print(f\"Ticket Generated: {ticket.ticket_id}\")\n\n        # Simulate parking duration\n        time.sleep(2)  # demo purpose\n        ticket.exit_time = time.time()\n\n        print(\"\\n--- Vehicle Exits ---\")\n        payment_method = UPIPayment()\n        invoice, payment = exit_gate.exit_vehicle(ticket, payment_method)\n\n        print(\"\\n--- Invoice Details ---\")\n        print(invoice.get_invoice_details())\n\n        print(\"\\n--- Payment Status ---\")\n        print(f\"Payment Status: {payment.status}\")",
      "autoResize": true,
      "lineHeight": 1.25
    },
