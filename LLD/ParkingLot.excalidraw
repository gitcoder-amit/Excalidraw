      "boundElements": [],
      "updated": 1770732989960,
      "link": null,
      "locked": false,
      "text": "class VehicleType(Enum):\n    MOTORCYCLE = 1\n    CAR = 2\n    TRUCK = 3\n\n\nclass SpotType(Enum):\n    MOTORCYCLE = 1\n    CAR = 2\n    TRUCK = 3",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class VehicleType(Enum):\n    MOTORCYCLE = 1\n    CAR = 2\n    TRUCK = 3\n\n\nclass SpotType(Enum):\n    MOTORCYCLE = 1\n    CAR = 2\n    TRUCK = 3",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "6v_RnJ1lyi7IfVUT1I1pA",
      "type": "text",
      "x": 1673.1472444212425,
      "y": 22074.905367098385,
      "width": 989.9993896484375,
      "height": 900,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
