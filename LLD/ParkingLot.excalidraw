      "text": "from datetime import datetime\nfrom enum import Enum\nimport uuid\n\n\nclass TicketStatus(Enum):\n    ACTIVE = \"ACTIVE\"\n    CLOSED = \"CLOSED\"\n\n\nclass ParkingTicket:\n    def __init__(self, spot, vehicle):\n        self.ticket_id = str(uuid.uuid4())   # unique ticket id\n        self.spot = spot                     # ParkingSpot object\n        self.vehicle = vehicle               # Vehicle object\n        self.entry_time = datetime.now()\n        self.exit_time = None\n        self.status = TicketStatus.ACTIVE\n\n    def close_ticket(self):\n        self.exit_time = datetime.now()\n        self.status = TicketStatus.CLOSED",
      "fontSize": 40.601562499999986,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "from datetime import datetime\nfrom enum import Enum\nimport uuid\n\n\nclass TicketStatus(Enum):\n    ACTIVE = \"ACTIVE\"\n    CLOSED = \"CLOSED\"\n\n\nclass ParkingTicket:\n    def __init__(self, spot, vehicle):\n        self.ticket_id = str(uuid.uuid4())   # unique ticket id\n        self.spot = spot                     # ParkingSpot object\n        self.vehicle = vehicle               # Vehicle object\n        self.entry_time = datetime.now()\n        self.exit_time = None\n        self.status = TicketStatus.ACTIVE\n\n    def close_ticket(self):\n        self.exit_time = datetime.now()\n        self.status = TicketStatus.CLOSED",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
