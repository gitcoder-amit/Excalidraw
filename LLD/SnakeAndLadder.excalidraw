      "link": null,
      "locked": false,
      "text": "Player -> id, Name, current_position, piece_id(fk)\n          \nPiece -> id, color\n\nDice -> id, min, max\n        roll()\n\nCell -> id, jump(need to check), board_id(fk)\n        \nBoard -> cells[](need to check), size\n        initialize_board()\n\nJump -> start, end\n\nGame -> board_id(FK), dice_id(FK), player(Many to Many), winner_id\n        startGame(), playTurn(), checkWinner(), switchTurn\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Player -> id, Name, current_position, piece_id(fk)\n          \nPiece -> id, color\n\nDice -> id, min, max\n        roll()\n\nCell -> id, jump(need to check), board_id(fk)\n        \nBoard -> cells[](need to check), size\n        initialize_board()\n\nJump -> start, end\n\nGame -> board_id(FK), dice_id(FK), player(Many to Many), winner_id\n        startGame(), playTurn(), checkWinner(), switchTurn\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
