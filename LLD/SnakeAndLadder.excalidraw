      "boundElements": [],
      "updated": 1770822400071,
      "link": null,
      "locked": false,
      "text": "1 Game initializes board (size 100, snakes & ladders added)\n2 Players are registered\n3 Each player selects a piece\n4 Game starts\n5 Current player rolls dice\n6 Player moves forward by dice value\n7 If landed on snake/ladder → apply jump\n8 If position > 100 → move not allowed\n9 If position == 100 → player wins\n10 Switch turn to next player\n11 Repeat until someone wins",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1 Game initializes board (size 100, snakes & ladders added)\n2 Players are registered\n3 Each player selects a piece\n4 Game starts\n5 Current player rolls dice\n6 Player moves forward by dice value\n7 If landed on snake/ladder → apply jump\n8 If position > 100 → move not allowed\n9 If position == 100 → player wins\n10 Switch turn to next player\n11 Repeat until someone wins",
      "autoResize": true,
      "lineHeight": 1.25
    },
