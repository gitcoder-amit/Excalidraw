      "index": "b48",
      "roundness": null,
      "seed": 1452229520,
      "version": 142,
      "versionNonce": 279582576,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761946806837,
      "link": null,
      "locked": false,
      "text": "Bring it up in deep dives when talking about scaling. But justify! \n\n1. Storage\n2. Write throughput\n3. Read throughput",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Bring it up in deep dives when talking about scaling. But justify! \n\n1. Storage\n2. Write throughput\n3. Read throughput",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "kT0shHVz8soFHlhEiTMPZ",
      "type": "text",
      "x": 872.4980508967801,
      "y": 16603.717316926573,
      "width": 457.599365234375,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b49",
      "roundness": null,
      "seed": 1527141776,
      "version": 53,
      "versionNonce": 876651408,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761946776277,
      "link": null,
      "locked": false,
      "text": "What do you say? \n\n1. Propose a shard key based on your access patterns\n2. Choose your distribution strategy \n3. Call out the trade-offs\n4. Address how you'll handle growth\n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What do you say? \n\n1. Propose a shard key based on your access patterns\n2. Choose your distribution strategy \n3. Call out the trade-offs\n4. Address how you'll handle growth\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
