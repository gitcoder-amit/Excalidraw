    {
      "id": "0J5Z9RZjpWaRGU38gEPp7",
      "type": "text",
      "x": 1667.760187131307,
      "y": 15650.195950732601,
      "width": 275,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3n",
      "roundness": null,
      "seed": 320087952,
      "version": 76,
      "versionNonce": 1508378512,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1761945570826,
      "link": null,
      "locked": false,
      "text": "BEGIN;\n\nUPDATE accounts\nSET balance = balance - 5\nWHERE name = 'Bob';\n\nUPDATE accounts\nSET balance = balance + 5\nWHERE name = 'Alice';\n\nCOMMIT;\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "BEGIN;\n\nUPDATE accounts\nSET balance = balance - 5\nWHERE name = 'Bob';\n\nUPDATE accounts\nSET balance = balance + 5\nWHERE name = 'Alice';\n\nCOMMIT;\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
