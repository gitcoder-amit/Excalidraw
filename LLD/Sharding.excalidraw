    {
      "id": "TB_xode1aNRE_3_WydZdM",
      "type": "text",
      "x": 863.410912436807,
      "y": 16398.69918641765,
      "width": 589.5991821289062,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
