    {
      "id": "-8cY5rWaRTUey2ELG6h9R",
      "type": "text",
      "x": 1703.4994666679863,
      "y": 11584.788791959669,
      "width": 19.79998779296875,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#d0bfff",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bEF",
      "roundness": null,
      "seed": 1513627971,
      "version": 3,
      "versionNonce": 1320313891,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1770042666753,
      "link": null,
      "locked": false,
      "text": "",
      "fontSize": 36,
      "fontFamily": 8,
