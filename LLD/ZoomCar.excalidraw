    {
      "id": "F29dOqthlmtDEAYKwVgk8",
      "type": "text",
      "x": 1000.1546561548776,
      "y": 41707.46305443043,
      "width": 803,
      "height": 4050,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
