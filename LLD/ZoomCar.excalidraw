      "boundElements": [],
      "updated": 1775707748533,
      "link": null,
      "locked": false,
      "text": "class Song:\n    def __init__(self, id, title, artist, duration):\n        self.id = id\n        self.title = title\n        self.artist = artist\n        self.duration = duration\n\n    def __str__(self):\n        return self.title\n\n\nclass User:\n    def __init__(self, id, name):\n        self.id = id\n        self.name = name\n        self.playlists = []\n        self.liked_songs = set()\n\n\nclass Playlist:\n    def __init__(self, id, name):\n        self.id = id\n        self.name = name\n        self.songs = []\n\n    def add_song(self, song):\n        self.songs.append(song)\n\n    def remove_song(self, song):\n        self.songs.remove(song)\n\n\nQueue (Core Component)\nclass PlayQueue:\n    def __init__(self):\n        self.queue = []\n\n    def add_song(self, song):\n        self.queue.append(song)\n\n    def get_next_song(self):\n        if self.queue:\n            return self.queue.pop(0)\n        return None\n\n\n\nclass MusicPlayer:\n    def __init__(self):\n        self.queue = PlayQueue()\n        self.current_song = None\n        self.is_playing = False\n\n    def play(self):\n        if not self.current_song:\n            self.current_song = self.queue.get_next_song()\n\n        if self.current_song:\n            self.is_playing = True\n            print(f\"Playing: {self.current_song}\")\n        else:\n            print(\"No songs in queue\")\n\n    def pause(self):\n        self.is_playing = False\n        print(\"Paused\")\n\n    def resume(self):\n        if self.current_song:\n            self.is_playing = True\n            print(f\"Resumed: {self.current_song}\")\n\n    def skip(self):\n        print(\"Skipping...\")\n        self.current_song = self.queue.get_next_song()\n        self.play()\n\n\n\nMusic System (Controller)\n\nclass MusicSystem:\n    def __init__(self):\n        self.users = {}\n        self.songs = {}\n        self.player = MusicPlayer()\n\n    def add_song(self, song):\n        self.songs[song.id] = song\n\n    def register_user(self, user):\n        self.users[user.id] = user\n\n    def search_song(self, keyword):\n        return [s for s in self.songs.values() if keyword.lower() in s.title.lower()]\n\n    def play_song(self, song_id):\n        song = self.songs.get(song_id)\n        if not song:\n            print(\"Song not found\")\n            return\n        \n        self.player.queue.add_song(song)\n        self.player.play()\n\n    def like_song(self, user, song):\n        user.liked_songs.add(song)\n        print(f\"{user.name} liked {song}\")\n\n\n\nExample Execution\n\nsystem = MusicSystem()\n\n# Add songs\ns1 = Song(1, \"Shape of You\", \"Ed Sheeran\", 240)\ns2 = Song(2, \"Believer\", \"Imagine Dragons\", 210)\n\nsystem.add_song(s1)\nsystem.add_song(s2)\n\n# Register user\nuser = User(1, \"Amit\")\nsystem.register_user(user)\n\n# Search\nprint(system.search_song(\"shape\"))\n\n# Play song\nsystem.play_song(1)\n\n# Add another song\nsystem.player.queue.add_song(s2)\n\n# Skip\nsystem.player.skip()\n\n# Like song\nsystem.like_song(user, s2)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class Song:\n    def __init__(self, id, title, artist, duration):\n        self.id = id\n        self.title = title\n        self.artist = artist\n        self.duration = duration\n\n    def __str__(self):\n        return self.title\n\n\nclass User:\n    def __init__(self, id, name):\n        self.id = id\n        self.name = name\n        self.playlists = []\n        self.liked_songs = set()\n\n\nclass Playlist:\n    def __init__(self, id, name):\n        self.id = id\n        self.name = name\n        self.songs = []\n\n    def add_song(self, song):\n        self.songs.append(song)\n\n    def remove_song(self, song):\n        self.songs.remove(song)\n\n\nQueue (Core Component)\nclass PlayQueue:\n    def __init__(self):\n        self.queue = []\n\n    def add_song(self, song):\n        self.queue.append(song)\n\n    def get_next_song(self):\n        if self.queue:\n            return self.queue.pop(0)\n        return None\n\n\n\nclass MusicPlayer:\n    def __init__(self):\n        self.queue = PlayQueue()\n        self.current_song = None\n        self.is_playing = False\n\n    def play(self):\n        if not self.current_song:\n            self.current_song = self.queue.get_next_song()\n\n        if self.current_song:\n            self.is_playing = True\n            print(f\"Playing: {self.current_song}\")\n        else:\n            print(\"No songs in queue\")\n\n    def pause(self):\n        self.is_playing = False\n        print(\"Paused\")\n\n    def resume(self):\n        if self.current_song:\n            self.is_playing = True\n            print(f\"Resumed: {self.current_song}\")\n\n    def skip(self):\n        print(\"Skipping...\")\n        self.current_song = self.queue.get_next_song()\n        self.play()\n\n\n\nMusic System (Controller)\n\nclass MusicSystem:\n    def __init__(self):\n        self.users = {}\n        self.songs = {}\n        self.player = MusicPlayer()\n\n    def add_song(self, song):\n        self.songs[song.id] = song\n\n    def register_user(self, user):\n        self.users[user.id] = user\n\n    def search_song(self, keyword):\n        return [s for s in self.songs.values() if keyword.lower() in s.title.lower()]\n\n    def play_song(self, song_id):\n        song = self.songs.get(song_id)\n        if not song:\n            print(\"Song not found\")\n            return\n        \n        self.player.queue.add_song(song)\n        self.player.play()\n\n    def like_song(self, user, song):\n        user.liked_songs.add(song)\n        print(f\"{user.name} liked {song}\")\n\n\n\nExample Execution\n\nsystem = MusicSystem()\n\n# Add songs\ns1 = Song(1, \"Shape of You\", \"Ed Sheeran\", 240)\ns2 = Song(2, \"Believer\", \"Imagine Dragons\", 210)\n\nsystem.add_song(s1)\nsystem.add_song(s2)\n\n# Register user\nuser = User(1, \"Amit\")\nsystem.register_user(user)\n\n# Search\nprint(system.search_song(\"shape\"))\n\n# Play song\nsystem.play_song(1)\n\n# Add another song\nsystem.player.queue.add_song(s2)\n\n# Skip\nsystem.player.skip()\n\n# Like song\nsystem.like_song(user, s2)",
      "autoResize": true,
      "lineHeight": 1.25
    },
