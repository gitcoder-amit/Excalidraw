      "updated": 1776052198360,
      "link": null,
      "locked": false,
      "text": "class RentalSystem:\n    def __init__(self):\n        self.stores = []\n\n    def add_store(self, store):\n        self.stores.append(store)\n\n    def search_vehicle(self, location):\n        available_vehicles = []\n        for store in self.stores:\n            if store.location == location:\n                available_vehicles.extend(store.get_available_vehicles())\n        return available_vehicles\n\n    def reserve_vehicle(self, vehicle):\n        vehicle.reserve()\n\n    def release_vehicle(self, vehicle):\n        vehicle.release()\n\n\n\nclass Store:\n    def __init__(self, location):\n        self.location = location\n        self.vehicles = []\n\n    def add_vehicle(self, vehicle):\n        self.vehicles.append(vehicle)\n\n    def get_available_vehicles(self):\n        return [v for v in self.vehicles if v.is_available]\n\n\nclass Vehicle:\n    def __init__(self, vehicle_id, price_per_hour):\n        self.vehicle_id = vehicle_id\n        self.is_available = True\n\n    def reserve(self):\n        self.is_available = False\n\n    def release(self):\n        self.is_available = True\n\nclass User:\n    def __init__(self, user_id, name):\n        self.user_id = user_id\n        self.name = name\n\n\nfrom datetime import datetime\n\nclass Booking:\n    def __init__(self, user, vehicle):\n        self.booking_id = str(uuid.uuid4())\n        self.user = user\n        self.vehicle = vehicle\n        self.start_time = None\n        self.end_time = None\n        self.status = \"CREATED\"\n\n    def start_trip(self):\n        self.start_time = datetime.now()\n        self.status = \"ONGOING\"\n\n    def end_trip(self):\n        self.end_time = datetime.now()\n        self.status = \"COMPLETED\"\n        self.vehicle.release()\n\nimport uuid\n\nclass Invoice:\n    def __init__(self, booking, pricing_strategy):\n        self.invoice_id = str(uuid.uuid4())\n        self.ticket = booking\n        self.amount = pricing_strategy.calculate_price(ticket)\n        self.generated_at = time.time()\n\n    def get_invoice_details(self):\n        return {\n            \"invoice_id\": self.invoice_id,\n            \"booking_id\": self.booking.ticket_id,\n            \"vehicle_number\": self.ticket.vehicle.vehicle_number,\n            \"amount\": self.amount,\n            \"entry_time\": self.ticket.entry_time,\n            \"exit_time\": self.ticket.exit_time\n        }\n\nimport time\n\nclass PricingStrategy:\n    def calculate_price(self, ticket):\n        raise NotImplementedError\n\n\nclass HourlyPricingStrategy(PricingStrategy):\n    def calculate_price(self, ticket):\n        duration = ticket.exit_time - ticket.entry_time\n        hours = max(1, int(duration // 3600))\n        return hours * 50   # ₹50 per hour\n\n\n\n\n\n\nclass PaymentMethod:\n    def pay(self, amount):\n        raise NotImplementedError\n\n\nclass CashPayment(PaymentMethod):\n    def pay(self, amount):\n        print(f\"Paid ₹{amount} by cash\")\n        return True\n\n\nclass CardPayment(PaymentMethod):\n    def pay(self, amount):\n        print(f\"Paid ₹{amount} by card\")\n        return True\n\n\nclass UPIPayment(PaymentMethod):\n    def pay(self, amount):\n        print(f\"Paid ₹{amount} via UPI\")\n        return True\n\n\n👉 Strategy pattern\n👉 New payment modes = no changes to existing code\n\n\nclass PaymentStatus:\n    PENDING = \"PENDING\"\n    SUCCESS = \"SUCCESS\"\n    FAILED = \"FAILED\"\n\n\nimport uuid\nimport time\n\nclass Payment:\n    def __init__(self, invoice, payment_method):\n        self.payment_id = str(uuid.uuid4())\n        self.invoice = invoice\n        self.amount = invoice.amount\n        self.payment_method = payment_method\n        self.status = PaymentStatus.PENDING\n        self.paid_at = None\n\n    def make_payment(self):\n        success = self.payment_method.pay(self.amount)\n        if success:\n            self.status = PaymentStatus.SUCCESS\n            self.paid_at = time.time()\n        else:\n            self.status = PaymentStatus.FAILED\n\n        return self.status",
