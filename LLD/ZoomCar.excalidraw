    {
      "id": "Hhr9z1Sb3FxoQrkyDOJzS",
      "type": "text",
      "x": 989.6006551713419,
      "y": 41718.79396455291,
      "width": 990,
      "height": 2625,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVk",
      "roundness": null,
      "seed": 1391265808,
      "version": 187,
      "versionNonce": 2085887068,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776052171676,
      "link": null,
      "locked": false,
      "text": "class Car:\n    def __init__(self, id, model, location):\n        self.id = id\n        self.model = model\n        self.location = location\n        self.is_available = True\n\n    def __str__(self):\n        return f\"{self.model} ({self.id})\"\n\n\nclass User:\n    def __init__(self, id, name, license_valid=True):\n        self.id = id\n        self.name = name\n        self.license_valid = license_valid\n\n\nclass Booking:\n    def __init__(self, id, user, car, start_time, end_time):\n        self.id = id\n        self.user = user\n        self.car = car\n        self.start_time = start_time\n        self.end_time = end_time\n        self.status = \"CONFIRMED\"\n\n    def complete(self):\n        self.status = \"COMPLETED\"\n\n\nclass Payment:\n    def __init__(self, booking, amount):\n        self.booking = booking\n        self.amount = amount\n        self.status = \"PENDING\"\n\n    def pay(self):\n        self.status = \"SUCCESS\"\n        print(f\"Payment of {self.amount} successful\")\n\n\nclass CarRentalSystem:\n    def __init__(self):\n        self.cars = []\n        self.bookings = []\n        self.users = []\n\n    def add_car(self, car):\n        self.cars.append(car)\n\n    def register_user(self, user):\n        self.users.append(user)\n\n    def search_cars(self, location):\n        return [car for car in self.cars if car.location == location and car.is_available]\n\n    def book_car(self, user, car, start_time, end_time):\n        if not user.license_valid:\n            print(\"Invalid license\")\n            return None\n\n        if not car.is_available:\n            print(\"Car not available\")\n            return None\n\n        booking = Booking(len(self.bookings)+1, user, car, start_time, end_time)\n        self.bookings.append(booking)\n        car.is_available = False\n\n        print(f\"Car {car} booked successfully\")\n        return booking\n\n    def end_trip(self, booking):\n        booking.complete()\n        booking.car.is_available = True\n        print(f\"Trip ended for booking {booking.id}\")\n\n\n\nExample Execution\n\n\nsystem = CarRentalSystem()\n\n# Add cars\ncar1 = Car(1, \"Hyundai i20\", \"Lucknow\")\ncar2 = Car(2, \"Swift\", \"Lucknow\")\n\nsystem.add_car(car1)\nsystem.add_car(car2)\n\n# Register user\nuser = User(1, \"Amit\")\nsystem.register_user(user)\n\n# Search\ncars = system.search_cars(\"Lucknow\")\nprint(cars)\n\n# Book car\nbooking = system.book_car(user, car1, \"10AM\", \"2PM\")\n\n# End trip\nsystem.end_trip(booking)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class Car:\n    def __init__(self, id, model, location):\n        self.id = id\n        self.model = model\n        self.location = location\n        self.is_available = True\n\n    def __str__(self):\n        return f\"{self.model} ({self.id})\"\n\n\nclass User:\n    def __init__(self, id, name, license_valid=True):\n        self.id = id\n        self.name = name\n        self.license_valid = license_valid\n\n\nclass Booking:\n    def __init__(self, id, user, car, start_time, end_time):\n        self.id = id\n        self.user = user\n        self.car = car\n        self.start_time = start_time\n        self.end_time = end_time\n        self.status = \"CONFIRMED\"\n\n    def complete(self):\n        self.status = \"COMPLETED\"\n\n\nclass Payment:\n    def __init__(self, booking, amount):\n        self.booking = booking\n        self.amount = amount\n        self.status = \"PENDING\"\n\n    def pay(self):\n        self.status = \"SUCCESS\"\n        print(f\"Payment of {self.amount} successful\")\n\n\nclass CarRentalSystem:\n    def __init__(self):\n        self.cars = []\n        self.bookings = []\n        self.users = []\n\n    def add_car(self, car):\n        self.cars.append(car)\n\n    def register_user(self, user):\n        self.users.append(user)\n\n    def search_cars(self, location):\n        return [car for car in self.cars if car.location == location and car.is_available]\n\n    def book_car(self, user, car, start_time, end_time):\n        if not user.license_valid:\n            print(\"Invalid license\")\n            return None\n\n        if not car.is_available:\n            print(\"Car not available\")\n            return None\n\n        booking = Booking(len(self.bookings)+1, user, car, start_time, end_time)\n        self.bookings.append(booking)\n        car.is_available = False\n\n        print(f\"Car {car} booked successfully\")\n        return booking\n\n    def end_trip(self, booking):\n        booking.complete()\n        booking.car.is_available = True\n        print(f\"Trip ended for booking {booking.id}\")\n\n\n\nExample Execution\n\n\nsystem = CarRentalSystem()\n\n# Add cars\ncar1 = Car(1, \"Hyundai i20\", \"Lucknow\")\ncar2 = Car(2, \"Swift\", \"Lucknow\")\n\nsystem.add_car(car1)\nsystem.add_car(car2)\n\n# Register user\nuser = User(1, \"Amit\")\nsystem.register_user(user)\n\n# Search\ncars = system.search_cars(\"Lucknow\")\nprint(cars)\n\n# Book car\nbooking = system.book_car(user, car1, \"10AM\", \"2PM\")\n\n# End trip\nsystem.end_trip(booking)",
      "autoResize": true,
      "lineHeight": 1.25
    },
