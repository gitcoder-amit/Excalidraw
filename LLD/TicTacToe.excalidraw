    {
      "id": "tmO0tTGcuNtxKedmKoVoS",
      "type": "text",
      "x": 1873.9370178746096,
      "y": 3697.7089401331723,
      "width": 594,
      "height": 425,
      "angle": 0,
      "strokeColor": "#1e1e1e",
