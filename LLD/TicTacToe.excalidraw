      "seed": 1263025177,
      "version": 393,
      "versionNonce": 907127649,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774636513573,
      "link": null,
      "locked": false,
      "text": "2 Initialize chess board (8x8 grid with pieces placed)\n3 Register two players\n4 Assign colors (White / Black)\n5 White starts first\n6 Current player selects a piece\n7 Validate if selected piece belongs to player\n8 Player chooses destination position\n9 Validate move based on piece rules\n10 Check if path is blocked (except Knight)\n11 If valid → move piece\n12 If opponent piece present → capture it\n13 Check if move causes check\n14 If king is in check → notify player\n15 Check for checkmate or stalemate\n16 If checkmate → game ends (winner declared)\n17 Switch turn to next player\n18 Repeat until game ends",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2 Initialize chess board (8x8 grid with pieces placed)\n3 Register two players\n4 Assign colors (White / Black)\n5 White starts first\n6 Current player selects a piece\n7 Validate if selected piece belongs to player\n8 Player chooses destination position\n9 Validate move based on piece rules\n10 Check if path is blocked (except Knight)\n11 If valid → move piece\n12 If opponent piece present → capture it\n13 Check if move causes check\n14 If king is in check → notify player\n15 Check for checkmate or stalemate\n16 If checkmate → game ends (winner declared)\n17 Switch turn to next player\n18 Repeat until game ends",
      "autoResize": true,
      "lineHeight": 1.25
    },
