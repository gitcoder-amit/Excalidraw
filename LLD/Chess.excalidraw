      "text": "Demo\n\n\n# Create game\ngame = Game()\n\n# Add players\np1 = Player(\"Amit\", \"white\")\np2 = Player(\"Rahul\", \"black\")\n\ngame.add_player(p1)\ngame.add_player(p2)\n\n# Add more pieces manually\ngame.board.grid[7][0] = Rook(\"white\")   # White rook\ngame.board.grid[0][0] = Rook(\"black\")   # Black rook\n\nprint(\"Initial Setup Done\")\n\n# Move 1: White rook moves\nmove1 = Move(Position(7, 0), Position(5, 0))\ngame.play_move(move1)\n\n# Move 2: Black rook moves\nmove2 = Move(Position(0, 0), Position(2, 0))\ngame.play_move(move2)\n\n# Move 3: White rook attacks black king line\nmove3 = Move(Position(5, 0), Position(5, 4))\ngame.play_move(move3)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Demo\n\n\n# Create game\ngame = Game()\n\n# Add players\np1 = Player(\"Amit\", \"white\")\np2 = Player(\"Rahul\", \"black\")\n\ngame.add_player(p1)\ngame.add_player(p2)\n\n# Add more pieces manually\ngame.board.grid[7][0] = Rook(\"white\")   # White rook\ngame.board.grid[0][0] = Rook(\"black\")   # Black rook\n\nprint(\"Initial Setup Done\")\n\n# Move 1: White rook moves\nmove1 = Move(Position(7, 0), Position(5, 0))\ngame.play_move(move1)\n\n# Move 2: Black rook moves\nmove2 = Move(Position(0, 0), Position(2, 0))\ngame.play_move(move2)\n\n# Move 3: White rook attacks black king line\nmove3 = Move(Position(5, 0), Position(5, 4))\ngame.play_move(move3)",
