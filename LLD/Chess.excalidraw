      "updated": 1777350529915,
      "link": null,
      "locked": false,
      "text": "class Position:\n    def __init__(self, row, col):\n        self.row = row\n        self.col = col\n\n\nclass Piece:\n    def __init__(self, color):\n        self.color = color\n\n    def is_valid_move(self, board, start, end):\n        raise NotImplementedError\n\n\nclass Rook(Piece):\n    def is_valid_move(self, board, start, end):\n        return start.row == end.row or start.col == end.col\n\nclass Bishop(Piece):\n    def is_valid_move(self, board, start, end):\n        return abs(start.row - end.row) == abs(start.col - end.col)\n\nclass Knight(Piece):\n    def is_valid_move(self, board, start, end):\n        return (abs(start.row - end.row), abs(start.col - end.col)) in [(2,1), (1,2)]\n\n\nclass Queen(Piece):\n    def is_valid_move(self, board, start, end):\n        return (\n            start.row == end.row or\n            start.col == end.col or\n            abs(start.row - end.row) == abs(start.col - end.col)\n        )\n\nclass Pawn(Piece):\n    def is_valid_move(self, board, start, end):\n        direction = 1 if self.color == \"white\" else -1\n        return (end.row - start.row == direction) and (start.col == end.col)\n\n\nclass King(Piece):\n    def is_valid_move(self, board, start, end):\n        return abs(start.row - end.row) <= 1 and abs(start.col - end.col) <= 1\n\n\nclass Board:\n    def __init__(self):\n        self.grid = [[None for _ in range(8)] for _ in range(8)]\n        self.setup_board()\n\n    def setup_board(self):\n        # Example: placing kings\n        self.grid[0][4] = King(\"black\")\n        self.grid[7][4] = King(\"white\")\n\n    def get_piece(self, position):\n        return self.grid[position.row][position.col]\n\n    def move_piece(self, start, end):\n        piece = self.get_piece(start)\n        self.grid[end.row][end.col] = piece\n        self.grid[start.row][start.col] = None\n\n\nclass Player:\n    def __init__(self, name, color):\n        self.name = name\n        self.color = color\n\n\nclass Move:\n    def __init__(self, start, end):\n        self.start = start\n        self.end = end\n\n\n\nclass Game:\n    def __init__(self):\n        self.board = Board()\n        self.players = []\n        self.current_turn = 0\n        self.status = GameStatus.ONGOING\n        self.winner = None\n\n    def add_player(self, player):\n        if len(self.players) >= 2:\n            raise Exception(\"Only 2 players allowed\")\n        self.players.append(player)\n\n    def get_current_player(self):\n        return self.players[self.current_turn]\n\n    def switch_turn(self):\n        self.current_turn = (self.current_turn + 1) % 2\n\n   def play_move(self, move):\n        if self.status == GameStatus.FINISHED:\n            print(\"Game already finished\")\n            return\n\n        player = self.get_current_player()\n        piece = self.board.get_piece(move.start)\n\n        # 1. Validate piece ownership\n        if not piece or piece.color != player.color:\n            print(\"Invalid piece selection\")\n            return\n\n        # 2. Validate move rule\n        if not piece.is_valid_move(self.board, move.start, move.end):\n            print(\"Invalid move\")\n            return\n\n        # 3. Simulate move (for check validation)\n        captured_piece = self.board.get_piece(move.end)\n        self.board.move_piece(move.start, move.end)\n\n        # 4. Check if own king is in check → rollback\n        if self.is_in_check(player.color):\n            self.board.move_piece(move.end, move.start)\n            self.board.grid[move.end.row][move.end.col] = captured_piece\n            print(\"Move puts your king in check\")\n            return\n\n        # 5. Update game state\n        opponent_color = \"black\" if player.color == \"white\" else \"white\"\n\n        if self.is_in_check(opponent_color):\n            if self.is_checkmate(opponent_color):\n                self.status = GameStatus.CHECKMATE\n                self.winner = player\n                print(f\"Checkmate! Winner is {player.name}\")\n                return\n            else:\n                self.status = GameStatus.CHECK\n                print(\"Check!\")\n        else:\n            if self.is_stalemate(opponent_color):\n                self.status = GameStatus.STALEMATE\n                print(\"Stalemate! Game Draw\")\n                return\n            else:\n                self.status = GameStatus.ONGOING\n\n        # 6. Switch turn\n        self.switch_turn()\n\n    def is_in_check(self, color):\n        king_pos = self.find_king(color)\n\n        for row in range(8):\n            for col in range(8):\n                piece = self.board.grid[row][col]\n                if piece and piece.color != color:\n                    if piece.is_valid_move(\n                        self.board,\n                        Position(row, col),\n                        king_pos\n                    ):\n                        return True\n        return False\n\n\n\nfrom enum import Enum\nclass GameStatus(Enum):\n    ONGOING = 1\n    CHECK = 2\n    CHECKMATE = 3\n    STALEMATE = 4\n    FINISHED = 5\n\n\n\n⚡ Bonus (What Interviewers Expect)\n\nIf you want to go next level (LLD round), mention:\n\nAdd Check detection\nAdd Checkmate logic\nAdd Castling\nAdd En Passant\nAdd Pawn Promotion\nAdd Move history / undo",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class Position:\n    def __init__(self, row, col):\n        self.row = row\n        self.col = col\n\n\nclass Piece:\n    def __init__(self, color):\n        self.color = color\n\n    def is_valid_move(self, board, start, end):\n        raise NotImplementedError\n\n\nclass Rook(Piece):\n    def is_valid_move(self, board, start, end):\n        return start.row == end.row or start.col == end.col\n\nclass Bishop(Piece):\n    def is_valid_move(self, board, start, end):\n        return abs(start.row - end.row) == abs(start.col - end.col)\n\nclass Knight(Piece):\n    def is_valid_move(self, board, start, end):\n        return (abs(start.row - end.row), abs(start.col - end.col)) in [(2,1), (1,2)]\n\n\nclass Queen(Piece):\n    def is_valid_move(self, board, start, end):\n        return (\n            start.row == end.row or\n            start.col == end.col or\n            abs(start.row - end.row) == abs(start.col - end.col)\n        )\n\nclass Pawn(Piece):\n    def is_valid_move(self, board, start, end):\n        direction = 1 if self.color == \"white\" else -1\n        return (end.row - start.row == direction) and (start.col == end.col)\n\n\nclass King(Piece):\n    def is_valid_move(self, board, start, end):\n        return abs(start.row - end.row) <= 1 and abs(start.col - end.col) <= 1\n\n\nclass Board:\n    def __init__(self):\n        self.grid = [[None for _ in range(8)] for _ in range(8)]\n        self.setup_board()\n\n    def setup_board(self):\n        # Example: placing kings\n        self.grid[0][4] = King(\"black\")\n        self.grid[7][4] = King(\"white\")\n\n    def get_piece(self, position):\n        return self.grid[position.row][position.col]\n\n    def move_piece(self, start, end):\n        piece = self.get_piece(start)\n        self.grid[end.row][end.col] = piece\n        self.grid[start.row][start.col] = None\n\n\nclass Player:\n    def __init__(self, name, color):\n        self.name = name\n        self.color = color\n\n\nclass Move:\n    def __init__(self, start, end):\n        self.start = start\n        self.end = end\n\n\n\nclass Game:\n    def __init__(self):\n        self.board = Board()\n        self.players = []\n        self.current_turn = 0\n        self.status = GameStatus.ONGOING\n        self.winner = None\n\n    def add_player(self, player):\n        if len(self.players) >= 2:\n            raise Exception(\"Only 2 players allowed\")\n        self.players.append(player)\n\n    def get_current_player(self):\n        return self.players[self.current_turn]\n\n    def switch_turn(self):\n        self.current_turn = (self.current_turn + 1) % 2\n\n   def play_move(self, move):\n        if self.status == GameStatus.FINISHED:\n            print(\"Game already finished\")\n            return\n\n        player = self.get_current_player()\n        piece = self.board.get_piece(move.start)\n\n        # 1. Validate piece ownership\n        if not piece or piece.color != player.color:\n            print(\"Invalid piece selection\")\n            return\n\n        # 2. Validate move rule\n        if not piece.is_valid_move(self.board, move.start, move.end):\n            print(\"Invalid move\")\n            return\n\n        # 3. Simulate move (for check validation)\n        captured_piece = self.board.get_piece(move.end)\n        self.board.move_piece(move.start, move.end)\n\n        # 4. Check if own king is in check → rollback\n        if self.is_in_check(player.color):\n            self.board.move_piece(move.end, move.start)\n            self.board.grid[move.end.row][move.end.col] = captured_piece\n            print(\"Move puts your king in check\")\n            return\n\n        # 5. Update game state\n        opponent_color = \"black\" if player.color == \"white\" else \"white\"\n\n        if self.is_in_check(opponent_color):\n            if self.is_checkmate(opponent_color):\n                self.status = GameStatus.CHECKMATE\n                self.winner = player\n                print(f\"Checkmate! Winner is {player.name}\")\n                return\n            else:\n                self.status = GameStatus.CHECK\n                print(\"Check!\")\n        else:\n            if self.is_stalemate(opponent_color):\n                self.status = GameStatus.STALEMATE\n                print(\"Stalemate! Game Draw\")\n                return\n            else:\n                self.status = GameStatus.ONGOING\n\n        # 6. Switch turn\n        self.switch_turn()\n\n    def is_in_check(self, color):\n        king_pos = self.find_king(color)\n\n        for row in range(8):\n            for col in range(8):\n                piece = self.board.grid[row][col]\n                if piece and piece.color != color:\n                    if piece.is_valid_move(\n                        self.board,\n                        Position(row, col),\n                        king_pos\n                    ):\n                        return True\n        return False\n\n\n\nfrom enum import Enum\nclass GameStatus(Enum):\n    ONGOING = 1\n    CHECK = 2\n    CHECKMATE = 3\n    STALEMATE = 4\n    FINISHED = 5\n\n\n\n⚡ Bonus (What Interviewers Expect)\n\nIf you want to go next level (LLD round), mention:\n\nAdd Check detection\nAdd Checkmate logic\nAdd Castling\nAdd En Passant\nAdd Pawn Promotion\nAdd Move history / undo",
