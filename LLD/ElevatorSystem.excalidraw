    {
      "id": "lY2UK18BJsAzvTHYkiIo2",
      "type": "text",
      "x": 981.2686239213419,
      "y": 35771.15919892791,
      "width": 1089,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bQD",
      "roundness": null,
      "seed": 1427257572,
      "version": 616,
      "versionNonce": 1383595175,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775105901858,
      "link": null,
      "locked": false,
      "text": "It is that software, which allows us to create metadata in a certain way\nIn windows we generally format it in a way called as NTFS, this is the way that Windows uses\nto format a system or to format pendrive or something like that\n\nLinux generally uses fat, exfat, exts , ext4, we can install NTFS, and start using NTFS also.\n\nWhen file system table created ? this table gets created when we format our partition with a\nspecific file system type. So when we format our partition, after formating partition gets created.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It is that software, which allows us to create metadata in a certain way\nIn windows we generally format it in a way called as NTFS, this is the way that Windows uses\nto format a system or to format pendrive or something like that\n\nLinux generally uses fat, exfat, exts , ext4, we can install NTFS, and start using NTFS also.\n\nWhen file system table created ? this table gets created when we format our partition with a\nspecific file system type. So when we format our partition, after formating partition gets created.",
      "autoResize": true,
      "lineHeight": 1.25
    },
