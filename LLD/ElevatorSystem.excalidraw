    },
    {
      "id": "QFwHytBW_Xn13u680j8Lb",
      "type": "text",
      "x": 962.7920614213419,
      "y": 31687.596698927915,
      "width": 1067,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bPe",
