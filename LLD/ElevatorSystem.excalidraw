      "link": null,
      "locked": false,
      "text": "from enum import Enum\n\nclass Direction(Enum):\n    UP = 1\n    DOWN = -1\n    IDLE = 0",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "from enum import Enum\n\nclass Direction(Enum):\n    UP = 1\n    DOWN = -1\n    IDLE = 0",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "kW-LHcA03rydJcj6tf0my",
      "type": "text",
      "x": 1044.5666106413544,
      "y": 36359.552045866556,
      "width": 990,
      "height": 2800,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVc",
      "roundness": null,
      "seed": 1339690983,
      "version": 51,
      "versionNonce": 1457812703,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775619026060,
      "link": null,
      "locked": false,
      "text": "class Request:\n    def __init__(self, floor, direction=None):\n        self.floor = floor\n        self.direction = direction  # None for internal request\n\nimport heapq\n\nclass Elevator:\n    def __init__(self, id, capacity):\n        self.id = id\n        self.current_floor = 0\n        self.direction = Direction.IDLE\n        self.capacity = capacity\n        self.load = 0\n        \n        self.up_queue = []     # min heap\n        self.down_queue = []   # max heap (store negative values)\n\n    def add_request(self, request):\n        if request.floor > self.current_floor:\n            heapq.heappush(self.up_queue, request.floor)\n        elif request.floor < self.current_floor:\n            heapq.heappush(self.down_queue, -request.floor)\n        else:\n            self.open_door()\n\n    def move(self):\n        if self.direction in [Direction.IDLE, Direction.UP]:\n            if self.up_queue:\n                self.direction = Direction.UP\n                next_floor = heapq.heappop(self.up_queue)\n                self.travel_to(next_floor)\n            elif self.down_queue:\n                self.direction = Direction.DOWN\n\n        if self.direction == Direction.DOWN:\n            if self.down_queue:\n                next_floor = -heapq.heappop(self.down_queue)\n                self.travel_to(next_floor)\n            elif self.up_queue:\n                self.direction = Direction.UP\n\n    def travel_to(self, floor):\n        print(f\"Elevator {self.id} moving from {self.current_floor} to {floor}\")\n        self.current_floor = floor\n        self.open_door()\n\n    def open_door(self):\n        print(f\"Elevator {self.id} opening door at {self.current_floor}\")\n\n\n\n\nclass ElevatorController:\n    def __init__(self, elevators):\n        self.elevators = elevators\n\n    def assign_elevator(self, request):\n        best_elevator = None\n        min_distance = float('inf')\n\n        for elevator in self.elevators:\n            distance = abs(elevator.current_floor - request.floor)\n\n            if distance < min_distance:\n                min_distance = distance\n                best_elevator = elevator\n\n        print(f\"Request at floor {request.floor} assigned to Elevator {best_elevator.id}\")\n        best_elevator.add_request(request)\n\n\nclass ElevatorSystem:\n    def __init__(self, num_elevators, capacity):\n        self.elevators = [Elevator(i, capacity) for i in range(num_elevators)]\n        self.controller = ElevatorController(self.elevators)\n        self.floors = [Floor(i) for i in range(num_floors)]\n\n    def request_elevator(self, floor, direction):\n        request = Request(floor, direction)\n        self.controller.assign_elevator(request)\n\n    def step(self):\n        for elevator in self.elevators:\n            elevator.move()\n\nclass Floor:\n    def __init__(self, number):\n        self.number = number\n        self.up_requests = []\n        self.down_requests = []\n\n    def press_button(self, direction):\n        request = Request(self.number, direction)\n        if direction == Direction.UP:\n            self.up_requests.append(request)\n        else:\n            self.down_requests.append(request)\n        return request\n\n\nsystem = ElevatorSystem(num_elevators=2, capacity=5)\n\n# External requests\nsystem.request_elevator(3, Direction.UP)\nsystem.request_elevator(7, Direction.DOWN)\n\n# Simulate movement\nfor _ in range(5):\n    system.step()\n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class Request:\n    def __init__(self, floor, direction=None):\n        self.floor = floor\n        self.direction = direction  # None for internal request\n\nimport heapq\n\nclass Elevator:\n    def __init__(self, id, capacity):\n        self.id = id\n        self.current_floor = 0\n        self.direction = Direction.IDLE\n        self.capacity = capacity\n        self.load = 0\n        \n        self.up_queue = []     # min heap\n        self.down_queue = []   # max heap (store negative values)\n\n    def add_request(self, request):\n        if request.floor > self.current_floor:\n            heapq.heappush(self.up_queue, request.floor)\n        elif request.floor < self.current_floor:\n            heapq.heappush(self.down_queue, -request.floor)\n        else:\n            self.open_door()\n\n    def move(self):\n        if self.direction in [Direction.IDLE, Direction.UP]:\n            if self.up_queue:\n                self.direction = Direction.UP\n                next_floor = heapq.heappop(self.up_queue)\n                self.travel_to(next_floor)\n            elif self.down_queue:\n                self.direction = Direction.DOWN\n\n        if self.direction == Direction.DOWN:\n            if self.down_queue:\n                next_floor = -heapq.heappop(self.down_queue)\n                self.travel_to(next_floor)\n            elif self.up_queue:\n                self.direction = Direction.UP\n\n    def travel_to(self, floor):\n        print(f\"Elevator {self.id} moving from {self.current_floor} to {floor}\")\n        self.current_floor = floor\n        self.open_door()\n\n    def open_door(self):\n        print(f\"Elevator {self.id} opening door at {self.current_floor}\")\n\n\n\n\nclass ElevatorController:\n    def __init__(self, elevators):\n        self.elevators = elevators\n\n    def assign_elevator(self, request):\n        best_elevator = None\n        min_distance = float('inf')\n\n        for elevator in self.elevators:\n            distance = abs(elevator.current_floor - request.floor)\n\n            if distance < min_distance:\n                min_distance = distance\n                best_elevator = elevator\n\n        print(f\"Request at floor {request.floor} assigned to Elevator {best_elevator.id}\")\n        best_elevator.add_request(request)\n\n\nclass ElevatorSystem:\n    def __init__(self, num_elevators, capacity):\n        self.elevators = [Elevator(i, capacity) for i in range(num_elevators)]\n        self.controller = ElevatorController(self.elevators)\n        self.floors = [Floor(i) for i in range(num_floors)]\n\n    def request_elevator(self, floor, direction):\n        request = Request(floor, direction)\n        self.controller.assign_elevator(request)\n\n    def step(self):\n        for elevator in self.elevators:\n            elevator.move()\n\nclass Floor:\n    def __init__(self, number):\n        self.number = number\n        self.up_requests = []\n        self.down_requests = []\n\n    def press_button(self, direction):\n        request = Request(self.number, direction)\n        if direction == Direction.UP:\n            self.up_requests.append(request)\n        else:\n            self.down_requests.append(request)\n        return request\n\n\nsystem = ElevatorSystem(num_elevators=2, capacity=5)\n\n# External requests\nsystem.request_elevator(3, Direction.UP)\nsystem.request_elevator(7, Direction.DOWN)\n\n# Simulate movement\nfor _ in range(5):\n    system.step()\n\n",
