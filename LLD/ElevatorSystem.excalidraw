      "index": "bS8",
      "roundness": null,
      "seed": 943938472,
      "version": 95,
      "versionNonce": 1290697927,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775105901859,
      "link": null,
      "locked": false,
      "text": "Disk would not be there, disk ud jaegi. Why ? -> we will talk about it in next session",
