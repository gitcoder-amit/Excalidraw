      "type": "text",
      "x": 1057.268623921342,
      "y": 47911.10451142791,
      "width": 847,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
