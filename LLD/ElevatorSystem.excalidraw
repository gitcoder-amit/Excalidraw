    {
      "id": "8BVJq_TtUCyjFxVv2MIAe",
      "type": "text",
      "x": 1047.538155171342,
      "y": 37741.50294892791,
      "width": 671,
      "height": 775,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bQn",
      "roundness": null,
      "seed": 1796542308,
      "version": 1453,
      "versionNonce": 746479273,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775105901858,
      "link": null,
      "locked": false,
      "text": "Everything is here like\n/bin/date like that\neverything exists over here\n\nBut now we have to attach one\nmore partition also to this,\nFor attaching one more partition we\nwill create one more directory over here\nbecause we have no other way to read\nour system, apart from where my OS\nis and our OS is in /.\n\nFor example in windows machine where do\nwe have our OS? Which drive by default -> C drive\n\nLets says someone says D drive is different, it is\nnot connected with C drive for a moment lets say\nwe are agree with this also, But where are we able\nto see C and D drive in This PC or my computer section\nwhere this PC is ? -> C drive\n\nSo in a way in the location of C drive there are few\ndirectories more created and those directories are just\ntelling us that if you write data in me it will go \nto different partition called as D drive.\n\nLikewise we create a directory inside /. And that directory\nwe set it as mount point and this mount point tells us that\nif we write the data into this mount point or if we write the\ndata in this directory, It is still listed inside /.\nBut the data will go to a different partition.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Everything is here like\n/bin/date like that\neverything exists over here\n\nBut now we have to attach one\nmore partition also to this,\nFor attaching one more partition we\nwill create one more directory over here\nbecause we have no other way to read\nour system, apart from where my OS\nis and our OS is in /.\n\nFor example in windows machine where do\nwe have our OS? Which drive by default -> C drive\n\nLets says someone says D drive is different, it is\nnot connected with C drive for a moment lets say\nwe are agree with this also, But where are we able\nto see C and D drive in This PC or my computer section\nwhere this PC is ? -> C drive\n\nSo in a way in the location of C drive there are few\ndirectories more created and those directories are just\ntelling us that if you write data in me it will go \nto different partition called as D drive.\n\nLikewise we create a directory inside /. And that directory\nwe set it as mount point and this mount point tells us that\nif we write the data into this mount point or if we write the\ndata in this directory, It is still listed inside /.\nBut the data will go to a different partition.",
      "autoResize": true,
      "lineHeight": 1.25
    },
