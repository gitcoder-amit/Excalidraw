    },
    {
      "id": "9yPGoe7OumCdA3tJVPL8B",
      "type": "text",
      "x": 967.0733114213419,
      "y": 43213.73341767791,
      "width": 946,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
