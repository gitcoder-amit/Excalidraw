      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "One single question will teach entire linux networking, linux network troubleshooting, everything\nthat we need to know.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "H2MNJSiO6l7mFugOjfOMN",
      "type": "text",
      "x": 867.0459676713419,
      "y": 49959.43263642791,
      "width": 1177,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bTe",
      "roundness": null,
      "seed": 439456697,
      "version": 174,
      "versionNonce": 490720073,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775105901859,
      "link": null,
      "locked": false,
      "text": "Q How will you troubleshoot(t/s) if you are not able to reach google.com? this type of question called OEQ \nOpen Ended Questions",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Q How will you troubleshoot(t/s) if you are not able to reach google.com? this type of question called OEQ \nOpen Ended Questions",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "n4wcMeQg1DMuBYhIfI5WN",
      "type": "text",
      "x": 943.5850301713419,
      "y": 50033.29982392791,
      "width": 605,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
