    {
      "id": "E1g_sDgBlJ4T1aCtlipmy",
      "type": "text",
      "x": 1384.030342671342,
      "y": 50117.57912080291,
      "width": 66,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
