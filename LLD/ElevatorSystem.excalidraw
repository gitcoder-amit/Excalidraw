    {
      "id": "eI3jhn68p0nHIsyt-vUrn",
      "type": "text",
      "x": 1036.1134856413544,
      "y": 34958.614545866556,
      "width": 869,
      "height": 625,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bVV",
      "roundness": null,
      "seed": 629581033,
      "version": 11,
      "versionNonce": 688001521,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775619192390,
      "link": null,
      "locked": false,
      "text": "1. System initializes with N elevators and M floors\n2. Each elevator is set to initial state (floor=0, direction=IDLE, empty queue)\n3. User presses UP/DOWN button on a floor\n4. Request is sent to Elevator Controller\n5. Controller selects best elevator based on:\n   - Direction\n   - Distance\n   - Load\n6. Controller assigns request to selected elevator\n7. Elevator adds pickup floor to its request queue\n8. Elevator starts moving toward requested floor\n9. Elevator reaches floor → opens door\n10. User enters elevator\n11. User selects destination floor\n12. Destination is added to elevator queue\n13. Elevator continues moving:\n    - Stops at intermediate requested floors\n14. If elevator reaches a stop:\n    - Open door\n    - Users exit/enter\n15. If no more requests in current direction:\n    - Change direction OR become IDLE\n16. If capacity exceeded:\n    - New users must wait for next elevator\n17. Repeat until all requests are served",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. System initializes with N elevators and M floors\n2. Each elevator is set to initial state (floor=0, direction=IDLE, empty queue)\n3. User presses UP/DOWN button on a floor\n4. Request is sent to Elevator Controller\n5. Controller selects best elevator based on:\n   - Direction\n   - Distance\n   - Load\n6. Controller assigns request to selected elevator\n7. Elevator adds pickup floor to its request queue\n8. Elevator starts moving toward requested floor\n9. Elevator reaches floor → opens door\n10. User enters elevator\n11. User selects destination floor\n12. Destination is added to elevator queue\n13. Elevator continues moving:\n    - Stops at intermediate requested floors\n14. If elevator reaches a stop:\n    - Open door\n    - Users exit/enter\n15. If no more requests in current direction:\n    - Change direction OR become IDLE\n16. If capacity exceeded:\n    - New users must wait for next elevator\n17. Repeat until all requests are served",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oUvNHHkDUUrBB0vu3fgAE",
      "type": "text",
      "x": 976.2736418913544,
      "y": 35644.220014616556,
      "width": 123.199951171875,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
