    {
      "id": "6rFeEJYbcjERb8E9iNRqL",
      "type": "text",
      "x": 1015.0459676713419,
      "y": 38596.54201142791,
      "width": 341,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
