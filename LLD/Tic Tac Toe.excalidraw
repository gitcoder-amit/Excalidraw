    {
      "id": "LM4Fcgsj1iLHrWIdJFwpH",
      "type": "text",
      "x": 1793.2196038503075,
      "y": -17417.656915769767,
      "width": 1674.4676513671875,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0c",
      "roundness": null,
      "seed": 186562929,
      "version": 395,
      "versionNonce": 267608964,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1767451149436,
      "link": null,
      "locked": false,
      "text": "1. Board size nxn or 10x10 is fine or it should be scalable for nxn\n2. How many dice: will go with one but it should be scalable\n3. Number and place of snakes and Ladder : During game setup we should be able to dynamically\n    define\n4. Number of Players : 2 Player but scalable\n5. Winning Strategy : Any one player wins, game should get finished",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Board size nxn or 10x10 is fine or it should be scalable for nxn\n2. How many dice: will go with one but it should be scalable\n3. Number and place of snakes and Ladder : During game setup we should be able to dynamically\n    define\n4. Number of Players : 2 Player but scalable\n5. Winning Strategy : Any one player wins, game should get finished",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "yEYs6ZJM7JF4AQtrTHp8j",
      "type": "text",
      "x": 1700.4421072842306,
      "y": -16981.009850225764,
      "width": 1865.663818359375,
      "height": 360,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
