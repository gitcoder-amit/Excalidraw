    {
      "id": "xGuJEVAwI9ofK6HI1xzy1",
      "type": "text",
      "x": 904.9893907653108,
      "y": -213.71452770645215,
      "width": 1822.6436767578125,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aS",
      "roundness": null,
      "seed": 1054882216,
      "version": 833,
      "versionNonce": 1306886961,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1767448183650,
      "link": null,
      "locked": false,
      "text": "- System should be fault tolerant\n- System should be available -> because these system are also used for contests those are time \n                                       based \n- For contest specifically consistency is  imp -> Leaderboard should be correct but it can take some\n                                                            time no issues on that so eventually consistency is\n                                                            fine not like payment should be immediate consistent\n                                                             or strongly consistencty\n- Highly Scalable system during Contest -> During Contest we can't compromise on scalability otherwise \n                                                     we can't give right rank to the candidate due to we will not\n                                                      be able to track time",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- System should be fault tolerant\n- System should be available -> because these system are also used for contests those are time \n                                       based \n- For contest specifically consistency is  imp -> Leaderboard should be correct but it can take some\n                                                            time no issues on that so eventually consistency is\n                                                            fine not like payment should be immediate consistent\n                                                             or strongly consistencty\n- Highly Scalable system during Contest -> During Contest we can't compromise on scalability otherwise \n                                                     we can't give right rank to the candidate due to we will not\n                                                      be able to track time",
      "autoResize": true,
      "lineHeight": 1.25
    },
