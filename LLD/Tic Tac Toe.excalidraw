      "boundElements": [],
      "updated": 1767450732229,
      "link": null,
      "locked": false,
      "text": "About Game and Rules :\n\n- Its a simple 2 player paper and pencil game\n- Each player selects a piece before the game i.e 'X' or 'O'\n- Player takes turn placing there peice on 3x3 grid\n- A player wins by placing three of its pieces in a row, column or diagonal\n- The game ends when a player wins or when all grid cells are filled",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "About Game and Rules :\n\n- Its a simple 2 player paper and pencil game\n- Each player selects a piece before the game i.e 'X' or 'O'\n- Player takes turn placing there peice on 3x3 grid\n- A player wins by placing three of its pieces in a row, column or diagonal\n- The game ends when a player wins or when all grid cells are filled",
      "autoResize": true,
      "lineHeight": 1.25
    },
