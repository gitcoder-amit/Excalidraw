    {
      "id": "7Sruu6m-skLDpGtYJMRs7",
      "type": "text",
      "x": 1734.364001324776,
      "y": -14174.49455314854,
      "width": 1679.1114501953125,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
