      "seed": 1927673951,
      "version": 468,
      "versionNonce": 1549488316,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1767451149436,
      "link": null,
      "locked": false,
      "text": "both the classes looks same Only diff is \n    Snake -> startposition is greater than endposition\n    Ladder -> startpostion is less than endPositioin\n\nSO we can create only one class Jump\nAs both snake and ladder work is to provide jump whether jump to high position or low position\n\n\n\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "both the classes looks same Only diff is \n    Snake -> startposition is greater than endposition\n    Ladder -> startpostion is less than endPositioin\n\nSO we can create only one class Jump\nAs both snake and ladder work is to provide jump whether jump to high position or low position\n\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
