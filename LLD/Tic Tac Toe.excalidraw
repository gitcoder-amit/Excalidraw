    {
      "id": "6rykJh739qRG2TaiS03QV",
      "type": "text",
      "x": 1691.8732853712627,
      "y": -13687.494499720868,
      "width": 1954.9075927734375,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
