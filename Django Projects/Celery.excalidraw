      "boundElements": [],
      "updated": 1775569678254,
      "link": null,
      "locked": false,
      "text": "Problem start when we have 20K wps and storage is approacing 70 TB.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem start when we have 20K wps and storage is approacing 70 TB.",
