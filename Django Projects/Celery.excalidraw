    },
    {
      "id": "pXRkHHmsQPK72eMK4Yyl7",
      "type": "text",
      "x": 401.391496608421,
      "y": 171.05504950238537,
      "width": 1320,
      "height": 125,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bINZ",
      "roundness": null,
      "seed": 1779306920,
      "version": 331,
      "versionNonce": 1329413724,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775569678254,
      "link": null,
      "locked": false,
      "text": "Now we have two solution\n1 Vertical Scaling  -> Everyone at first view thing about increase the power of database that can handle 140TB space and\n can handle 50K wps. but vertical scaling has a upper limit always\n\nAWS provide bigger machine depending on our requirement",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Now we have two solution\n1 Vertical Scaling  -> Everyone at first view thing about increase the power of database that can handle 140TB space and\n can handle 50K wps. but vertical scaling has a upper limit always\n\nAWS provide bigger machine depending on our requirement",
      "autoResize": true,
      "lineHeight": 1.25
    },
