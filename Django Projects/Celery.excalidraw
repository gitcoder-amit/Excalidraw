      "updated": 1775569678244,
      "link": null,
      "locked": false,
      "text": "# tasks.py\nfrom celery import shared_task\n\n@shared_task\ndef send_welcome_email(user_id):\n    # heavy logic here\n    print(f\"Sending email to user {user_id}\")",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "# tasks.py\nfrom celery import shared_task\n\n@shared_task\ndef send_welcome_email(user_id):\n    # heavy logic here\n    print(f\"Sending email to user {user_id}\")",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "HdDHdJhdXcHwhcVUVN6eF",
