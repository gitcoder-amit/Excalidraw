    {
      "id": "Ue1Az5F-D9t0LSZgsPcWa",
      "type": "text",
      "x": -1352.8677308874205,
      "y": -1036.6565371399352,
      "width": 374,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bJV",
      "roundness": null,
      "seed": 2073638035,
      "version": 21,
      "versionNonce": 806127324,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775569678249,
      "link": null,
      "locked": false,
      "text": "This single purchase triggered:\nsearch service → event lookup\ninventory service → seat lock\ncache → concurrency control\norder service → transaction record\npayment service → gateway call\nticket service → QR generation\nnotification service → email",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This single purchase triggered:\nsearch service → event lookup\ninventory service → seat lock\ncache → concurrency control\norder service → transaction record\npayment service → gateway call\nticket service → QR generation\nnotification service → email",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-OajIq7sszR8CtY7KTBTJ",
      "type": "text",
      "x": -1320.7106128318646,
      "y": -2909.447335751047,
      "width": 781,
      "height": 1775,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bJW",
      "roundness": null,
      "seed": 1440645085,
      "version": 230,
      "versionNonce": 168355044,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775569678249,
      "link": null,
      "locked": false,
      "text": "🎤 Example: Buying a concert ticket on Ticketmaster\n\nEvent: Coldplay Live in Mumbai\nVenue: DY Patil Stadium\nSeat: A12\n\n\n🧭 Step-by-step user journey\n1️⃣ Event Setup (before users arrive)\n\nOrganizer uploads:\nstadium seat map\nticket prices\nsale start time = 10:00 AM\nSystem stores all seats like:\nSeat A12 → AVAILABLE\nSeat A13 → AVAILABLE\n...\n\n2️⃣ User Searches Event\nAt 10:01 AM, Rahul opens the app and searches “Coldplay Mumbai”.\nSystem:\nfetches event from search index\nloads seat map\nshows green (available), grey (sold), yellow (locked)\nRahul clicks Seat A12.\n\n3️⃣ Seat Lock (most critical step)\nSystem instantly does:\nSeat A12 → LOCKED for Rahul (10 min hold)\n\nInternally:\nRedis lock created\nDB updated\ntimer started\nNow nobody else can buy A12 during the hold.\nIf Rahul leaves checkout → lock expires → seat becomes AVAILABLE again.\n\n4️⃣ Checkout & Payment\n\nRahul pays ₹5,000.\nSystem performs:\nverify seat still locked for Rahul\ncall payment gateway\npayment success\n\nSeat A12 → SOLD\nOrder ID → generated\n\n5️⃣ Ticket Generation\n\nSystem creates:\nunique ticket ID\nQR code\ndigital ticket\nRahul receives:\n📩 email confirmation\n📱 mobile ticket in account\n\n6️⃣ Entry at Venue\nAt concert gate:\nStaff scans Rahul’s QR code.\nSystem checks:\nTicket exists ✔\nNot used ✔\nValid event ✔\n\nThen marks:\nTicket → USED\n\nRahul enters 🎉",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "🎤 Example: Buying a concert ticket on Ticketmaster\n\nEvent: Coldplay Live in Mumbai\nVenue: DY Patil Stadium\nSeat: A12\n\n\n🧭 Step-by-step user journey\n1️⃣ Event Setup (before users arrive)\n\nOrganizer uploads:\nstadium seat map\nticket prices\nsale start time = 10:00 AM\nSystem stores all seats like:\nSeat A12 → AVAILABLE\nSeat A13 → AVAILABLE\n...\n\n2️⃣ User Searches Event\nAt 10:01 AM, Rahul opens the app and searches “Coldplay Mumbai”.\nSystem:\nfetches event from search index\nloads seat map\nshows green (available), grey (sold), yellow (locked)\nRahul clicks Seat A12.\n\n3️⃣ Seat Lock (most critical step)\nSystem instantly does:\nSeat A12 → LOCKED for Rahul (10 min hold)\n\nInternally:\nRedis lock created\nDB updated\ntimer started\nNow nobody else can buy A12 during the hold.\nIf Rahul leaves checkout → lock expires → seat becomes AVAILABLE again.\n\n4️⃣ Checkout & Payment\n\nRahul pays ₹5,000.\nSystem performs:\nverify seat still locked for Rahul\ncall payment gateway\npayment success\n\nSeat A12 → SOLD\nOrder ID → generated\n\n5️⃣ Ticket Generation\n\nSystem creates:\nunique ticket ID\nQR code\ndigital ticket\nRahul receives:\n📩 email confirmation\n📱 mobile ticket in account\n\n6️⃣ Entry at Venue\nAt concert gate:\nStaff scans Rahul’s QR code.\nSystem checks:\nTicket exists ✔\nNot used ✔\nValid event ✔\n\nThen marks:\nTicket → USED\n\nRahul enters 🎉",
      "autoResize": true,
      "lineHeight": 1.25
    },
