    {
      "id": "2Kfpovx5i3CWVw12cbEhr",
      "type": "text",
      "x": 486.88876690428924,
      "y": 12559.927737534284,
      "width": 297,
      "height": 25,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "cross-hatch",
      "strokeWidth": 1,
      "strokeStyle": "solid",
