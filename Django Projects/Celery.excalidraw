    {
      "id": "0aNfdAlWIV91h1AeT0p6K",
      "type": "text",
      "x": 125.82923377731305,
      "y": 6899.9470242574835,
      "width": 968,
      "height": 150,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bIOt",
      "roundness": null,
      "seed": 703062696,
      "version": 668,
      "versionNonce": 2138054116,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775569678254,
      "link": null,
      "locked": false,
      "text": "Lets say we sharded on the value is premium, In our User table some user are premium\nmember and some are not thats the boolean flag in our database, If we were to shard \non this, then this gives us only 2 groups premium users and non premium users, thats\nextremely low cardinality. We immediately cap ourself to just two shards and once they\nfill up, we have kind of stuck, there is nothing to split them on if we have chosen that\nour shard key ",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Lets say we sharded on the value is premium, In our User table some user are premium\nmember and some are not thats the boolean flag in our database, If we were to shard \non this, then this gives us only 2 groups premium users and non premium users, thats\nextremely low cardinality. We immediately cap ourself to just two shards and once they\nfill up, we have kind of stuck, there is nothing to split them on if we have chosen that\nour shard key ",
      "autoResize": true,
      "lineHeight": 1.25
    },
