    {
      "id": "TQmdili24vZW_ImbTLbQz",
      "type": "text",
      "x": 1337.6905082661692,
      "y": 14782.639069128896,
      "width": 484,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bIQV",
      "roundness": null,
      "seed": 277817647,
      "version": 215,
      "versionNonce": 490518628,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775569678254,
      "link": null,
      "locked": false,
      "text": "Atomic nature of transaction will make\nsure both of them will succeed\nor neither of them will succeed. So we never\nend up in inconsistent state.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Atomic nature of transaction will make\nsure both of them will succeed\nor neither of them will succeed. So we never\nend up in inconsistent state.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ToCkJxwZlG2gNwpUT3sbf",
