    {
      "id": "mgNCtdoGMjCH-8gcVCwlJ",
      "type": "text",
      "x": -807.1604369973536,
      "y": 3389.0916282552107,
      "width": 1762.1993408203125,
      "height": 90,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
