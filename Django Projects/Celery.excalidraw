    {
      "type": "text",
      "version": 1764,
      "versionNonce": 1146314852,
      "index": "bCE",
      "isDeleted": true,
      "id": "sGDkpWWck7oYJhOe_09Jl",
      "fillStyle": "solid",
      "strokeWidth": 2,
