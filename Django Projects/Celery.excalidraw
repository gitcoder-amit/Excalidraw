    {
      "id": "35dr9RZ3hYdJ4iLJKs9-R",
      "type": "text",
      "x": 311.83872903102383,
      "y": 9481.71577807136,
      "width": 1245.5123240055927,
      "height": 207.81350597167852,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bGg",
      "roundness": null,
      "seed": 1547586448,
      "version": 1392,
      "versionNonce": 1123464036,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775569678254,
      "link": null,
      "locked": false,
      "text": "Hash Based -> industry standard use in production, just take hash of data and take modulo\nfrom no of shard that will be shard in whihc we need to interact with. so it will be always even distribute\ndata, but there are multiple problems also with this strategy\n \nProblem no 1 -> Rebalancing -> if we need to add or delete one shard then whole data redistributed should be \nhappend, this is where consistent hashing comes in, consistent hashing places both key and shards on the\nvirtual ring, and the way it works we hash the key and what the value we will put that in right shard\n of that value in ring.",
      "fontSize": 20.781350597167823,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Hash Based -> industry standard use in production, just take hash of data and take modulo\nfrom no of shard that will be shard in whihc we need to interact with. so it will be always even distribute\ndata, but there are multiple problems also with this strategy\n \nProblem no 1 -> Rebalancing -> if we need to add or delete one shard then whole data redistributed should be \nhappend, this is where consistent hashing comes in, consistent hashing places both key and shards on the\nvirtual ring, and the way it works we hash the key and what the value we will put that in right shard\n of that value in ring.",
      "autoResize": true,
      "lineHeight": 1.25
    },
