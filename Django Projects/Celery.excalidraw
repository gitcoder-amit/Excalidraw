      "type": "text",
      "x": -539.3042953889911,
      "y": 7783.481575752845,
      "width": 473,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
