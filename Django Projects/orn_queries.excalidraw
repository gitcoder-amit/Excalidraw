    {
      "id": "qGq7PKBffzUTdOBbX9K93",
      "type": "text",
      "x": -877.040774606253,
      "y": -624.1128702340336,
      "width": 2692.798828125,
      "height": 2700,
      "angle": 6.279805009203768,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bHP",
      "roundness": null,
      "seed": 533775972,
      "version": 3156,
      "versionNonce": 873958456,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774278816164,
      "link": null,
      "locked": false,
      "text": "    from django.db.models import Q\n    from django.contrib.auth import authenticate, login, logout\n    \n    \n    views.py\n    \n    def registration(request):\n        if request.method == 'POST':\n            first_name = request.POST.get('first_name')\n            last_name = request.POST.get('last_name')\n            username = request.POST.get('username')\n            email = request.POST.get('email')\n            password = request.POST.get('password')\n            \n            user_obj = User.objects.filter(Q(email = email) |  Q(usename = username))\n            if user_obj.exists():\n                messages.error(request, 'username or email already exists')\n                return redirec('/registration')\n    \n            user_obj = User.objects.create(first_name = first_name, last_name=last_name, username=username, email=email)\n            user_obj.set_password(password)\n            user_obj.save()\n            messages.error(request, 'Account Created')\n                \n        return render(request, 'registration.html')\n    \n    \n    def login_page(request):\n        if request.method == 'POST':\n            username = request.POST.get('usename')\n            password = request.POST.get('password')\n            user_obj = User.objects.filter(usename = username)\n            \n            if not user_obj.exists():\n                messages.error(request, 'username does not exists')\n                return redirect('/login')\n    \n    \n            user_obj = authenticate(username = username, password=password) # authenticate is used to login due to password in not plain\n                                                                                password is encoded\n    \n            if not user_obj:\n                messages.error(request, 'Invalid User')\n                return redirect('/login')\n\n\n            \n            login(request, user_obj)\n            return redirect('/')\n        return render(request, 'login.html')\n\n   \n    def logout_page(request):\n        logout(request)\n        messages.error(request, 'logout successful')\n        return redirect('/login')\n        \n        \n           \n    ",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "    from django.db.models import Q\n    from django.contrib.auth import authenticate, login, logout\n    \n    \n    views.py\n    \n    def registration(request):\n        if request.method == 'POST':\n            first_name = request.POST.get('first_name')\n            last_name = request.POST.get('last_name')\n            username = request.POST.get('username')\n            email = request.POST.get('email')\n            password = request.POST.get('password')\n            \n            user_obj = User.objects.filter(Q(email = email) |  Q(usename = username))\n            if user_obj.exists():\n                messages.error(request, 'username or email already exists')\n                return redirec('/registration')\n    \n            user_obj = User.objects.create(first_name = first_name, last_name=last_name, username=username, email=email)\n            user_obj.set_password(password)\n            user_obj.save()\n            messages.error(request, 'Account Created')\n                \n        return render(request, 'registration.html')\n    \n    \n    def login_page(request):\n        if request.method == 'POST':\n            username = request.POST.get('usename')\n            password = request.POST.get('password')\n            user_obj = User.objects.filter(usename = username)\n            \n            if not user_obj.exists():\n                messages.error(request, 'username does not exists')\n                return redirect('/login')\n    \n    \n            user_obj = authenticate(username = username, password=password) # authenticate is used to login due to password in not plain\n                                                                                password is encoded\n    \n            if not user_obj:\n                messages.error(request, 'Invalid User')\n                return redirect('/login')\n\n\n            \n            login(request, user_obj)\n            return redirect('/')\n        return render(request, 'login.html')\n\n   \n    def logout_page(request):\n        logout(request)\n        messages.error(request, 'logout successful')\n        return redirect('/login')\n        \n        \n           \n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
