      "text": "from django.db.models import Subquery, OuterRef\n\nlatest_order = Order.objects.filter(user=OuterRef(\"pk\")).order_by(\"-id\")\n\nUser.objects.annotate(\n    latest_order_id=Subquery(latest_order.values(\"id\")[:1])\n)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "from django.db.models import Subquery, OuterRef\n\nlatest_order = Order.objects.filter(user=OuterRef(\"pk\")).order_by(\"-id\")\n\nUser.objects.annotate(\n    latest_order_id=Subquery(latest_order.values(\"id\")[:1])\n)",
      "autoResize": true,
      "lineHeight": 1.25
