      "isDeleted": false,
      "boundElements": [],
      "updated": 1774276737977,
      "link": null,
      "locked": false,
      "text": "we want if user is not authenticated then we will not allow any view, user will be redirected to login page\nfor that 1 way is we can check in each view\n\nif not request.user.is_authenticated:\n    return redirect('/login')",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "we want if user is not authenticated then we will not allow any view, user will be redirected to login page\nfor that 1 way is we can check in each view\n\nif not request.user.is_authenticated:\n    return redirect('/login')",
      "autoResize": true,
      "lineHeight": 1.25
    },
