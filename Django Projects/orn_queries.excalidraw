      "updated": 1774358385778,
      "link": null,
      "locked": false,
      "text": "User.objects.filter(age__gt=18)     # >\nUser.objects.filter(age__lt=30)     # <\nUser.objects.filter(name__icontains=\"amit\")\nUser.objects.filter(created_at__date=\"2026-03-23\")\n\nWHERE age > 18.  -> SQL\nWHERE name LIKE '%amit%'",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User.objects.filter(age__gt=18)     # >\nUser.objects.filter(age__lt=30)     # <\nUser.objects.filter(name__icontains=\"amit\")\nUser.objects.filter(created_at__date=\"2026-03-23\")\n\nWHERE age > 18.  -> SQL\nWHERE name LIKE '%amit%'",
      "autoResize": true,
      "lineHeight": 1.25
    },
