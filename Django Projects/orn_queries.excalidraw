      "containerId": null,
      "originalText": "User.objects.filter(age=25, city=\"Delhi\") -> 👉 AND condition\n\nfrom django.db.models import Q\nUser.objects.filter(Q(age=25) | Q(city=\"Delhi\")) ✔ OR condition",
      "autoResize": true,
