      "link": null,
      "locked": false,
      "text": "from django.db.models import Case, When, Value\n\nUser.objects.annotate(\n    status=Case(\n        When(age__gt=18, then=Value(\"Adult\")),\n        default=Value(\"Minor\")\n    )\n)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "from django.db.models import Case, When, Value\n\nUser.objects.annotate(\n    status=Case(\n        When(age__gt=18, then=Value(\"Adult\")),\n        default=Value(\"Minor\")\n    )\n)",
      "autoResize": true,
      "lineHeight": 1.25
    },
