      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "from django.contrib.auth.decorators import login_required\n\n@login_required(login_url='/login')\ndef index(request):\n    return render(request, 'index.html')\n    ",
      "autoResize": true,
      "lineHeight": 1.25
