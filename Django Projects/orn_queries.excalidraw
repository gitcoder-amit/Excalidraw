      "updated": 1774359770649,
      "link": null,
      "locked": false,
      "text": "User.objects.values(\"id\", \"name\") 👉 Returns dict instead of model objects <QuerySet [{'phone_number': '', 'first_name': ''}, {'phone_number': '1234567891', 'first_name': ''}, {'phone_number': '12345', 'first_name': 'amit'}, {'phone_number': '123456', 'first_name': 'ravi'}, {'phone_number': '1234567', 'first_name': 'Golu'}]>\nUser.objects.values_list(\"name\", flat=True) 👉 Returns list -> without flat <QuerySet [('',), ('12345',), ('123456',), ('1234567',), ('1234567891',)]>\n                    flat only works with single attribute -> with flat -> <QuerySet ['', '12345', '123456', '1234567', '1234567891']>\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "User.objects.values(\"id\", \"name\") 👉 Returns dict instead of model objects <QuerySet [{'phone_number': '', 'first_name': ''}, {'phone_number': '1234567891', 'first_name': ''}, {'phone_number': '12345', 'first_name': 'amit'}, {'phone_number': '123456', 'first_name': 'ravi'}, {'phone_number': '1234567', 'first_name': 'Golu'}]>\nUser.objects.values_list(\"name\", flat=True) 👉 Returns list -> without flat <QuerySet [('',), ('12345',), ('123456',), ('1234567',), ('1234567891',)]>\n                    flat only works with single attribute -> with flat -> <QuerySet ['', '12345', '123456', '1234567', '1234567891']>\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
