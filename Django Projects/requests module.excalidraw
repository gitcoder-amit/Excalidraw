      "text": "🚀 1. GET (Fetch Data) -> 👉 Used for: retrieving data",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "🚀 1. GET (Fetch Data) -> 👉 Used for: retrieving data",
      "autoResize": true,
