    {
      "id": "7iQ11Grdo8XKtLiiMItjb",
      "type": "text",
      "x": 1733.9574483907295,
      "y": 2348.8661352625904,
      "width": 495,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
