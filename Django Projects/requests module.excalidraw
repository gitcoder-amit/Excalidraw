      "text": "pip install python-dotenv\n\nimport os\nfrom dotenv import load_dotenv\n\n# Load .env file\nload_dotenv()\n\n# Read the variable\napi_key = os.getenv(\"API_KEY\")\n\nprint(api_key)  # just to verify (remove later)\n\n\nproject/\n│── .env\n│── main.py\n│── requirements.txt\n\n\n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "pip install python-dotenv\n\nimport os\nfrom dotenv import load_dotenv\n\n# Load .env file\nload_dotenv()\n\n# Read the variable\napi_key = os.getenv(\"API_KEY\")\n\nprint(api_key)  # just to verify (remove later)\n\n\nproject/\n│── .env\n│── main.py\n│── requirements.txt\n\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
