      "seed": 727274966,
      "version": 4,
      "versionNonce": 835500758,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776175532676,
      "link": null,
      "locked": false,
      "text": "import requests\n\nresponse = requests.get(\n    \"https://api.example.com/users\",\n    params={\"page\": 1},\n    headers={\"Authorization\": \"Bearer token\"}\n)\n\nprint(response.json())",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "import requests\n\nresponse = requests.get(\n    \"https://api.example.com/users\",\n    params={\"page\": 1},\n    headers={\"Authorization\": \"Bearer token\"}\n)\n\nprint(response.json())",
      "autoResize": true,
      "lineHeight": 1.25
    },
