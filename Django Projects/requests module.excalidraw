    },
    {
      "id": "agLNhNzngRAdW2UJZHmod",
      "type": "text",
      "x": 1673.4613546407295,
      "y": 906.4870499903802,
      "width": 781,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5s",
      "roundness": null,
      "seed": 1379749898,
      "version": 231,
      "versionNonce": 1946251722,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776176146611,
      "link": null,
      "locked": false,
      "text": "We use requests to communicate with external services over HTTP easily.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We use requests to communicate with external services over HTTP easily.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LGn53frbL9rFUN_taC3dg",
      "type": "text",
      "x": 1666.9926046407295,
      "y": 957.0262915125904,
      "width": 286,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5t",
      "roundness": null,
      "seed": 1574826198,
      "version": 209,
      "versionNonce": 1415825930,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776176066778,
      "link": null,
      "locked": false,
      "text": "🧠 Why do we even need it?",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "🧠 Why do we even need it?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "YldR107UoPyT98f6lb0pK",
      "type": "text",
      "x": 1688.3676046407295,
      "y": 1003.1356665125904,
      "width": 759,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5u",
      "roundness": null,
      "seed": 1519648778,
      "version": 185,
      "versionNonce": 962818890,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776176068696,
      "link": null,
      "locked": false,
      "text": "In backend systems (like your Django apps), your code often needs to:\n\nCall payment APIs\nFetch data from another service\nSend data to an LLM (like Groq)\nIntegrate with third-party tools\n\n👉 All of this happens via HTTP requests",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In backend systems (like your Django apps), your code often needs to:\n\nCall payment APIs\nFetch data from another service\nSend data to an LLM (like Groq)\nIntegrate with third-party tools\n\n👉 All of this happens via HTTP requests",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Hjm5Z1paHSEaO__pQ1bU_",
      "type": "text",
      "x": 1660.6058858907295,
      "y": 1237.8036352625904,
      "width": 572,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5v",
      "roundness": null,
      "seed": 2100032406,
      "version": 75,
      "versionNonce": 1237664906,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776176070945,
      "link": null,
      "locked": false,
      "text": "🚫 Without requests (low-level, messy)\nYou’d have to use built-in modules like http.client:",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "🚫 Without requests (low-level, messy)\nYou’d have to use built-in modules like http.client:",
      "autoResize": true,
      "lineHeight": 1.25
    },
