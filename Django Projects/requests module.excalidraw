      "versionNonce": 119854858,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776175563725,
      "link": null,
      "locked": false,
      "text": "response = requests.post(\n    \"https://api.example.com/users\",\n    json={\n        \"name\": \"Amit\",\n        \"email\": \"amit@example.com\"\n    },\n    headers={\"Authorization\": \"Bearer token\"}\n)\n\nprint(response.json())",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "response = requests.post(\n    \"https://api.example.com/users\",\n    json={\n        \"name\": \"Amit\",\n        \"email\": \"amit@example.com\"\n    },\n    headers={\"Authorization\": \"Bearer token\"}\n)\n\nprint(response.json())",
      "autoResize": true,
      "lineHeight": 1.25
    },
