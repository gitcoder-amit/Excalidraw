    {
      "id": "cF2zYlftT2A4TPBNdjuFp",
      "type": "text",
      "x": 1746.4926046407295,
      "y": 2023.8856665125907,
      "width": 495,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
