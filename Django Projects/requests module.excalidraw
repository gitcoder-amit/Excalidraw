      "text": "🔥 Bonus: Generic Request Method\n\nYou can use one function for everything:",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "🔥 Bonus: Generic Request Method\n\nYou can use one function for everything:",
