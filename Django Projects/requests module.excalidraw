      "lineHeight": 1.25
    },
    {
      "id": "kFC5brIyDxHZY_Ufe3tMu",
      "type": "text",
      "x": 1768.2035421407295,
      "y": 4237.99894776259,
      "width": 440,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
