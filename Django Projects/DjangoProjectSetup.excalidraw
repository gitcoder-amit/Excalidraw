      "link": null,
      "locked": false,
      "text": "-> Able to accept input from user\n\n-> users will directly give input on laptop\n\n-> The game is expected to also recommend best next moves\n\n-> the game will also judge the winning situations that who is\n    more likely to wiin\n\n-> Log every move so that later we should be replay the game\n    and suggest users the best move that could have been made.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-> Able to accept input from user\n\n-> users will directly give input on laptop\n\n-> The game is expected to also recommend best next moves\n\n-> the game will also judge the winning situations that who is\n    more likely to wiin\n\n-> Log every move so that later we should be replay the game\n    and suggest users the best move that could have been made.",
      "autoResize": true,
      "lineHeight": 1.25
    },
