    {
      "id": "xmf03yzviW1kIAWXB6l5Z",
      "type": "text",
      "x": 2814.4064149836013,
      "y": 6352.53034989428,
      "width": 1219.28369140625,
      "height": 540,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f0fc",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bEi",
      "roundness": null,
      "seed": 1770968150,
      "version": 530,
      "versionNonce": 1440299094,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769796658352,
      "link": null,
      "locked": false,
      "text": "We can do this via middleware, we can push our\nlogic inside middleware and it will be checked in every request\n\nor in every request we need to check\n\nif ip == 'x':\n    return \nlike that in this way we need to write in every view function\n\nlets say we have 100 function then we need to implement in all places\nthat is not good way so good way is we willl push this logic into \nour middleware and that will be checked in every request.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We can do this via middleware, we can push our\nlogic inside middleware and it will be checked in every request\n\nor in every request we need to check\n\nif ip == 'x':\n    return \nlike that in this way we need to write in every view function\n\nlets say we have 100 function then we need to implement in all places\nthat is not good way so good way is we willl push this logic into \nour middleware and that will be checked in every request.",
      "autoResize": true,
      "lineHeight": 1.25
    },
