    {
      "id": "2v-VIKw6etqWnrkvVn6Oe",
      "type": "text",
      "x": 2920.507947256861,
      "y": 11278.310276640126,
      "width": 1267.1993408203125,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFn",
      "roundness": null,
      "seed": 1318851177,
      "version": 146,
      "versionNonce": 1224627207,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769881568380,
      "link": null,
      "locked": false,
      "text": "One User can have multiple stores at diff diff locations like UP\nBangalore, Hyderabad etc",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "One User can have multiple stores at diff diff locations like UP\nBangalore, Hyderabad etc",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "TAq_4cq8W_xEk_jRXyrKr",
      "type": "text",
      "x": 2113.0493904824643,
      "y": 12234.344922856486,
      "width": 2217.5986328125,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFo",
      "roundness": null,
      "seed": 1237708711,
      "version": 255,
      "versionNonce": 1039872297,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769881777896,
      "link": null,
      "locked": false,
      "text": "If we want to show sales of an store then we need bmp_id, here we write logic of if request header\nnot containg bmp_id then user should not be able to access that store. we will write custom middleware for this.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If we want to show sales of an store then we need bmp_id, here we write logic of if request header\nnot containg bmp_id then user should not be able to access that store. we will write custom middleware for this.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wN5yd7614qpIaAQosMfPT",
      "type": "text",
      "x": 1978.3205026443707,
      "y": 7996.928787394281,
      "width": 1113.1446533203125,
      "height": 376.1594082446808,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFp",
      "roundness": null,
      "seed": 1116205246,
      "version": 247,
      "versionNonce": 1114732578,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773325803238,
      "link": null,
      "locked": false,
      "text": "EC2 Machine\n    nginx (process running on port 80)\n    gunicorn (process running on port 8000)\n    django application code\n\nSO nginx is just a process that handle http request \nand forward to gunicorn \n\nNginx is a web server (process) that receives HTTP requests \nfrom clients and forwards dynamic requests to Gunicorn \nwhile optionally serving static files and handling other web server tasks.",
      "fontSize": 27.357047872340424,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "EC2 Machine\n    nginx (process running on port 80)\n    gunicorn (process running on port 8000)\n    django application code\n\nSO nginx is just a process that handle http request \nand forward to gunicorn \n\nNginx is a web server (process) that receives HTTP requests \nfrom clients and forwards dynamic requests to Gunicorn \nwhile optionally serving static files and handling other web server tasks.",
      "autoResize": true,
      "lineHeight": 1.25
    },
