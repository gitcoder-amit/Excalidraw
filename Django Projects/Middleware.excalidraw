      "locked": false,
      "text": "from django.http import HttpResponseForbidden\n\n\nBlocked_IPS = ['123.45.67.89', '987.56.65.21']\n\nclass IPBlockingMiddleware:\n    \"\"\"\n    Middleware to block requests from specific IP addresses.\n    \"\"\"\n\n    def __init__(self, get_response):\n        self.get_response = get_response\n\n    def __call__(self, request):\n        ip = request.META.get('REMOTE_ADDR')\n        if ip in Blocked_IPS:\n            return HttpResponseForbidden(\"Forbidden: IP not allowed.\")\n        response = self.get_response(request)\n        return response\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "from django.http import HttpResponseForbidden\n\n\nBlocked_IPS = ['123.45.67.89', '987.56.65.21']\n\nclass IPBlockingMiddleware:\n    \"\"\"\n    Middleware to block requests from specific IP addresses.\n    \"\"\"\n\n    def __init__(self, get_response):\n        self.get_response = get_response\n\n    def __call__(self, request):\n        ip = request.META.get('REMOTE_ADDR')\n        if ip in Blocked_IPS:\n            return HttpResponseForbidden(\"Forbidden: IP not allowed.\")\n        response = self.get_response(request)\n        return response\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
