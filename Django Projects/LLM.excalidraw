      "boundElements": [],
      "updated": 1770902289153,
      "link": null,
      "locked": false,
      "text": "Api Call to github\n\nhttps://api.github.com/repos/gitcoder-amit/FoodOrdering-App\nhttps://api.github.com/repos/gitcoder-amit/Django-Projects/contents/project_middleware/manage.py. -> this will give content of manage.py in base64 encoded string\n\n\nimport base64\ncode_str = \"\"\"content\"\"\"\nprint(base64.b64decode(code_str).decode()) -> this will give the content of manage.py\n\n\nbase64 is just a format anyone can use it. \nencryption is different thing for that we need salt and key to decrypt.\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Api Call to github\n\nhttps://api.github.com/repos/gitcoder-amit/FoodOrdering-App\nhttps://api.github.com/repos/gitcoder-amit/Django-Projects/contents/project_middleware/manage.py. -> this will give content of manage.py in base64 encoded string\n\n\nimport base64\ncode_str = \"\"\"content\"\"\"\nprint(base64.b64decode(code_str).decode()) -> this will give the content of manage.py\n\n\nbase64 is just a format anyone can use it. \nencryption is different thing for that we need salt and key to decrypt.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
