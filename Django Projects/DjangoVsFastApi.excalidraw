    {
      "id": "oQua7TCqolb_gd0TxZ46K",
      "type": "text",
      "x": 2004.6850358576967,
      "y": 981.1874665930809,
      "width": 627,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
