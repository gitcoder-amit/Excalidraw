    {
      "id": "GkBd2BkgG4_8LRNTePsTx",
      "type": "text",
      "x": 2026.0411422125815,
      "y": 7208.557823961252,
      "width": 11,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
