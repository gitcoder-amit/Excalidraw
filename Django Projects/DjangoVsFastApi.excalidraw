    {
      "id": "WE8PyfjCSV55wLvcLRCjr",
      "type": "text",
      "x": 1957.0170671076967,
      "y": 4637.894497843081,
      "width": 275,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFH",
      "roundness": null,
      "seed": 1628383211,
      "version": 176,
      "versionNonce": 718815329,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775226369120,
      "link": null,
      "locked": false,
      "text": "Nginx\n  ↓\nGunicorn (8 workers)\n  ↓\nDjango\n\nCapacity:\n    8 concurrent requests\n\nIf 100 users hit the API:\n    8 active\n    92 waiting",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Nginx\n  ↓\nGunicorn (8 workers)\n  ↓\nDjango\n\nCapacity:\n    8 concurrent requests\n\nIf 100 users hit the API:\n    8 active\n    92 waiting",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "aGY8El9ACFM1GA4JUtnO6",
      "type": "text",
      "x": 1891.8803483576967,
      "y": 4990.906216593081,
      "width": 1067,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
