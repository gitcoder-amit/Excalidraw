      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "YjR0psWr65IKTdS2sfovx",
      "type": "text",
      "x": 1620.8803483576967,
      "y": 1619.054654093081,
      "width": 900.3125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
