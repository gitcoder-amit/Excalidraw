    },
    {
      "id": "QLxXNKS98cbQUKvz95kmF",
      "type": "text",
      "x": 2072.3022233576967,
      "y": 875.6835603430809,
      "width": 363,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
