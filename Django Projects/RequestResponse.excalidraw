      "updated": 1773235365038,
      "link": null,
      "locked": false,
      "text": "2️⃣ What WSGI Actually Does?\nThink of WSGI as a translator layer.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2️⃣ What WSGI Actually Does?\nThink of WSGI as a translator layer.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qlJyNn3iymzcbRiyA8jQG",
      "type": "text",
      "x": 2097.0990983576967,
      "y": 159.6991853430809,
      "width": 330,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bEj",
      "roundness": null,
      "seed": 461823755,
      "version": 417,
      "versionNonce": 1805480057,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773235365038,
      "link": null,
      "locked": false,
      "text": "Browser\n   │\n   ▼\nHTTP Request\n   │\n   ▼\nWeb Server (Nginx)\n   │\n   ▼\nWSGI Server (Gunicorn / uWSGI)\n   │\n   ▼\nPython App (Django / Flask)",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Browser\n   │\n   ▼\nHTTP Request\n   │\n   ▼\nWeb Server (Nginx)\n   │\n   ▼\nWSGI Server (Gunicorn / uWSGI)\n   │\n   ▼\nPython App (Django / Flask)",
      "autoResize": true,
      "lineHeight": 1.25
    },
