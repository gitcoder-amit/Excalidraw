      "originalText": "",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "rwo17gQLBbJLbYkp4k-CA",
      "type": "text",
      "x": 1976.0795671076967,
      "y": 3423.812466593081,
      "width": 209,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFA",
      "roundness": null,
      "seed": 890741931,
      "version": 164,
      "versionNonce": 1634439321,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773235365038,
      "link": null,
      "locked": false,
      "text": "Receive request\n↓\nProcess request\n↓\nReturn response\n↓\nHandle next request\n\nNo async/await.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Receive request\n↓\nProcess request\n↓\nReturn response\n↓\nHandle next request\n\nNo async/await.",
