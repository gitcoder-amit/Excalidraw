    {
      "id": "UXx6QNW4kPqxOjrA5T-Lf",
      "type": "text",
      "x": 2005.4780046076967,
      "y": -340.9765959069191,
      "width": 1122,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
