      "boundElements": [],
      "updated": 1773235365038,
      "link": null,
      "locked": false,
      "text": "That would be extremely complex.\nSo WSGI handles all this for you.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "That would be extremely complex.\nSo WSGI handles all this for you.",
      "autoResize": true,
