      "isDeleted": false,
      "boundElements": [],
      "updated": 1773235365038,
      "link": null,
      "locked": false,
      "text": "3️⃣ Real Example Without WSGI\nSuppose a request comes:",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3️⃣ Real Example Without WSGI\nSuppose a request comes:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_Z9GdIbR0YwHpcCayzZpM",
      "type": "text",
      "x": 2079.6928483576967,
      "y": 707.7655915930809,
      "width": 484,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bEo",
      "roundness": null,
      "seed": 2006609477,
      "version": 238,
      "versionNonce": 10021881,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773235365038,
      "link": null,
      "locked": false,
      "text": "raw_request = \"GET /products?id=10 HTTP/1.1\"\n\n# parse method\n# parse headers\n# parse body\n# route request",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "raw_request = \"GET /products?id=10 HTTP/1.1\"\n\n# parse method\n# parse headers\n# parse body\n# route request",
      "autoResize": true,
