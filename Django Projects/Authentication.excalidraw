      "seed": 419066420,
      "version": 216,
      "versionNonce": 1680421772,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770139961675,
      "link": null,
      "locked": false,
      "text": "Django inbuild User has lot of fields like\nfirst_name\nlast_name\nemail\npassword\nusername\ngroup and others\nand function for authentication like is_authenticated & all",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Django inbuild User has lot of fields like\nfirst_name\nlast_name\nemail\npassword\nusername\ngroup and others\nand function for authentication like is_authenticated & all",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "iRtdTcKYRUfLkW27lJTj_",
      "type": "text",
      "x": 208.79285650186125,
      "y": 5787.088808705233,
      "width": 19.79998779296875,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bII",
      "roundness": null,
      "seed": 379440012,
      "version": 3,
      "versionNonce": 542590516,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1770139037606,
