    {
      "id": "-8cY5rWaRTUey2ELG6h9R",
      "type": "text",
      "x": 1703.4994666679863,
      "y": 11584.788791959669,
      "width": 19.79998779296875,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
