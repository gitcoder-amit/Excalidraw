    {
      "id": "C5pkbEs2MFCtJ0EbyelKu",
      "type": "text",
      "x": -343.38737099256446,
      "y": 5811.008819853505,
      "width": 1168.199462890625,
      "height": 360,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
